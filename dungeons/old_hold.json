  "props": [
    {
      "type": "sign",
      "pos": [
        -2.0,
        0.0,
        -1.0
      ],
      "rotation_y": 3.14159,
      "message": "The hearth is cold.\n\nYou can still smell pine-smoke if you stand close enough. Or you think you can. Sometimes the wanting is enough."
    },
    {
      "type": "sign",
      "pos": [
        2.0,
        0.0,
        -1.0
      ],
      "rotation_y": 3.14159,
      "message": "Two chairs by the cold hearth.\n\nThe chair where she sat. The chair where he sat. They are turned a little toward each other still."
    },
    {
      "type": "sign",
      "pos": [
        0.0,
        0.0,
        4.0
      ],
      "rotation_y": 3.14159,
      "message": "The garden has gone to seed.\n\nWhat the Wyrdkin planted has spread, and softened, and become the kind of green that does not need keeping."
    },
    {
      "type": "sign",
      "pos": [
        -3.0,
        0.0,
        2.0
      ],
      "rotation_y": 3.14159,
      "message": "An old letter, folded into the wall:\n\n\"My own one \u2014 I will be back before the snow that we do not have. The road is long but the road is the road. Keep my chair warm. Walk well.\""
    },
    {
      "type": "sign",
      "pos": [
        3.0,
        0.0,
        2.0
      ],
      "rotation_y": 3.14159,
      "message": "A recipe scratched into the table-edge:\n\n\"Sweetfern pie. Three handfuls of sweetfern. Two of root-honey. One of patience. The Wyrdkin do not make this any more.\""
    },
    {
      "type": "sign",
      "pos": [
        0.0,
        0.0,
        -4.0
      ],
      "rotation_y": 3.14159,
      "message": "A small memorial stone outside the back door:\n\n\"Two names, kept close.\nWalk well, both of you.\""
    },
    {
      "type": "chest",
      "pos": [
        0.0,
        0.0,
        0.0
      ],
      "rotation_y": 0.0,
      "contents": "heart",
      "open_message": "A Heart Container \u2014 the line endures."
    },
    {
      "type": "npc",
      "pos": [
        0.0,
        0.0,
        -1.0
      ],
      "rotation_y": 3.14159,
      "name": "Old Wyrdkin Grandmother",
      "body_color": [
        0.92,
        0.92,
        0.95,
        1.0
      ],
      "hat_color": [
        0.85,
        0.78,
        0.72,
        1.0
      ],
      "idle_hint": "[E] Speak softly",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Old Wyrdkin Grandmother",
            "text": "Oh \u2014 oh, who is that? The light is wrong, child. Stand a little closer. My eyes are a memory of eyes.",
            "choices": [
              {
                "label": "It's me. Tux.",
                "next": "name"
              }
            ]
          },
          "name": {
            "speaker": "Old Wyrdkin Grandmother",
            "text": "Tux. Tux. The name is fond on the tongue. I knew a Tux once \u2014 small as a kettle, brave as a kettle on the boil. Are you that one?",
            "choices": [
              {
                "label": "I think I am.",
                "next": "warm"
              }
            ]
          },
          "warm": {
            "speaker": "Old Wyrdkin Grandmother",
            "text": "Then come a little closer. The hearth is cold but the room remembers being warm. Sit a moment with an old ghost. Tell me \u2014 do you carry a sword?",
            "choices": [
              {
                "label": "Bone-and-wood.",
                "next": "look"
              }
            ]
          },
          "look": {
            "speaker": "Old Wyrdkin Grandmother",
            "text": "Bone-and-wood. He carried bone-and-wood, my own one did. Let me see your face properly, child. Lirien's breath \u2014",
            "choices": [
              {
                "label": "...",
                "next": "eyes"
              }
            ]
          },
          "eyes": {
            "speaker": "Old Wyrdkin Grandmother",
            "text": "You have her eyes.",
            "sets": "met_grandmother"
          }
        }
      }
    },
