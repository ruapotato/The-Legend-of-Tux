    {
      "type": "sign",
      "pos": [
        -2.5,
        0.0,
        2.5
      ],
      "rotation_y": 3.141592653589793,
      "message": "SPRAWL OUTPOST\n\nA single guardpost at the edge of the Sprawl. The merchants pay her wages. She does not pretend to like the merchants.\n\nThe sister-watch on the Crown is older. The watches keep an open door."
    },
    {
      "type": "sign",
      "pos": [
        2.5,
        0.0,
        2.5
      ],
      "rotation_y": 3.141592653589793,
      "message": "Posted on a small board:\n\n'The watch keeps. The watch is paid in pebbles. The watch would keep regardless.'"
    },
    {
      "type": "npc",
      "pos": [
        -0.5,
        0.0,
        0.5
      ],
      "rotation_y": 3.141592653589793,
      "name": "Outpost Sentinel Quenn",
      "body_color": [
        0.45,
        0.48,
        0.55,
        1.0
      ],
      "hat_color": [
        0.4,
        0.42,
        0.4,
        1.0
      ],
      "idle_hint": "[E] Address the sentinel",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Outpost Sentinel Quenn",
            "text": "*she nods once. The hand on the spear does not move.*\n\nWalker. The Outpost is kept. Pass through if you've a reason. Don't if you don't.",
            "choices": [
              {
                "label": "What do you watch for?",
                "next": "watch"
              },
              {
                "label": "Are you alone here?",
                "next": "alone"
              },
              {
                "label": "Walk well.",
                "next": "bye"
              }
            ]
          },
          "watch": {
            "speaker": "Outpost Sentinel Quenn",
            "text": "Whatever the merchants have decided to be afraid of this season. Mostly other merchants.\n\nThe sister-watch up on the Crown \u2014 her hall is older than this one. The walk between is open. The watches keep open doors.",
            "choices": [
              {
                "label": "Walk well.",
                "next": "bye"
              }
            ]
          },
          "alone": {
            "speaker": "Outpost Sentinel Quenn",
            "text": "Alone enough. The sister-watch can hear me if I call. So can the realm.\n\nI don't call often.",
            "choices": [
              {
                "label": "Walk well.",
                "next": "bye"
              }
            ]
          },
          "bye": {
            "speaker": "Outpost Sentinel Quenn",
            "text": "Walk well. The watch is kept."
          }
        }
      }
    },
