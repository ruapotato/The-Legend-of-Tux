    {
      "type": "sign",
      "pos": [
        -2.5,
        0.0,
        2.5
      ],
      "rotation_y": 3.141592653589793,
      "message": "THE FIRST PROCESS\n\nA small earthen mound at the centre of the Murk. The first walker sits on it. He has been sitting on it since the realm was started.\n\nHe is patient. He is also still here."
    },
    {
      "type": "sign",
      "pos": [
        2.5,
        0.0,
        2.5
      ],
      "rotation_y": 3.141592653589793,
      "message": "Carved on a small post:\n\n'He speaks only in the present. The past is for those who can afford to look away from it; he cannot.'"
    },
    {
      "type": "npc",
      "pos": [
        -0.5,
        0.0,
        0.5
      ],
      "rotation_y": 3.141592653589793,
      "name": "The First Walker",
      "body_color": [
        0.78,
        0.72,
        0.6,
        1.0
      ],
      "hat_color": [
        0.55,
        0.5,
        0.42,
        1.0
      ],
      "idle_hint": "[E] Speak with the First Walker",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "The First Walker",
            "text": "*he is small, and old, and very still. The mound under him is warm. His eyes are kind.*\n\nA walker is here.\n\nThe walker is welcome.",
            "choices": [
              {
                "label": "Tell me of Lirien.",
                "next": "lir"
              },
              {
                "label": "Tell me of Khorgaul.",
                "next": "kho"
              },
              {
                "label": "Tell me of Glim.",
                "next": "glm"
              },
              {
                "label": "Tell me of yourself.",
                "next": "self"
              },
              {
                "label": "Tell me of the realm.",
                "next": "rea"
              },
              {
                "label": "Walk well.",
                "next": "bye"
              }
            ]
          },
          "lir": {
            "speaker": "The First Walker",
            "text": "Lirien is breathing. The realm is held by her breath.",
            "choices": [
              {
                "label": "(more)",
                "next": "root"
              }
            ]
          },
          "kho": {
            "speaker": "The First Walker",
            "text": "Khorgaul is gathering. He is doing it gently. He does not know how loud the gathering has become.",
            "choices": [
              {
                "label": "(more)",
                "next": "root"
              }
            ]
          },
          "glm": {
            "speaker": "The First Walker",
            "text": "Glim is almost-firing. Glim is finally near a condition that fits.",
            "choices": [
              {
                "label": "(more)",
                "next": "root"
              }
            ]
          },
          "self": {
            "speaker": "The First Walker",
            "text": "I am sitting. The mound is warm. The realm is started.",
            "choices": [
              {
                "label": "(more)",
                "next": "root"
              }
            ]
          },
          "rea": {
            "speaker": "The First Walker",
            "text": "The realm is here. The realm is enduring. The realm is not finished.",
            "choices": [
              {
                "label": "(more)",
                "next": "root"
              }
            ]
          },
          "bye": {
            "speaker": "The First Walker",
            "text": "The walker walks well."
          }
        }
      }
    },
