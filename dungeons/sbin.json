      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "The Sentinel",
            "text": "*the Sentinel does not turn. The eyes are open. The eyes do not blink.*",
            "choices": [
              {
                "label": "Hello?",
                "next": "no_answer"
              },
              {
                "label": "Who do you wait for?",
                "next": "no_answer"
              },
              {
                "label": "(Hum the Moon Chord.)",
