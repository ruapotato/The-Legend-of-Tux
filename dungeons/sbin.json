      ],
      "rotation_y": 3.141592653589793,
      "message": "SENTINEL HALL\n\nThe quiet wardens stand here. They were set in stone before any Wyrdkin came north. They have not moved.\n\nThey are not asleep."
    },
    {
      "type": "sign",
      "pos": [
        2.5,
        0.0,
        2.5
      ],
      "rotation_y": 3.141592653589793,
      "message": "A small carved line at the base of the floor:\n\n'Speak the right thing and the watch will answer. Speak the wrong thing and the watch will not.'"
    },
    {
      "type": "npc",
      "pos": [
        0.0,
        0.0,
        1.5
      ],
      "rotation_y": 3.141592653589793,
      "name": "The Sentinel",
      "body_color": [
        0.42,
        0.45,
        0.5,
        1.0
      ],
      "hat_color": [
        0.32,
        0.34,
        0.38,
        1.0
      ],
      "idle_hint": "[E] Address the Sentinel",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "The Sentinel",
            "text": "*the Sentinel does not turn. The eyes are open. The eyes do not blink.*",
            "choices": [
              {"label": "Hello?", "next": "no_answer"},
              {"label": "Who do you wait for?", "next": "no_answer"},
              {"label": "(Hum the Moon Chord.)", "next": "answer", "requires_song": "moon_chord"},
              {"label": "Walk away.", "next": "leave"}
            ]
          },
          "no_answer": {
            "speaker": "The Sentinel",
            "text": "*no answer. The light on its shoulder does not flicker.*",
            "choices": [
              {"label": "...", "next": "root"}
            ]
          },
          "answer": {
            "speaker": "The Sentinel",
            "text": "*the head turns. Slow. The voice is older than stone-cutting.*\n\nWalker. The watch is kept. The realm endures.\n\nGo well. Go quietly. The next door north is the Crown.",
            "choices": [
              {"label": "Walk well.", "next": "leave"}
            ]
          },
          "leave": {
            "speaker": "The Sentinel",
            "text": "*the Sentinel is again as it was.*"
          }
        }
      }
    }
