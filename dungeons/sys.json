  "props": [
    {
      "type": "sign",
      "pos": [
        -2.5,
        0.0,
        2.5
      ],
      "rotation_y": 3.141592653589793,
      "message": "THE HEARTWORKS\n\nA glassed-in observatory beneath the Murk. The Source can be seen here in slow, steady pulses \u2014 each one a heartbeat of the realm.\n\nWatch for as long as you like. It will not stop while you watch."
    },
    {
      "type": "sign",
      "pos": [
        2.5,
        0.0,
        3.5
      ],
      "rotation_y": 3.141592653589793,
      "message": "Faded notice on the inner wall:\n\n'Each pulse is a kept promise. No promise is kept silently \u2014 there is always a song in it. The reader who counts pulses also hums.'\n\n\u2014 Thallin, Heart-Reader, two ages ago."
    },
    {
      "type": "npc",
      "pos": [
        -0.5,
        0.0,
        0.5
      ],
      "rotation_y": 3.141592653589793,
      "name": "Heart-Reader Velis",
      "body_color": [
        0.45,
        0.55,
        0.78,
        1.0
      ],
      "hat_color": [
        0.85,
        0.85,
        0.95,
        1.0
      ],
      "idle_hint": "[E] Speak softly with the Heart-Reader",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Heart-Reader Velis",
            "text": "*she has one hand on the glass and her eyes half-closed.*\n\nQuiet, walker. I am counting.\n\n...there. Two thousand and fourteen since dawn. The realm is well today.",
            "choices": [
              {
                "label": "What are you counting?",
                "next": "count"
              },
              {
                "label": "Have you a hint for me?",
                "next": "hint"
              },
              {
                "label": "Walk well.",
                "next": "bye"
              }
            ]
          },
          "count": {
            "speaker": "Heart-Reader Velis",
            "text": "Heartbeats. The realm has them. Each one is the Source breathing in and out. Each one is a small kept promise.\n\nWhen the count slows, somewhere a shrine is dimming. When the count steadies, somewhere a walker has done something kind.",
            "choices": [
              {
                "label": "Have you a hint for me?",
                "next": "hint"
              },
              {
                "label": "Walk well.",
                "next": "bye"
              }
            ]
          },
          "hint": {
            "speaker": "Heart-Reader Velis",
            "text": "*she turns from the glass, finally.*\n\nThe pulses make a song-glyph if you stand here long enough. Three high beats, one low, three high again. The realm hums it to itself.\n\nIf you ever learn to hum back, walker \u2014 the right doors might open for you.",
            "choices": [
              {
                "label": "Walk well.",
                "next": "bye"
              }
            ]
          },
          "bye": {
            "speaker": "Heart-Reader Velis",
            "text": "Walk well. Step quietly through the next door. The pulses notice."
          }
        }
      }
    },
