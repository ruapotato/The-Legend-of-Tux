[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3, 0.218, -42)
message = "MIRELAKE.\n\nThe Source slows here, settling between the reeds. Black streams trickle in from the Burnt Hollow to the west, staining the water like old ink."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3, -0.014, -42)
message = "Step lightly, traveler. The peat will swallow what it can. The wisps know the path — if they don't mean you harm, follow them."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0.529, 14)
message = "Half-sunken cairns of Source-stone, raised by older hands than ours. Lirien's name is carved on the lowest course — the rest is mud."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, -0.2, 36)
message = "The shrine drowns, year by year. Whatever the keepers warded sleeps under the water now. The wisps gather thickest here."

[node name="Chest4" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0.614, 44)
contents_scene = ExtResource("boomerang_pickup")
open_message = "An offering of the keepers, preserved in pitch and reed. A curved Source-blade that returns to the hand that throws it."

[node name="Chest5" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, -0.69, -4)
