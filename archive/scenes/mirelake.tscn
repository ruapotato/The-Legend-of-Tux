dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Sunken Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires\": \"anchor_boots\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"anchor_boots\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Sunken Stone\", \"text\": \"The Maw lives below the lake-floor. To reach it, you must walk down.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Sunken Stone\", \"text\": \"The Boots will hold you down. The Maw will not flee.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Sunken Stone\", \"text\": \"*The hum fades.*\"}}}"

