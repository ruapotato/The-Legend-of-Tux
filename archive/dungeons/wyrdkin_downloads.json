      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Postal-Wyrd Hessa",
            "text": "Mm. I keep leaving it here. The pile by the door. I\nmean to read it, and then a day goes by, and the pile\ngrows.",
            "choices": [
              {
                "label": "Anything from far away?",
                "next": "far"
              },
              {
                "label": "Why not just open one?",
                "next": "open"
              },
              {
                "label": "Walk well."
              }
            ]
          },
          "far": {
            "speaker": "Postal-Wyrd Hessa",
            "text": "A folded scroll on top \u2014 from somewhere I cannot place.\nCould be the Drift. Could be older than the Drift.",
            "choices": [
              {
                "label": "Walk well."
              }
            ]
          },
          "open": {
            "speaker": "Postal-Wyrd Hessa",
            "text": "Because then there will be a thing to do, child. And\nI am not yet ready for a thing to do.",
            "choices": [
              {
                "label": "Walk well."
              }
            ]
          }
        }
      }
    },
