      ],
      "idle_hint": "[E] Talk to Wren",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Little Wren",
            "text": "*chases an invisible thing*\nCome BACK, Tuffins! Tuffins is my favorite lambwisp and she is REALLY FAST and also INVISIBLE because she is hiding which is RUDE.",
            "next": "two"
          },
          "two": {
            "speaker": "Little Wren",
            "text": "Have you seen her? She has — well, she has wool. And a chime. And a tiny attitude. ...You haven't, have you. Sigh. *runs off*"
          }
        }
      }
