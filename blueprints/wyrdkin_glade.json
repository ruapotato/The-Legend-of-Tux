  "tux_props": [
    {
      "type": "npc",
      "pos": [
        3.0,
        0.0,
        8.0
      ],
      "rotation_y": -2.0,
      "name": "Old Hesper",
      "body_color": [
        0.5,
        0.65,
        0.7,
        1.0
      ],
      "hat_color": [
        0.3,
        0.45,
        0.55,
        1.0
      ],
      "idle_hint": "[E] Speak with the keeper",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Old Hesper",
            "text": "Welcome to the Glade, little one. I am Hesper, oldest of the keepers here. The wyrdkin sleep, and we tend their dreaming. You wake into a strange hour. Will you sit, and learn?",
            "choices": [
              {
                "label": "Tell me of this realm.",
                "next": "realm"
              },
              {
                "label": "What is the Sigil of Sharing?",
                "next": "sigil"
              },
              {
                "label": "Who is Glim?",
                "next": "glim"
              },
              {
                "label": "Where should I go?",
                "next": "go"
              },
              {
                "label": "Farewell, keeper.",
                "next": "bye"
              }
            ]
          },
          "realm": {
            "speaker": "Old Hesper",
            "text": "This is Lirien's weave. Forest, brook, kiln, and stone — all spun from the Source. The Maker gave; the Hoarder takes. The balance has tipped, and so the wardstones thin. That is why you are here.",
            "choices": [
              {
                "label": "What is the Sigil of Sharing?",
                "next": "sigil"
              },
              {
                "label": "Who is Glim?",
                "next": "glim"
              },
              {
                "label": "Back.",
                "next": "root"
              }
            ]
          },
          "sigil": {
            "speaker": "Old Hesper",
            "text": "Three sigils mark the Triglyph — Sight, Shaping, Sharing. Yours is the third. To share is to refuse the hoard; to refuse the hoard is to be the answer to Khorgaul. Carry it gently. Carry it bright.",
            "choices": [
              {
                "label": "Who is Glim?",
                "next": "glim"
              },
              {
                "label": "Tell me of this realm.",
                "next": "realm"
              },
              {
                "label": "Back.",
                "next": "root"
              }
            ]
          },
          "glim": {
            "speaker": "Old Hesper",
            "text": "A wisp — a fleck of the Source given a small, brave will. She has chosen you, and that is no small thing. Where you are dim, Glim brightens. Where you forget, Glim remembers.",
            "choices": [
              {
                "label": "Where should I go?",
                "next": "go"
              },
              {
                "label": "Back.",
                "next": "root"
              }
            ]
          },
          "go": {
            "speaker": "Old Hesper",
            "text": "North, through the wyrdwood. Past the fork, past the ribbon, into the Hollow. You will know it when you see it. The road from there is yours to find.",
            "choices": [
              {
                "label": "Thank you, keeper.",
                "next": "bye"
              }
            ]
          },
          "bye": {
            "speaker": "Old Hesper",
            "text": "Walk in the green. Walk under the wing of Lirien."
          }
        }
      }
    },
    {
      "type": "npc",
      "pos": [
        -4.0,
        0.0,
        -6.0
      ],
      "rotation_y": 1.5,
      "name": "Little Pip",
      "body_color": [
        0.65,
        0.8,
        0.75,
        1.0
      ],
      "hat_color": [
        0.55,
        0.7,
        0.85,
        1.0
      ],
      "idle_hint": "[E] Talk to Pip",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Little Pip",
            "text": "Are you the wanderer? Hesper said a wanderer would come. Are you going north? You should go north! The wyrdwood is north!",
            "next": "two"
          },
          "two": {
            "speaker": "Little Pip",
            "text": "I'm not allowed to go past the marker stone. But you can! Go on! The trees there know secrets. I think they whisper them to wisps. Maybe Glim already knows!"
          }
        }
      }
    },
    {
      "type": "npc",
      "pos": [
        0.0,
        0.5,
        4.0
      ],
      "rotation_y": 3.14,
      "name": "Glim",
      "body_color": [
        0.95,
        0.92,
        0.55,
        1.0
      ],
      "hat_color": [
        1.0,
        0.85,
        0.3,
        1.0
      ],
      "idle_hint": "[E] Listen to Glim",
      "dialog_tree": {
        "start": "root",
        "nodes": {
          "root": {
            "speaker": "Glim",
            "text": "*The little wisp pulses, gentle and curious.* You hear me, don't you. The Source still moves through you. Good.",
            "choices": [
              {
                "label": "Teach me a song.",
                "next": "teach",
                "requires_not": "glim_theme_learned"
              },
              {
                "label": "(You hum the song to yourself.)",
                "next": "remembered",
                "requires_song": "glim_theme"
              },
              {
                "label": "Goodbye.",
                "next": "bye"
              }
            ]
          },
          "teach": {
            "speaker": "Glim",
            "text": "Listen — and remember. *up... right... down... left... up.* Carry it. Hum it at any owl-shrine and the keepers will tend you. *[Z] to hum.*",
            "learns_song": "glim_theme",
            "next": "bye"
          },
          "remembered": {
            "speaker": "Glim",
            "text": "Yes. The melody's in you now. The Source remembers what you remember.",
            "next": "bye"
          },
          "bye": {
            "speaker": "Glim",
            "text": "*Glim drifts a little higher and waits.*"
          }
        }
      }
    },
    {
      "type": "sign",
      "pos": [
        -1.5,
        0,
        4
      ],
      "rotation_y": 0,
      "message": "Wyrdkin Glade.\n\nThe wyrdkin sleep beneath the great trees, and Glim flickers at your shoulder. South, beyond the elder pines, the path runs to the Wyrdwood."
    },
    {
      "type": "sign",
      "pos": [
        4,
        0,
        -2
      ],
      "rotation_y": -1.5708,
      "message": "Glim chimes once, gently. \"You can read what's left of the Source by Sight,\" she says, \"but only one Sigil can pass it on. We carry that one.\""
    },
    {
      "type": "sign",
      "pos": [
        -6,
        0,
        8
      ],
      "rotation_y": 0,
      "message": "A wyrdkin-stone, cool to the touch.\n\n\"Lirien's roots reach here. The Source whispers in the leaves — listen, and you may hear your own name spoken back.\""
    },
    {
      "type": "sign",
      "pos": [
        -12,
        0,
        7
      ],
      "rotation_y": 0,
      "message": "A leaf-curtain stirs against the wall — there is a hollow behind it."
    },
