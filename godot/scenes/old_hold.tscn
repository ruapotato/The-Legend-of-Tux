[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -2, -1.461, -1)
message = "The hearth is cold.\n\nYou can still smell pine-smoke if you stand close enough. Or you think you can. Sometimes the wanting is enough."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 2, -1.31, -1)
message = "Two chairs by the cold hearth.\n\nThe chair where she sat. The chair where he sat. They are turned a little toward each other still."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -1.581, 4)
message = "The garden has gone to seed.\n\nWhat the Wyrdkin planted has spread, and softened, and become the kind of green that does not need keeping."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, -1.585, 2)
message = "An old letter, folded into the wall:\n\n\"My own one — I will be back before the snow that we do not have. The road is long but the road is the road. Keep my chair warm. Walk well.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, -1.322, 2)
message = "A recipe scratched into the table-edge:\n\n\"Sweetfern pie. Three handfuls of sweetfern. Two of root-honey. One of patience. The Wyrdkin do not make this any more.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -1.344, -4)
message = "A small memorial stone outside the back door:\n\n\"Two names, kept close.\nWalk well, both of you.\""

[node name="Chest6" parent="." instance=ExtResource("chest")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -1.341, 0)
contents_scene = ExtResource("heart_pickup")
open_message = "A Heart Container — the line endures."

[node name="Npc7_Old_Wyrdkin_Grandmother" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -1.344, -1)
npc_name = "Old Wyrdkin Grandmother"
body_color = Color(0.92, 0.92, 0.95, 1)
hat_color = Color(0.85, 0.78, 0.72, 1)
idle_hint = "[E] Speak softly"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Old Wyrdkin Grandmother\", \"text\": \"Oh — oh, who is that? The light is wrong, child. Stand a little closer. My eyes are a memory of eyes.\", \"choices\": [{\"label\": \"It's me. Tux.\", \"next\": \"name\"}]}, \"name\": {\"speaker\": \"Old Wyrdkin Grandmother\", \"text\": \"Tux. Tux. The name is fond on the tongue. I knew a Tux once — small as a kettle, brave as a kettle on the boil. Are you that one?\", \"choices\": [{\"label\": \"I think I am.\", \"next\": \"warm\"}]}, \"warm\": {\"speaker\": \"Old Wyrdkin Grandmother\", \"text\": \"Then come a little closer. The hearth is cold but the room remembers being warm. Sit a moment with an old ghost. Tell me — do you carry a sword?\", \"choices\": [{\"label\": \"Bone-and-wood.\", \"next\": \"look\"}]}, \"look\": {\"speaker\": \"Old Wyrdkin Grandmother\", \"text\": \"Bone-and-wood. He carried bone-and-wood, my own one did. Let me see your face properly, child. Lirien's breath —\", \"choices\": [{\"label\": \"...\", \"next\": \"eyes\"}]}, \"eyes\": {\"speaker\": \"Old Wyrdkin Grandmother\", \"text\": \"You have her eyes.\", \"sets\": \"met_grandmother\"}}}"

