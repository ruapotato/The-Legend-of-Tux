[node name="Npc1_Trader_Pem" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.661, 0)
npc_name = "Trader Pem"
body_color = Color(0.78, 0.62, 0.4, 1)
hat_color = Color(0.95, 0.85, 0.55, 1)
idle_hint = "[E] Speak to Pem"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Trader Pem\", \"text\": \"Sacks just came in from the dock-wagons. I'd weigh 'em\\nbut the miller's gone and forgotten, and I'm no miller.\", \"choices\": [{\"label\": \"Will they spoil?\", \"next\": \"spoil\"}, {\"label\": \"What's in them?\", \"next\": \"what\"}, {\"label\": \"Walk well.\"}]}, \"spoil\": {\"speaker\": \"Trader Pem\", \"text\": \"Grain keeps. People forget faster than grain spoils,\\nwhich is most of my problem.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"what\": {\"speaker\": \"Trader Pem\", \"text\": \"Mostly barley. Some oats. One sack is suspiciously\\nlight — I think a child opened it and never said.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 1.449, -1)
message = "Sacks of grain, not opened.\n\nThe miller meant to weigh them last week."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 0.597, -1)
message = "Eight sacks against the wall. Dust on the topmost.\nThe barn-cat sleeps on the lightest one."

