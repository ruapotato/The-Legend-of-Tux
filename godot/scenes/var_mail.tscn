[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 0, 2.5)
message = "THE POSTMARK\n\nFour pigeon-cotes line the back wall, each named for a village. Letters arrive. Letters depart. The pigeons know their own road.\n\nThe Postmaster keeps the ledger. The Postmaster always has work."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0, -1.5)
message = "COTE: HEARTHOLD\n\nA grey pigeon nestles inside, eyes half-closed. Letters here run east to the village of bakers and Source-priests. Most weeks she carries one or two."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0, 1.5)
message = "COTE: BROOKHOLD\n\nA brown pigeon coos softly. The farmstead's letters tend to be longer than the others — there is more to say when there are fields to keep account of."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, 1, 0, 1, 0, -1, 0, 6.12323e-17, 2.5, 0, -1.5)
message = "COTE: OLD HOLD\n\nThis cote is empty. The pigeon used to be silver-grey. The Postmaster keeps the cote ready anyway. 'In case someone writes,' he says."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, 1, 0, 1, 0, -1, 0, 6.12323e-17, 2.5, 0, 1.5)
message = "COTE: LIRIEN'S CHAMBER\n\nThe pigeon here is paler than the others, almost white. She comes and goes at her own hours. The Postmaster has never had to feed her. He doesn't ask why."

[node name="Npc5_Postmaster_Olbrin" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 0, 0.5)
npc_name = "Postmaster Olbrin"
body_color = Color(0.55, 0.5, 0.45, 1)
hat_color = Color(0.4, 0.55, 0.42, 1)
idle_hint = "[E] Speak with the postmaster"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Postmaster Olbrin\", \"text\": \"*he looks up from a tray of small folded letters. The pigeons murmur behind him.*\\n\\nWalker — letter? News? Or just the smell of the cotes?\\n\\nWe send to all four. Hearthold, Brookhold, the Old Hold, Lirien's Chamber. The pigeons find their roads.\", \"choices\": [{\"label\": \"Have you any work for a walker?\", \"next\": \"work\"}, {\"label\": \"Tell me about the Old Hold cote.\", \"next\": \"old\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"work\": {\"speaker\": \"Postmaster Olbrin\", \"text\": \"I do, as it happens. If you walk past one of the four villages, ask if there's a letter waiting to come back to me. Bring it. The pigeons fly the other way; you can fly the way the pigeons don't.\\n\\nI'll pay in pebbles. Or news. Or both.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"old\": {\"speaker\": \"Postmaster Olbrin\", \"text\": \"*his voice softens.*\\n\\nThe last keeper of the Old Hold wrote regularly. Then she didn't. Then she didn't again. I keep the cote ready. The pigeon will come back if there's a letter for her.\\n\\nSometimes a thing is only a kindness if you do it after it stops mattering.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Postmaster Olbrin\", \"text\": \"Walk well. Bring me a letter when you next pass a village.\"}}}"

