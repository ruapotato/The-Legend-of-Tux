[node name="Npc1_Sky_Scribe_Vell" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.079, 0)
npc_name = "Sky-Scribe Vell"
body_color = Color(0.55, 0.62, 0.78, 1)
hat_color = Color(0.35, 0.42, 0.62, 1)
idle_hint = "[E] Speak to Sky-Scribe Vell"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Sky-Scribe Vell\", \"text\": \"I file the sky. Charts on the left; tablets on the\\nright. The middle drawer is the one that does not\\nmove.\", \"choices\": [{\"label\": \"The one that does not move?\", \"next\": \"fixed\"}, {\"label\": \"The seven that walk slow?\", \"next\": \"seven\"}, {\"label\": \"Walk well.\"}]}, \"fixed\": {\"speaker\": \"Sky-Scribe Vell\", \"text\": \"Every chart has one. The pivot of the great wheel.\\nSailors call it North; Lirien calls it the Stayer.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"seven\": {\"speaker\": \"Sky-Scribe Vell\", \"text\": \"Seven slow walkers cross the sky over a year. The\\ntablets record where they pause. Lirien predicts the\\nnext pause; she is usually right.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 1.039, -1)
message = "Star-charts.\n\nThe seven that walk slow. The one that does not move."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 0.078, -1)
message = "Sky-tablets stacked by season. Each is a thin slate\netched with sigil-points and faint compass lines."

