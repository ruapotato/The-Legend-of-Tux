[node name="Npc61_Swap_keeper" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, -4)
npc_name = "Swap-keeper"
body_color = Color(0.3, 0.35, 0.45, 1)
hat_color = Color(0.5, 0.5, 0.6, 1)
idle_hint = "[E] Speak with the swap-keeper"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Swap-keeper\", \"text\": \"*he is sorting damp pages into shelves and back out of them*\\n\\nPages go in. Pages go out. I do not read them. That is the agreement. If I read them, I would slow.\", \"choices\": [{\"label\": \"Who decides which goes where?\", \"next\": \"who\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"who\": {\"speaker\": \"Swap-keeper\", \"text\": \"The pressure does. When the air is full, the older pages descend. When the air thins, they rise. I am only the keeper of the descent.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Swap-keeper\", \"text\": \"*he resumes sorting*\"}}}"

