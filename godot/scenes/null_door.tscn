[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0, -2.5)
message = "The Null Door stands closed.\n\nYour eyes find nothing past it. The breath of Lirien stops a few paces from the threshold and resumes a few paces past it on this side. There is no past it on its side."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -2.5, 0, -1)
message = "WARNING\n\nDo not approach within three paces of the door.\nThe rule is older than the warden.\nThe rule is older than the warning."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 2.5, 0, -1)
message = "Carved into the stone frame:\n\n\"DO NOT KNOCK.\nNO ONE WILL ANSWER\nIN A WAY YOU CAN HEAR.\""

[node name="Chest3" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0, 3)
contents_scene = ExtResource("glim_mirror_pickup")
open_message = "The Glim Mirror. Lirien's true silver, beaten thin and blessed cool. It will catch what Init throws — and throw it back."
requires_flag = "censor_defeated"

[node name="Npc4_Watcher_Velm" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 3.5, 0, 0)
npc_name = "Watcher Velm"
body_color = Color(0.45, 0.45, 0.5, 1)
hat_color = Color(0.2, 0.2, 0.25, 1)
idle_hint = "[E] Speak with Velm"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Watcher Velm\", \"text\": \"*Velm does not turn from the door.* Three paces back, traveller. The door is not for knocking. It is for listening.\", \"choices\": [{\"label\": \"Teach me how to listen.\", \"next\": \"teach\", \"requires_not\": \"moon_chord_learned\"}, {\"label\": \"(Hum the Moon Chord.)\", \"next\": \"remembered\", \"requires_song\": \"moon_chord\"}, {\"label\": \"Have others come?\", \"next\": \"others\"}, {\"label\": \"I'll keep my distance.\", \"next\": \"bye\"}]}, \"others\": {\"speaker\": \"Watcher Velm\", \"text\": \"A small grey-cloaked figure, recent. Did not knock. Stayed three paces back. Listened. Walked back the way they came. *Velm seems to approve.*\", \"next\": \"root\"}, \"teach\": {\"speaker\": \"Watcher Velm\", \"text\": \"Then listen now. *Velm hums, low and slow.* Left... down... left... down... right. The moon-marked gates open to it. So do certain other things. Be careful which.\", \"learns_song\": \"moon_chord\", \"next\": \"bye\"}, \"remembered\": {\"speaker\": \"Watcher Velm\", \"text\": \"*Velm nods once and resumes their watch.*\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Watcher Velm\", \"text\": \"*Velm watches the door.*\"}}}"

