[node name="Npc14_Trapped_Wisp" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, -0.932039, 0, 1, 0, 0.932039, 0, 0.362358, -3, 0, -7)
npc_name = "Trapped Wisp"
body_color = Color(0.95, 0.95, 0.55, 1)
hat_color = Color(0.95, 0.85, 0.4, 1)
idle_hint = "[E] Listen to the wisp"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Trapped Wisp\", \"text\": \"*a tiny voice, faint as a candle*\\nOh — traveler! You see me? You hear me? I — I am one of the small ones. They have my sister, deep below. In the boss-room. Please — please free her.\", \"choices\": [{\"label\": \"Tell me what happened.\", \"next\": \"what\"}, {\"label\": \"I will free her.\", \"next\": \"vow\", \"requires_not\": \"free_the_wisp\"}, {\"label\": \"I am already on the way.\", \"next\": \"ongoing\", \"requires\": \"free_the_wisp\"}, {\"label\": \"I cannot promise that.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"Trapped Wisp\", \"text\": \"We chose Tux-kin to carry our light, but the Hoarder's seed-things took her in the dark. They cage what they cannot understand. She glows still — I feel her. Find her. Free her.\", \"choices\": [{\"label\": \"I will free her.\", \"next\": \"vow\", \"requires_not\": \"free_the_wisp\"}, {\"label\": \"I am already on the way.\", \"next\": \"ongoing\", \"requires\": \"free_the_wisp\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"vow\": {\"speaker\": \"Trapped Wisp\", \"text\": \"Truly? Then carry this charge — find her, beyond the locked door, in the chamber where the Wyrd-keeper waits. I will burn brighter for the hoping.\", \"next\": \"vow_post\"}, \"vow_post\": {\"speaker\": \"Trapped Wisp\", \"text\": \"Go bright, little Tux. Go bright.\", \"choices\": [{\"label\": \"I will.\", \"next\": \"bye\", \"sets\": \"free_the_wisp\"}]}, \"ongoing\": {\"speaker\": \"Trapped Wisp\", \"text\": \"Bless you, bless you. She is below still. I feel her dim. Hurry.\"}, \"bye\": {\"speaker\": \"Trapped Wisp\", \"text\": \"*flickers*\\nGo gently, traveler.\"}}}"

