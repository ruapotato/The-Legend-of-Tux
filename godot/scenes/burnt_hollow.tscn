[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, 93, 0, 49)
message = "BURNT HOLLOW.\n\nThe wood that grew here was old when the Source first sang. Khorgaul the Hoarder burned it to its roots and locked the ash in glass. Walk softly. The ground remembers."

[node name="OwlStatue_owl_burnt_hollow" parent="." instance=ExtResource("owl_statue")]
