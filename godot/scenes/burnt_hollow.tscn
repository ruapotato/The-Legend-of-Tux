[node name="Npc47_Soot_Helka" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 88, 0, 70)
npc_name = "Soot Helka"
body_color = Color(0.45, 0.42, 0.4, 1)
hat_color = Color(0.3, 0.28, 0.28, 1)
idle_hint = "[E] Approach the survivor"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Soot Helka\", \"text\": \"*coughs ash*\\nYou — you came in. Most don't, anymore. I can't go back. The fire ate the ridge behind me. Look — look how the Hollow weeps ash.\", \"choices\": [{\"label\": \"What happened here?\", \"next\": \"what\"}, {\"label\": \"Tell me of the Hoarder.\", \"next\": \"khor\"}, {\"label\": \"What lies deeper in?\", \"next\": \"deep\"}, {\"label\": \"Stay strong. Farewell.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"Soot Helka\", \"text\": \"The wood was old when the Source was young. Then Khorgaul gathered the green out of it — not at once, no, that would be merciful — gathered it slow, gathered it patient, gathered it gone. The Source bleeds. You can taste it on the air.\", \"choices\": [{\"label\": \"Tell me of the Hoarder.\", \"next\": \"khor\"}, {\"label\": \"What lies deeper in?\", \"next\": \"deep\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"khor\": {\"speaker\": \"Soot Helka\", \"text\": \"He does not show himself. He sends bone-things and ash-things and the cold beneath. But this — *gestures at the burnt land* — this is his hand. As clear as a print in clay.\", \"choices\": [{\"label\": \"What lies deeper in?\", \"next\": \"deep\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"deep\": {\"speaker\": \"Soot Helka\", \"text\": \"His reliquary. Where he hoards what he has gathered. The bone-knights guard it; the bats keep its sky. Go in only if you can come out. Few can. None alone, I think.\", \"choices\": [{\"label\": \"Stay strong. Farewell.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Soot Helka\", \"text\": \"Go bright. Go careful. Go and come back.\"}}}"

