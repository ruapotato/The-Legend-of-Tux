[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, 71, -1.76, 31)
message = "Where the ridge narrows: keep your blade drawn. The bone-walkers know every crack of this stone."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 41, 0.879, 57)
message = "A Source-shrine, half-melted into glass slag.\n\nHere Lirien wept, and her tears boiled. The hoarder bled the Source dry into this hollow. Embers still bank in the cracks."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, 23, -0.755, 49)
message = "Beyond: the dead-end shelf. The Hoarder's reliquary lies on the far stone — but the path narrows to a bone's-width."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 57, 2.246, 61)
message = "Knights of bone do not forget where their hoard lies. Take only what you can carry. Leave the rest to ash."

