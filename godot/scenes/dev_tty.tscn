body_color = Color(0.7, 0.65, 0.6, 1)
hat_color = Color(0.6, 0.55, 0.5, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"A Walker\", \"text\": \"*she steps to the podium. The room goes very still.*\\n\\n'I am all right. The road has been long, but I am all right. Walk well, all of you.'\\n\\n*she steps back. She does not look at you on the way out.*\"}}}"

