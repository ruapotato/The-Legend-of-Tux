transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0.869, 2.5)
message = "THE SPEAKER'S ROOM\n\nA small round room with a stone podium. Anyone who speaks here is heard everywhere in the realm.\n\nWalkers come, speak one line, and leave. The room remembers what was said. The realm remembers what mattered."

[node name="Sign1" parent="." instance=ExtResource("sign")]
