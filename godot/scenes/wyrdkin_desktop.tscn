[node name="Npc1_Grandmother_s_Ghost" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.808, 0)
npc_name = "Grandmother's Ghost"
body_color = Color(0.78, 0.72, 0.85, 1)
hat_color = Color(0.55, 0.45, 0.62, 1)
idle_hint = "[E] Speak to Grandmother"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Grandmother's Ghost\", \"text\": \"Oh — it's you. Come here, child. The pen is where I\\nset it down. I meant to come back to it.\", \"choices\": [{\"label\": \"What were you writing?\", \"next\": \"writing\"}, {\"label\": \"Are you alright?\", \"next\": \"alright\"}, {\"label\": \"Walk well.\"}]}, \"writing\": {\"speaker\": \"Grandmother's Ghost\", \"text\": \"A letter. To you, perhaps. To someone I would not see\\nagain. The words ran out before the meaning did.\", \"choices\": [{\"label\": \"I'll read it.\", \"next\": \"read\"}, {\"label\": \"Some other time.\"}]}, \"read\": {\"speaker\": \"Grandmother's Ghost\", \"text\": \"It is folded in the next room. Read it when you are\\nold enough — though I suspect you already are.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"alright\": {\"speaker\": \"Grandmother's Ghost\", \"text\": \"I am as I am. The kin remember; that is enough work\\nfor the realm. Don't sit too long here, child. The\\nlight is going.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 0.164, -1)
message = "Grandmother's desk.\n\nThe pen is where she set it down."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 2.02, -1)
message = "Untouched. The kin do not move anything in this room."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.819, 4)
message = "A wooden desk under a small window. A pen, an inkwell,\na stack of paper. The chair is pushed back as if she\nhad only just stood."

