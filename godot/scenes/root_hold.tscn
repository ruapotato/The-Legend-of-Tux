[node name="from_crown" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 0.89, -1.5)

[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 0, -1.5)
message = "ROOT'S HOLD\n\nA small cottage at the highest spur. Plain rugs. A simple desk. A kettle that has been on a low boil since the realm was started.\n\nThe door is closed until the chord is assembled."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -1.5, 0, 3.5)
message = "Tacked to the inside of the door:\n\n'If a walker reaches this room, the realm needs them more than it knows. Make tea. Speak true. Send them well.'\n\n— in a hand older than most stones."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0, 2.5)
message = "On the desk: a small ledger left open.\n\n'The Wyrdmark is in good hands today. The Wyrdmark was in good hands yesterday. The Wyrdmark will be in good hands tomorrow if the hands keep at it.'\n\nNo signature."

[node name="Npc3_The_Sysadmin" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0, 0.5)
npc_name = "The Sysadmin"
body_color = Color(0.55, 0.5, 0.45, 1)
hat_color = Color(0.4, 0.38, 0.32, 1)
idle_hint = "[E] Speak with the elder"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"The Sysadmin\", \"text\": \"*an older Wyrdkin pours tea without asking. The cup is the right temperature when it reaches your hand.*\\n\\nSit, walker. You came up the long way. Most do.\\n\\nWhat's still in front of you?\", \"choices\": [{\"label\": \"I don't know yet.\", \"next\": \"advice\"}, {\"label\": \"A locked dungeon.\", \"next\": \"advice\"}, {\"label\": \"A boss I can't beat.\", \"next\": \"advice\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"advice\": {\"speaker\": \"The Sysadmin\", \"text\": \"Then I will tell you the one thing I tell every walker who finds this room.\\n\\nThe realm runs because somebody, somewhere, kept showing up. Not because anyone was strong. Because they kept showing up.\\n\\nGo on. Show up.\\n\\n*the kettle starts to sing.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"The Sysadmin\", \"text\": \"Walk well, walker. The kettle will be on when you come back.\"}}}"

[node name="LoadZone0" type="Area3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.433847, 1.79, -3.49854)
collision_layer = 64
