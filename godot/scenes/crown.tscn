hat_color = Color(0.35, 0.3, 0.25, 1)
idle_hint = "[E] Speak with Hesp"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Pilgrim Hesp\", \"text\": \"Look at you, little climber. The wind up here is thin and old. I come once a year. I have come for forty years. What would you ask of an old man with cold knees?\", \"choices\": [{\"label\": \"Why do you come?\", \"next\": \"why\"}, {\"label\": \"What do you hope to see?\", \"next\": \"hope\"}, {\"label\": \"What is the Throne?\", \"next\": \"throne\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"why\": {\"speaker\": \"Pilgrim Hesp\", \"text\": \"Because the climb is the answer. Because if I stop climbing I will not start again. Because the wind here is the breath of Lirien with no leaves between us.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"hope\": {\"speaker\": \"Pilgrim Hesp\", \"text\": \"Some climbers say they have seen her. Lirien, I mean. A figure beside the Throne, or a wind that turns. I have seen nothing in forty climbs. I keep climbing.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"throne\": {\"speaker\": \"Pilgrim Hesp\", \"text\": \"The Throne is older than the asking. There is no record of who carved it. Nobody alive remembers what it was for. That doesn't seem to bother the Throne.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Pilgrim Hesp\", \"text\": \"Walk well, climber. Breathe what you can.\"}}}"

[node name="Npc9_Reader_on_pilgrimage" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -6, 0, 0)
npc_name = "Reader-on-pilgrimage"
body_color = Color(0.5, 0.45, 0.55, 1)
hat_color = Color(0.65, 0.55, 0.4, 1)
idle_hint = "[E] Speak with the Reader"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Reader-on-pilgrimage\", \"text\": \"Pardon — I'm taking notes. You arrived. I had written that you would. The page is glad to be right.\", \"choices\": [{\"label\": \"Where are you from?\", \"next\": \"from\"}, {\"label\": \"What are you writing?\", \"next\": \"writing\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"from\": {\"speaker\": \"Reader-on-pilgrimage\", \"text\": \"The Library. Not Sigilkeep's — the other one. We had a spring of new arrivals; the Throne has been generous this year, before the climb begins.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"writing\": {\"speaker\": \"Reader-on-pilgrimage\", \"text\": \"What was carved here, who carved it, who came after. I always wrote what came after first; the order is wrong but the page does not mind.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Reader-on-pilgrimage\", \"text\": \"Walk well. You did walk well.\"}}}"

[node name="Npc10__" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 1.5, 0, -2)
npc_name = "?"
body_color = Color(0.78, 0.85, 0.95, 1)
hat_color = Color(0.78, 0.85, 0.95, 1)
idle_hint = "[E] ..."
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"?\", \"text\": \"*Their voice does not reach you.*\"}}}"

