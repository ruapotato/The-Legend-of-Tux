[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0, -3)
message = "The Old Throne.\n\nCarved before any record. Nobody alive remembers its purpose. It is empty.\n\nThe wind around it does not touch you. The seat has dust as old as the wind."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 2, 0, -2.5)
message = "Someone is standing here.\n\nYou can't quite see them. They turn at the sound of your steps and then they are gone."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -10, 0, 10)
message = "ALTITUDE MARKER\n\nYou are at the highest point in the Wyrdmark. The wind is the same wind you breathed at sea-level, only thinner, and older for the climb."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 10, 0, 10)
message = "Carved deep into the rim:\n\n\"THE CROWN IS COLD AND THE BREATH IS THIN. BREATHE WHAT YOU CAN.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -10, 0, -10)
message = "Memorial slab.\n\nFor those who climbed and did not return. The list is long; the names are old. We do not read them aloud, because the wind is enough."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 10, 0, -10)
message = "Posted by an old hand:\n\n\"If you see something beside the Throne, do not chase it. It is being kind by leaving.\""

[node name="Chest6" parent="." instance=ExtResource("chest")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3, 0, 3)
contents_scene = ExtResource("pebble_pickup")
open_message = "A pouch of summit pebbles, smoothed by wind."
contents_amount = 15

[node name="Chest7" parent="." instance=ExtResource("chest")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3, 0, 3)
contents_scene = ExtResource("heart_pickup")
open_message = "A Heart Container — the climb was long, but you arrived. The Crown has a quiet way of being generous."

