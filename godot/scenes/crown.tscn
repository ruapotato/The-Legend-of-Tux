[node name="Npc20_Lirien" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.79, -8)
npc_name = "Lirien"
body_color = Color(0.85, 0.88, 0.95, 1)
hat_color = Color(0.6, 0.7, 0.85, 1)
idle_hint = "[E] Approach Lirien"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Lirien\", \"text\": \"*Lirien stands beside the Old Throne. Tall, hooded, looking past you to the cold horizon.* You climbed. Few do.\", \"choices\": [{\"label\": \"I came to ask about the Door.\", \"next\": \"door\"}, {\"label\": \"(Hum the songs you have learned.)\", \"next\": \"weave\", \"requires_song\": \"glim_theme\", \"requires_flag\": \"sun_chord_learned\"}, {\"label\": \"(Hum the Triglyph Chord.)\", \"next\": \"remembered\", \"requires_song\": \"triglyph_chord\"}, {\"label\": \"I'll go.\", \"next\": \"bye\"}]}, \"door\": {\"speaker\": \"Lirien\", \"text\": \"The Door at the end of the Forge. It is held by an older watch than any kingdom. To open it you need a chord no one alive can hum alone. *Lirien glances at you.* Bring me what you have learned, and I will teach you the rest.\", \"next\": \"root\"}, \"weave\": {\"speaker\": \"Lirien\", \"text\": \"*Lirien listens. Closes her eyes.* You have Glim's Theme. You have the Sun. You have the Moon. *She nods.* Then I will give you the chord that ties them.\", \"next\": \"weave_check\"}, \"weave_check\": {\"speaker\": \"Lirien\", \"text\": \"*She hums it once, slowly. Up... down... up... left... right. The wind carries it.* Now hum it back. The Door will hear.\", \"learns_song\": \"triglyph_chord\", \"sets_flag\": \"lirien_blessing\", \"next\": \"bye\"}, \"remembered\": {\"speaker\": \"Lirien\", \"text\": \"*Lirien tilts her head a fraction.* The Triglyph holds. The Door is yours to wake.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Lirien\", \"text\": \"*The wind on the summit does not stop for anyone.*\"}}}"

