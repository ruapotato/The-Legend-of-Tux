[node name="Npc0_Crier_of_the_Day" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.698, 0)
npc_name = "Crier of the Day"
body_color = Color(0.92, 0.85, 0.62, 1)
hat_color = Color(0.78, 0.55, 0.32, 1)
idle_hint = "[E] Hear the day's notice"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Crier of the Day\", \"text\": \"Today's notice. Hear ye:\\n\\n\\\"Welcome to the Wyrdmark. Watch your step.\\\"\", \"choices\": [{\"label\": \"Read me another one.\", \"next\": \"two\"}, {\"label\": \"Walk well.\"}]}, \"two\": {\"speaker\": \"Crier of the Day\", \"text\": \"\\\"Maintenance window: never. The realm has been up since\\nanyone can remember and will be up tomorrow.\\\"\", \"choices\": [{\"label\": \"And another?\", \"next\": \"three\"}, {\"label\": \"Walk well.\"}]}, \"three\": {\"speaker\": \"Crier of the Day\", \"text\": \"\\\"Today is a good day to whistle.\\\"\", \"choices\": [{\"label\": \"One more?\", \"next\": \"four\"}, {\"label\": \"Walk well.\"}]}, \"four\": {\"speaker\": \"Crier of the Day\", \"text\": \"\\\"The realm thanks you for your trust.\\\"\\n\\nThat's all I have today. The board only takes four.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.199, -3)
message = "A banner stretches overhead, freshly painted:\n\n\"Welcome to the Wyrdmark. Watch your step.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, -1.09, 2)
message = "Message of the Day —\n\nRead once on entry. Replaced at dawn. The day's word, no more."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 0.119, 2)
message = "A small ledger of past banners hangs by the door.\n\nYesterday: \"Mind the kettle.\"\nThe day before: \"It is raining somewhere. Take a kindness.\""

