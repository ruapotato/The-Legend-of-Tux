[node name="Npc49_Fisher_Aelis" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.801144, 0, -0.598472, 0, 1, 0, 0.598472, 0, -0.801144, -2, 0, -36)
npc_name = "Fisher Aelis"
body_color = Color(0.45, 0.55, 0.55, 1)
hat_color = Color(0.4, 0.4, 0.55, 1)
idle_hint = "[E] Talk to the fisher"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Fisher Aelis\", \"text\": \"Quiet, quiet — the mire-fish bite shy in the bright hour. You from the plain? You here for the shrine?\", \"choices\": [{\"label\": \"What shrine?\", \"next\": \"shrine\"}, {\"label\": \"Tell me of the lake.\", \"next\": \"lake\"}, {\"label\": \"Just passing.\", \"next\": \"bye\"}]}, \"shrine\": {\"speaker\": \"Fisher Aelis\", \"text\": \"South of here, beneath the water. A sunken sigil-shrine. The keepers warded a thing inside; the lake has been finishing the job for a hundred summers. Bring a bright heart and a held breath.\", \"choices\": [{\"label\": \"Tell me of the lake.\", \"next\": \"lake\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"lake\": {\"speaker\": \"Fisher Aelis\", \"text\": \"The Source slows here. What flows fast in the brook turns thick in the mire. It's why the wards held so long; it's why the things below are waking so slow. Slow waking is still waking.\", \"choices\": [{\"label\": \"What shrine?\", \"next\": \"shrine\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Fisher Aelis\", \"text\": \"Tread the boards, not the peat. The peat takes.\"}}}"

[node name="Npc50_Reedweaver_Pell" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, 0.932039, 0, 1, 0, -0.932039, 0, 0.362358, 28, 0, 4)
npc_name = "Reedweaver Pell"
body_color = Color(0.55, 0.65, 0.4, 1)
hat_color = Color(0.4, 0.5, 0.3, 1)
idle_hint = "[E] Talk to Pell"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Reedweaver Pell\", \"text\": \"*braids a long reed without looking up*\\nOh — visitor. Forgive me, the weave needs a steady hand. What brings you out to my island?\", \"choices\": [{\"label\": \"What are you weaving?\", \"next\": \"weave\"}, {\"label\": \"What lives in the mire?\", \"next\": \"mire\"}, {\"label\": \"Just passing through.\", \"next\": \"bye\"}]}, \"weave\": {\"speaker\": \"Reedweaver Pell\", \"text\": \"A wardmat. The reeds remember the old patterns when you set them right. Lay one in your doorway and the dim things turn aside. Of course, I have not had a customer in two seasons. *smiles*\", \"choices\": [{\"label\": \"What lives in the mire?\", \"next\": \"mire\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"mire\": {\"speaker\": \"Reedweaver Pell\", \"text\": \"Spores, mostly. Things that bloom and burst. And the great quiet beneath the water — but we don't speak of that one, not on a still day.\", \"choices\": [{\"label\": \"What are you weaving?\", \"next\": \"weave\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Reedweaver Pell\", \"text\": \"Tread softly off my island, traveler. The reeds remember footfalls.\"}}}"

