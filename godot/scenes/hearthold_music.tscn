[node name="Npc1_Lutenist_Cael" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.415, 0)
npc_name = "Lutenist Cael"
body_color = Color(0.62, 0.45, 0.78, 1)
hat_color = Color(0.95, 0.78, 0.45, 1)
idle_hint = "[E] Ask Cael to play"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Lutenist Cael\", \"text\": \"Oh, hello! Want to hear one? It's a short one. The kin\\nsing it while the bread rises.\", \"choices\": [{\"label\": \"Please play.\", \"next\": \"play\"}, {\"label\": \"What's it called?\", \"next\": \"name\"}, {\"label\": \"Some other time.\"}]}, \"play\": {\"speaker\": \"Lutenist Cael\", \"text\": \"*Cael plucks three notes, then a fourth that hangs in the\\nair a beat longer than the others. The room feels warmer.*\", \"choices\": [{\"label\": \"Beautiful.\"}]}, \"name\": {\"speaker\": \"Lutenist Cael\", \"text\": \"'The Long Loaf.' My grandmother taught it to me. Hers\\ntaught her. Probably nobody wrote it down — that would\\nbe how you'd lose it.\", \"choices\": [{\"label\": \"Please play.\", \"next\": \"play\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 0.849, -1)
message = "Songs the kin sing while the bread rises."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 0.08, -1)
message = "A lute on a wooden stand. Strings dark with use, smooth\nwhere fingers find them."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -1.766, 4)
message = "A small concert hall — three rows of benches, hand-carved.\nThe acoustics are warmer than the size suggests."

