[node name="from_forge" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, -2.14, -1.5)

[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, -2.399, 2.5)
message = "THE WILD HUM\n\nA chaotic room. The floor pattern is different every visit. Wind from indeterminate directions.\n\nLirien's breath, the realm has rooms that just are like this. The Wyrdkin shrug and bring an extra cloak."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, -2.085, -1.5)
message = "Carved into a stone you swear was somewhere else last time:\n\n'The hum is the realm not knowing what it wants to be just now. Wait a breath. The hum will decide. By the Source, it always does.'"

[node name="Chest2" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, -2.801, -0.5)
contents_scene = ExtResource("heart_piece")
open_message = "A piece of heart, half-buried in the shifting floor. The realm hummed it into being while you were looking the other way."

[node name="Npc3_Urandom" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 2.5, -2.553, -0.5)
npc_name = "Urandom"
body_color = Color(0.55, 0.35, 0.65, 1)
hat_color = Color(0.95, 0.55, 0.85, 1)
idle_hint = "[E] Ask Urandom for a hint"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Urandom\", \"text\": \"*she rummages in a bag of bone-dice and pulls one out at random*\\n\\nA hint for you. From the well of unpredictable things. It is good enough for almost any use.\", \"choices\": [{\"label\": \"Roll once.\", \"next\": \"h1\"}, {\"label\": \"Roll again.\", \"next\": \"h2\"}, {\"label\": \"And again.\", \"next\": \"h3\"}, {\"label\": \"Once more.\", \"next\": \"h4\"}, {\"label\": \"Last time.\", \"next\": \"h5\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"h1\": {\"speaker\": \"Urandom\", \"text\": \"\\\"The thing you cannot reach is two paces lower than you think.\\\"\", \"next\": \"root\"}, \"h2\": {\"speaker\": \"Urandom\", \"text\": \"\\\"Hammers open doors that are not doors.\\\"\", \"next\": \"root\"}, \"h3\": {\"speaker\": \"Urandom\", \"text\": \"\\\"There is a chest behind something you walked past today.\\\"\", \"next\": \"root\"}, \"h4\": {\"speaker\": \"Urandom\", \"text\": \"\\\"Glim sees more in the dark. You should let him try.\\\"\", \"next\": \"root\"}, \"h5\": {\"speaker\": \"Urandom\", \"text\": \"\\\"When in doubt, hum the chord you know best.\\\"\", \"next\": \"root\"}, \"bye\": {\"speaker\": \"Urandom\", \"text\": \"*she pockets the dice*\"}}}"

