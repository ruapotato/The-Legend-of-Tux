[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0.546, 2.5)
message = "THE INITIATES\n\nA candle-lit row of novices. Each is responsible for waking one of the realm's morning ceremonies. Twelve in all — five here today, the others at their posts."

[node name="Npc1_Initiate_Olm" parent="." instance=ExtResource("npc")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0.181, -0.5)
npc_name = "Initiate Olm"
body_color = Color(0.95, 0.92, 0.88, 1)
hat_color = Color(0.85, 0.78, 0.6, 1)
idle_hint = "[E] Listen to the initiate"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Initiate Olm\", \"text\": \"*kneeling, eyes closed*\\n\\n'By the breath of the Maker, the morning is opened. By the Source, the dawn-shrine wakes. Walk the realm, walk it well...'\\n\\n*she does not pause for you.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Initiate Olm\", \"text\": \"*she does not stop reciting.*\"}}}"

[node name="Npc2_Initiate_Belth" parent="." instance=ExtResource("npc")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -1.5, 0.193, -0.5)
npc_name = "Initiate Belth"
body_color = Color(0.92, 0.9, 0.85, 1)
hat_color = Color(0.8, 0.7, 0.55, 1)
idle_hint = "[E] Listen to the initiate"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Initiate Belth\", \"text\": \"*low, steady*\\n\\n'The wells are blessed at first light. The kettles are blessed at second. The ovens at third. The hearth at fourth, and so on, to the twelfth, which is the last...'\\n\\n*his voice is calm enough to fall asleep to.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Initiate Belth\", \"text\": \"*he does not pause.*\"}}}"

[node name="Npc3_Initiate_Ress" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 0.196, -0.5)
npc_name = "Initiate Ress"
body_color = Color(0.95, 0.95, 0.92, 1)
hat_color = Color(0.7, 0.6, 0.45, 1)
idle_hint = "[E] Speak with the initiate"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Initiate Ress\", \"text\": \"*opens his eyes wide*\\n\\nWalker — please. I've forgotten my recantation. The seventh line. It opens the kettle-shrine for the noon-cooks and I cannot remember it.\\n\\nIs it 'by the breath of the Maker' or 'by the breath of the Source'?\", \"choices\": [{\"label\": \"By the breath of the Maker.\", \"next\": \"right\"}, {\"label\": \"By the breath of the Source.\", \"next\": \"wrong\"}, {\"label\": \"I'm not sure.\", \"next\": \"patience\"}]}, \"right\": {\"speaker\": \"Initiate Ress\", \"text\": \"Yes! Yes — that's it. By the breath of the Maker the kettle-shrine wakes.\\n\\nLirien's breath, walker, you saved me a scolding. Walk well. Walk very well.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"wrong\": {\"speaker\": \"Initiate Ress\", \"text\": \"Hm. Maybe. I'll try it.\\n\\n*he doesn't look convinced.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"patience\": {\"speaker\": \"Initiate Ress\", \"text\": \"Fair. Fair. I'll keep at it.\\n\\nMaybe Belth will tell me. Belth never forgets a line.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Initiate Ress\", \"text\": \"Walk well, walker. By the breath of the Maker.\"}}}"

[node name="Npc4_Initiate_Maro" parent="." instance=ExtResource("npc")]
transform = Transform3D(6.12323e-17, 0, 1, 0, 1, 0, -1, 0, 6.12323e-17, 1.5, 0.244, -0.5)
npc_name = "Initiate Maro"
body_color = Color(0.9, 0.88, 0.85, 1)
hat_color = Color(0.78, 0.65, 0.5, 1)
idle_hint = "[E] Listen to the initiate"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Initiate Maro\", \"text\": \"*humming a long, low note. Her hands are folded. Her eyes are open and not looking at anything.*\\n\\n*the tone shifts up half a step. Then back down.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Initiate Maro\", \"text\": \"*the humming continues.*\"}}}"

[node name="Npc5_Initiate_Quenn" parent="." instance=ExtResource("npc")]
transform = Transform3D(6.12323e-17, 0, 1, 0, 1, 0, -1, 0, 6.12323e-17, 2.5, 0.364, -0.5)
npc_name = "Initiate Quenn"
body_color = Color(0.93, 0.9, 0.88, 1)
hat_color = Color(0.85, 0.7, 0.5, 1)
idle_hint = "[E] Listen to the initiate"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Initiate Quenn\", \"text\": \"*reciting fast, almost under his breath*\\n\\n'...and the gardens, and the orchards, and the brooks, and the wells, and the smaller wells, and the unspoken wells, and the smaller unspoken wells, and—'\\n\\n*he doesn't notice you.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Initiate Quenn\", \"text\": \"*he is already on the next line.*\"}}}"

