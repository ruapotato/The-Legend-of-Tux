[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0, -1.5)
message = "THE QUIETNESS\n\nA perfectly silent stone room. Even your footsteps don't echo. The Source, the realm thinks, runs through here in long unbroken lines.\n\nNothing here can be taken from anyone. The chest gives. The room gives. The walker gives back when they can."

