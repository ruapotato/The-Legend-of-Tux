[node name="Npc31_Hermit_Olber" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.764842, 0, -0.644218, 0, 1, 0, 0.644218, 0, 0.764842, -6, 0, -2)
npc_name = "Hermit Olber"
body_color = Color(0.45, 0.55, 0.45, 1)
hat_color = Color(0.35, 0.3, 0.25, 1)
idle_hint = "[E] Talk to the hermit"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Hermit Olber\", \"text\": \"Eh? Is it morning? Is it night? The wood does not say. I have walked in circles for — well. Some time. You look less lost than I am. Tell me, are you looking for the Hollow?\", \"choices\": [{\"label\": \"Where is the Hollow?\", \"next\": \"hollow\"}, {\"label\": \"How long have you wandered?\", \"next\": \"wander\"}, {\"label\": \"Stay safe, hermit.\", \"next\": \"bye\"}]}, \"hollow\": {\"speaker\": \"Hermit Olber\", \"text\": \"East. East, then south. There is a fallen elder-tree, its roots carved like a mouth. The mouth swallows the path. That is the entrance. I would go in, but the door has no handle, and I have no patience.\", \"choices\": [{\"label\": \"How long have you wandered?\", \"next\": \"wander\"}, {\"label\": \"Thank you. Farewell.\", \"next\": \"bye\"}]}, \"wander\": {\"speaker\": \"Hermit Olber\", \"text\": \"Long enough to forget my own name some mornings. The wood folds upon itself, you see. The ribbons others have tied — those are the only true compass.\", \"choices\": [{\"label\": \"Where is the Hollow?\", \"next\": \"hollow\"}, {\"label\": \"Farewell.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Hermit Olber\", \"text\": \"Mind the trees. They watch.\"}}}"

[node name="Npc32_Wenna_the_Wisp_tender" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.696707, 0, 0.717356, 0, 1, 0, -0.717356, 0, 0.696707, 5, 0, -16)
npc_name = "Wenna the Wisp-tender"
body_color = Color(0.6, 0.7, 0.85, 1)
hat_color = Color(0.45, 0.55, 0.75, 1)
idle_hint = "[E] Talk to Wenna"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"Hush — they are timid. *cups her hands gently*\\nGood. Good. I see your wisp at your shoulder, traveler. She is bright. She has chosen you.\", \"choices\": [{\"label\": \"What is Glim's role?\", \"next\": \"role\"}, {\"label\": \"Why do wisps choose?\", \"next\": \"choose\"}, {\"label\": \"Farewell.\", \"next\": \"bye\"}]}, \"role\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"A wisp is a fleck of the Source with a small, bright will. She lights what is dim. She remembers what you forget. She names what you cannot. Listen for her chime — it speaks where words will not.\", \"choices\": [{\"label\": \"Why do wisps choose?\", \"next\": \"choose\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"choose\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"Because the Source likes a true heart, and a true heart never knows itself. Glim sees in you what you cannot. Trust her sight more than your own, when the green grows thick.\", \"choices\": [{\"label\": \"What is Glim's role?\", \"next\": \"role\"}, {\"label\": \"Farewell.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"Walk lightly. The wisps sleep nearby.\"}}}"

[node name="Chest33" parent="." instance=ExtResource("chest")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -8, 0, 11)
contents_scene = ExtResource("heart_piece")
open_message = "Beneath the eldest pine — its roots had grown around a Source-pulse so old it had nearly forgotten itself. Press on."

[node name="Npc34_Whispering_Stone" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 1, 0, 8)
npc_name = "Whispering Stone"
body_color = Color(0.32, 0.28, 0.4, 1)
hat_color = Color(0.45, 0.5, 0.4, 1)
idle_hint = "[E] Touch the stone"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Whispering Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires\": \"wyrdking_defeated\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"wyrdking_defeated\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Whispering Stone\", \"text\": \"The cache holds a Wyrd-king's bones. It is not far through the woods.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Whispering Stone\", \"text\": \"The Hollow rests now. Its dust has settled.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Whispering Stone\", \"text\": \"*The hum fades.*\"}}}"

