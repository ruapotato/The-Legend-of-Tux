body_color = Color(0.6, 0.7, 0.85, 1)
hat_color = Color(0.45, 0.55, 0.75, 1)
idle_hint = "[E] Talk to Wenna"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"Hush — they are timid. *cups her hands gently*\\nGood. Good. I see your wisp at your shoulder, traveler. She is bright. She has chosen you.\", \"choices\": [{\"label\": \"What is Glim's role?\", \"next\": \"role\"}, {\"label\": \"Why do wisps choose?\", \"next\": \"choose\"}, {\"label\": \"Farewell.\", \"next\": \"bye\"}]}, \"role\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"A wisp is a fleck of the Source with a small, bright will. She lights what is dim. She remembers what you forget. She names what you cannot. Listen for her chime — it speaks where words will not.\", \"choices\": [{\"label\": \"Why do wisps choose?\", \"next\": \"choose\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"choose\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"Because the Source likes a true heart, and a true heart never knows itself. Glim sees in you what you cannot. Trust her sight more than your own, when the green grows thick.\", \"choices\": [{\"label\": \"What is Glim's role?\", \"next\": \"role\"}, {\"label\": \"Farewell.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Wenna the Wisp-tender\", \"text\": \"Walk lightly. The wisps sleep nearby.\"}}}"

