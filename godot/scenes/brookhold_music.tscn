[node name="Npc1_Fiddler_Marn" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -1.009, 0)
npc_name = "Fiddler Marn"
body_color = Color(0.85, 0.55, 0.32, 1)
hat_color = Color(0.62, 0.42, 0.22, 1)
idle_hint = "[E] Ask Marn to play"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Fiddler Marn\", \"text\": \"Eh! Come sit. You ever learn a tune you couldn't read?\\nBest way. Hands learn faster than eyes.\", \"choices\": [{\"label\": \"Who taught you?\", \"next\": \"uncle\"}, {\"label\": \"Play me one?\", \"next\": \"play\"}, {\"label\": \"Walk well.\"}]}, \"uncle\": {\"speaker\": \"Fiddler Marn\", \"text\": \"Uncles. Three of 'em. Couldn't read a word between 'em\\nbut they could pull a wedding out of a Tuesday.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"play\": {\"speaker\": \"Fiddler Marn\", \"text\": \"*Marn draws the bow. A short, bright tune that sounds\\nlike running water and stamping feet at once. Then a\\nlong note that fades just as you notice it's there.*\", \"choices\": [{\"label\": \"Thank you.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, -1.422, -1)
message = "Fiddle-on-the-fence —\n\ntaught by uncles who could not read."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, -1.064, -1)
message = "A fiddle leans against the fence-post, bow tucked under\nthe strings. Anyone who passes can pick it up. Most do."

