[node name="Npc0_The_Reader_of_Lines" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 3.494, 0)
npc_name = "The Reader of Lines"
body_color = Color(0.85, 0.85, 0.92, 1)
hat_color = Color(0.45, 0.42, 0.55, 1)
idle_hint = "[E] Listen to the Reader"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"The Reader of Lines\", \"text\": \"Everything you have spoken, written down. I read it\\nback when the hold is quiet.\", \"choices\": [{\"label\": \"Everything?\", \"next\": \"all\"}, {\"label\": \"Even the mistakes?\", \"next\": \"mistakes\"}, {\"label\": \"Walk well.\"}]}, \"all\": {\"speaker\": \"The Reader of Lines\", \"text\": \"Every command, in order. Some of these tablets are\\nolder than the kin who first carved them.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"mistakes\": {\"speaker\": \"The Reader of Lines\", \"text\": \"Especially the mistakes. The mistakes are how we know\\nwhat we meant.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -4, 3.16, -3)
message = "Tablet carved deep:\n\n`ls`"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -2, 3.689, -3)
message = "Tablet carved shallow:\n\n`cd ..`"

[node name="Sign3" parent="." instance=ExtResource("sign")]
