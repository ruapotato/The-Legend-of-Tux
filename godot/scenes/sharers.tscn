[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0, 12)
message = "The Sharers\n\n/usr/share"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, -0.707108, 0, 1, 0, 0.707108, 0, 0.707105, -2, 0, -2)
message = "PLINTH I\n\n\"The breath of Lirien moves\nthrough us all —\nthrough the merchant's tally,\nthrough the watchman's pace,\nthrough the long quiet\nof those who do not speak\nbut listen, and listen,\nand are made larger by listening.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, 2, 0, -2)
message = "PLINTH II\n\n\"What is given is not lost.\nWhat is hoarded thins\nin the hand that holds it.\""

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, -0.707103, 0, 1, 0, 0.707103, 0, -0.707111, -2, 0, 2)
message = "PLINTH III\n\n\"Three roads, one breath.\nThree peoples, one ground.\nOlder than the agreement,\nthe agreement.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, 0.707103, 0, 1, 0, -0.707103, 0, -0.707111, 2, 0, 2)
message = "PLINTH IV\n\n\"The bell does not ring the hour.\nShe reminds the hour to ring itself.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, -0.707108, 0, 1, 0, 0.707108, 0, 0.707105, -9, 0, -9)
message = "FRAGMENT (author lost)\n\n\"We were a people of the held breath.\nThen we learned to let it out.\nThe world did not end.\nIt became a song, briefly,\nand then a quieter thing,\nand then ours.\""

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, 9, 0, -9)
message = "FRAGMENT\n\n\"Of the three Sigils,\nthe kindest is Sharing —\nthough the kindness wears\nthe shape of work.\""

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, -0.707103, 0, 1, 0, 0.707103, 0, -0.707111, -9, 0, 9)
message = "POSTED\n\nThe bell rings on the hour, and one\nadditional time when nobody is watching.\nThis is tradition. Do not investigate."

[node name="Sign8" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, 0.707103, 0, 1, 0, -0.707103, 0, -0.707111, 9, 0, 9)
message = "INSCRIPTION\n\n\"The Maker walks the realm in many shapes.\nMost we will never recognise. Some\nwill leave the change of a coin\nand be gone before we count it.\""

[node name="Sign9" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -13, 0, 0)
message = "ATTRIBUTED TO TELVA\n\n\"I have not seen Lirien.\nI have stood in places\nwhere she had recently been,\nand the stones were warmer.\""

[node name="Sign10" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 13, 0, 0)
message = "FROM A LONGER PIECE\n\n\"The Sprawl is contested ground.\nContested ground is shared ground.\nSharing is what we do here, even\nwhen we forget we are doing it,\neven when we are arguing about it,\neven — most of all — then.\""

