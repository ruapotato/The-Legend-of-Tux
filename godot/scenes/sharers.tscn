[node name="Npc25_Poet_Telva" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.707105, 0, -0.707108, 0, 1, 0, 0.707108, 0, 0.707105, -3, 0, -5)
npc_name = "Poet Telva"
body_color = Color(0.55, 0.55, 0.7, 1)
hat_color = Color(0.85, 0.78, 0.5, 1)
idle_hint = "[E] Listen to Telva"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Poet Telva\", \"text\": \"Walker. The plinths are warm tonight. Would you hear a verse?\", \"choices\": [{\"label\": \"Please.\", \"next\": \"verse\"}, {\"label\": \"Another time.\", \"next\": \"bye\"}]}, \"verse\": {\"speaker\": \"Poet Telva\", \"text\": \"\\\"The hand that holds nothing\\nis the hand that is full of all things.\\nThe hand that grasps\\nis the hand that is empty\\nof the air it once cupped\\nwithout knowing it was holding it.\\\"\", \"choices\": [{\"label\": \"Beautiful.\", \"next\": \"thanks\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"thanks\": {\"speaker\": \"Poet Telva\", \"text\": \"Lirien's breath. You are kind. The plinth is kinder. Walk on, walker.\"}, \"bye\": {\"speaker\": \"Poet Telva\", \"text\": \"Walk well. The bell will ring soon.\"}}}"

[node name="Npc26_Historian_Pren" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, 3, 0, -5)
npc_name = "Historian Pren"
body_color = Color(0.5, 0.42, 0.5, 1)
hat_color = Color(0.4, 0.3, 0.35, 1)
idle_hint = "[E] Speak with Pren"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Historian Pren\", \"text\": \"A walker. Good. I have been talking to the plinths and they are not improving as listeners.\", \"choices\": [{\"label\": \"Tell me of the Sprawl.\", \"next\": \"sprawl\"}, {\"label\": \"Tell me of the Sharers.\", \"next\": \"sharers\"}, {\"label\": \"Tell me of the bell.\", \"next\": \"bell\"}, {\"label\": \"Why does any of this matter?\", \"next\": \"matter\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"sprawl\": {\"speaker\": \"Historian Pren\", \"text\": \"Built in the third long-quiet, after the second forgetting, before the third. Three clans came together not because they liked one another but because the wind here was kinder than where they came from.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"sharers\": {\"speaker\": \"Historian Pren\", \"text\": \"We are the cultural ward. We tend verse, plinth, bell. The Binds find us insufferable. We find ourselves slightly insufferable. The Locals do not find us at all.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bell\": {\"speaker\": \"Historian Pren\", \"text\": \"Older than the courtyard. Possibly older than the Sprawl. Cael speaks of the bell as kin. I have stopped arguing. The bell does not seem to mind either way.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"matter\": {\"speaker\": \"Historian Pren\", \"text\": \"*(a small, real pause)*  ...That, walker, is the one thing I have never had a satisfying answer to. I keep teaching anyway. Make of it what you will.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Historian Pren\", \"text\": \"Walk well. Read the plinths.\"}}}"

[node name="Npc27_Olm" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.707105, 0, -0.707108, 0, 1, 0, 0.707108, 0, 0.707105, -7, 0, 3)
npc_name = "Olm"
body_color = Color(0.5, 0.4, 0.32, 1)
hat_color = Color(0.6, 0.42, 0.22, 1)
idle_hint = "[E] Talk to Olm"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Olm\", \"text\": \"*(in a Bind's clipped tone)* You're staring. Yes, I'm Bind. No, I'm not selling. I came here to mock the verses.\", \"choices\": [{\"label\": \"And?\", \"next\": \"and\"}, {\"label\": \"Why are you still here?\", \"next\": \"still\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"and\": {\"speaker\": \"Olm\", \"text\": \"And the first one was awful. *Truly* awful. Then I read another. ...And another. Then I sat down. Then a turn of the moon went by.\", \"choices\": [{\"label\": \"Why are you still here?\", \"next\": \"still\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"still\": {\"speaker\": \"Olm\", \"text\": \"*(quieter)* My ledger sits on its shelf. My stall is still open. My second-cousin keeps the chips. I keep coming back. I do not know why. ...That is not honest. I know exactly why.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Olm\", \"text\": \"Walk well. Don't tell the Guild.\"}}}"

[node name="Npc28_Bell_keeper_Cael" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, 7, 0, 3)
npc_name = "Bell-keeper Cael"
body_color = Color(0.6, 0.6, 0.65, 1)
hat_color = Color(0.78, 0.78, 0.85, 1)
idle_hint = "[E] Speak with Cael"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Bell-keeper Cael\", \"text\": \"Walker. The bell is well today. She has been quiet a long time, and she is enjoying the quiet.\", \"choices\": [{\"label\": \"Tell me about the bell.\", \"next\": \"bell\"}, {\"label\": \"How long have you tended her?\", \"next\": \"long\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bell\": {\"speaker\": \"Bell-keeper Cael\", \"text\": \"She is older than her tower, older than the courtyard, older than the agreement that brought the courtyard here. I do not know who first hung her. I do not need to.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"long\": {\"speaker\": \"Bell-keeper Cael\", \"text\": \"Long enough. My grandmother tended her. Her grandmother tended her. The line has been thin once or twice. We always come back to her. She is patient.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Bell-keeper Cael\", \"text\": \"Walk well. Listen for her on the hour.\"}}}"

[node name="Npc29_Apprentice_Nye" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0, 6)
npc_name = "Apprentice Nye"
body_color = Color(0.65, 0.7, 0.85, 1)
hat_color = Color(0.9, 0.85, 0.6, 1)
idle_hint = "[E] Talk to Nye"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Apprentice Nye\", \"text\": \"Oh — hello. I'm — I'm practicing. Telva says the plinth lines come easier if you say them aloud. They don't. Yet.\", \"choices\": [{\"label\": \"Try one on me.\", \"next\": \"try\"}, {\"label\": \"Don't be shy.\", \"next\": \"shy\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"try\": {\"speaker\": \"Apprentice Nye\", \"text\": \"Um — \\\"The hand that holds — that holds —\\\" ...the hand that holds *something*. I forget the rest. Telva will know. She always knows.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"shy\": {\"speaker\": \"Apprentice Nye\", \"text\": \"I'm not — I'm just — quiet. Quiet is also Sharer work, Cael says. The bell is quiet most of the time too.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Apprentice Nye\", \"text\": \"Walk well! ...I'll get the line right next time.\"}}}"

