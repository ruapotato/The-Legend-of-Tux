size = Vector3(0.7, 0.7, 1.1)

; Adapted from hamberg sheep: fluffy wool body composed of an oversized
; torso sphere with smaller bump spheres clustered on top, a dark capsule
; head with a wool tuft, four slim dark legs, a curly tail puff. The
; bumps are the load-bearing visual cue — flat sphere reads as 'ball', a
; cluster of overlapping spheres reads as 'fluff'.
[sub_resource type="SphereMesh" id="torso_mesh"]
radius = 0.32
height = 0.55
radial_segments = 12
rings = 6

