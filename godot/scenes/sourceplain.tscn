[node name="Npc125_Wandering_Reader_Bess" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 50, 0, 30)
npc_name = "Wandering Reader Bess"
body_color = Color(0.42, 0.45, 0.55, 1)
hat_color = Color(0.25, 0.28, 0.4, 1)
idle_hint = "[E] Speak with the wanderer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Wandering Reader Bess\", \"text\": \"*she's seated cross-legged on the grass, a small book open across her knee. She does not look up immediately.*\\n\\nMm. A walker. Sit, if you like. The wind reads aloud out here.\", \"choices\": [{\"label\": \"(Offer the painted mask.)\", \"next\": \"trade\", \"requires_flag\": \"trade_step_2\", \"requires_not\": \"trade_step_3\"}, {\"label\": \"(Show the folded scroll.)\", \"next\": \"already\", \"requires_flag\": \"trade_step_3\"}, {\"label\": \"What are you reading?\", \"next\": \"book\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"trade\": {\"speaker\": \"Wandering Reader Bess\", \"text\": \"*she finally looks up — and her quiet face lifts in a slow, surprised smile.*\\n\\nOh. Oh, that is a fox-mask, isn't it. Lacquer still wet at the edge. Drift work. I had one as a child. I lost it to a brookbed and cried for a season.\\n\\nHere — let me trade you fairly. This scroll has been folded in my pack for a year. I copied it from a stone I'll never find again. Carry it. It deserves a road, and I deserve to wear a fox-face for an afternoon.\", \"sets_flag\": \"trade_step_3\", \"next\": \"thanks\"}, \"thanks\": {\"speaker\": \"Wandering Reader Bess\", \"text\": \"*she ties the mask carefully into her hair-cord, both hands.*\\n\\nThank you, walker. Walk gently with the scroll. Some words like quiet hands.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"already\": {\"speaker\": \"Wandering Reader Bess\", \"text\": \"*she touches the lacquer at her temple and smiles faintly.*\\n\\nStill carrying the scroll? Good. The right reader will know it. They always do.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"book\": {\"speaker\": \"Wandering Reader Bess\", \"text\": \"An old hand-bound thing. Songs and small accounts. I've read it eleven times and still find a line that surprises me. That's the test of a good book — that the eleventh reading still has weather in it.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Wandering Reader Bess\", \"text\": \"Walk well, walker. The road reads you back, you know.\"}}}"

