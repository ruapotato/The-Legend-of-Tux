[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 1, 0, 95)
message = "SOUTHWARD: The bridge to the Wyrdwood.\n\nThe river beneath grows louder at dusk."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, 3.4641e-07, 0, 1, 0, -3.4641e-07, 0, -1, 1, 0, -93)
message = "NORTHWARD: Hearthold's gate.\n\nLast haven before the Hoarder's roads."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 125, 0, 1)
message = "EASTWARD: Brookhold of the Source-keepers.\n\nMind the lanterns; they listen."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -91, 0, 1)
message = "WESTWARD: The Burnt Hollow.\n\nWhat Khorgaul takes, he scorches.\nGo armed, and bring a key."

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, 0.707103, 0, 1, 0, -0.707103, 0, -0.707111, 85, 0, -83)
message = "UP TO STONEROOST.\n\nThe stair climbs through wind.\nDo not look down at the carrion-crows."

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, -0.707103, 0, 1, 0, 0.707103, 0, -0.707111, 85, 0, 85)
message = "SOUTHWARD AGAIN: The Mirelake.\n\nReed and pitch and slow water.\nThe Mire keeps its own counsel."

[node name="Sign8" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -53, 0, -47)
message = "A cairn of stones, half-overgrown.\n\nA name has been chiseled out.\nSomeone tried to remember."

[node name="Sign9" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 41, 0, 39)
message = "Glim flickers brighter here.\n\n\"The Source remembers,\" the wisp says, \"even what you have forgotten.\""

[node name="Sign10" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -63, 0, 29)
message = "Old wagon-ruts, deep in the grass.\n\nThey lead nowhere now."

