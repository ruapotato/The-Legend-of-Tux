[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0, 11)
message = "AT THE GATEWAY\n\n\"Walk gently.\nThese were saved for you.\""

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -8, 0, 8)
message = "Brass dedication on a bench:\n\n\"For those who sat here\nand for those who will.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 8, 0, 8)
message = "Brass dedication on a bench:\n\n\"In memory of Pell, who would not let the fountain be removed. The fountain is still here.\""

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -8, 0, -4)
message = "Brass dedication on a bench:\n\n\"For all who came back tired.\nThe hedges keep your shape.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0, 0)
message = "A long inscription beside the central garden:\n\n\"Lirien sets her care on what was, even when no one asked her to keep it. The Yard is one such place. The bench where you are sitting is another.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 8, 0, -4)
message = "Inscription on the dry fountain:\n\n\"It ran for a thousand years.\nIt is resting.\nWalk well.\""

