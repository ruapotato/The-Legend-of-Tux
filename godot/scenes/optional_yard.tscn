[node name="Npc9_Groundskeeper_Tess" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, -6, 0, 6)
npc_name = "Groundskeeper Tess"
body_color = Color(0.4, 0.55, 0.35, 1)
hat_color = Color(0.3, 0.4, 0.25, 1)
idle_hint = "[E] Speak with Tess"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Groundskeeper Tess\", \"text\": \"Welcome to the Yard, traveler. Wipe your feet on nothing in particular — the path keeps itself. What can I tell you?\", \"choices\": [{\"label\": \"Who tends this place?\", \"next\": \"tend\"}, {\"label\": \"What is here?\", \"next\": \"here\"}, {\"label\": \"Tell me of Lirien.\", \"next\": \"lirien\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"tend\": {\"speaker\": \"Groundskeeper Tess\", \"text\": \"I do, mostly. The leaves help. The hedges have been here longer than my line. Sometimes I think they tend me.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"here\": {\"speaker\": \"Groundskeeper Tess\", \"text\": \"Old gardens. Older benches. A fountain that has not run in three winters but has not stopped being a fountain. We keep what was, even when no one asks.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"lirien\": {\"speaker\": \"Groundskeeper Tess\", \"text\": \"She has walked here. I have not seen her, but the leaves know. They turn a little when the wind is from a direction the wind is not from. It is a kind of unease, and a kind of welcome.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Groundskeeper Tess\", \"text\": \"Walk gently. The Yard remembers walking.\"}}}"

[node name="Npc10_Poet_Nira" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.707111, 0, 0.707103, 0, 1, 0, -0.707103, 0, -0.707111, 6, 0, 6)
npc_name = "Poet Nira"
body_color = Color(0.55, 0.45, 0.65, 1)
hat_color = Color(0.3, 0.2, 0.4, 1)
idle_hint = "[E] Greet Nira"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Poet Nira\", \"text\": \"Hush — I'm almost there. Just a couplet, that's all I came for. Would you hear it?\", \"choices\": [{\"label\": \"Please.\", \"next\": \"couplet\"}, {\"label\": \"Another time.\", \"next\": \"bye\"}]}, \"couplet\": {\"speaker\": \"Poet Nira\", \"text\": \"\\\"What was kept here was kept by no one's asking;\\nthe leaves remembered, and the leaves were enough.\\\"\", \"choices\": [{\"label\": \"That's good.\", \"next\": \"thanks\"}]}, \"thanks\": {\"speaker\": \"Poet Nira\", \"text\": \"It came easy. They mostly don't. Walk well, traveler. Tell the leaves I said thank you.\"}, \"bye\": {\"speaker\": \"Poet Nira\", \"text\": \"Walk well. The couplet will keep.\"}}}"

[node name="Npc11_Young_Wyrdkin_Jen" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0, -8)
npc_name = "Young Wyrdkin Jen"
body_color = Color(0.4, 0.45, 0.55, 1)
hat_color = Color(0.55, 0.5, 0.4, 1)
idle_hint = "[E] Speak with Jen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Young Wyrdkin Jen\", \"text\": \"Oh — hello. Sorry. I was thinking. You're not interrupting, I just — I'm thinking. Did you need something?\", \"choices\": [{\"label\": \"What are you thinking about?\", \"next\": \"ask1\"}, {\"label\": \"Nothing. Walk well.\", \"next\": \"bye\"}]}, \"ask1\": {\"speaker\": \"Young Wyrdkin Jen\", \"text\": \"Oh — nothing, really. I came here to think and I'd rather not say what about. Sorry. The Yard is good for not-saying.\", \"choices\": [{\"label\": \"Are you sure?\", \"next\": \"ask2\"}, {\"label\": \"Of course. Walk well.\", \"next\": \"bye\"}]}, \"ask2\": {\"speaker\": \"Young Wyrdkin Jen\", \"text\": \"...all right. My brother went up the Stoneroost trail at the start of the spring and hasn't come back yet. He said he might not. I'm trying to decide if I'm allowed to be angry, or only sad. The hedges are helping me work it out.\", \"choices\": [{\"label\": \"I'm sorry.\", \"next\": \"thanks\"}]}, \"thanks\": {\"speaker\": \"Young Wyrdkin Jen\", \"text\": \"Thank you. Walk well. Tell anyone climbing toward Stoneroost that Jen's brother owes her a letter.\"}, \"bye\": {\"speaker\": \"Young Wyrdkin Jen\", \"text\": \"Walk well. Thank you for being kind.\"}}}"

