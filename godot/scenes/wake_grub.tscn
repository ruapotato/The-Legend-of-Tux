[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0, 4)
message = "Wake Sub-shrine.\n\nA narrow alcove behind the eastern step. The walls hold the names of every thing the realm wakes through, in the order it wakes them."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -4, 0.4, -5.5)
message = "FIRST INSCRIPTION\n\n\"First the captain reads the names of the realm — every kin who has stood the morning, in the order they came to it. The reading is short. The list is not.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2, 0.4, -5.5)
message = "SECOND INSCRIPTION\n\n\"Then the bell sounds three times. Once for what was. Once for what is. Once for what will be — if we hold.\""

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0.4, -5.5)
message = "THIRD INSCRIPTION\n\n\"Then the sun is greeted at the eastern step. The greeting is small. The sun has heard it before. The sun does not require it. The sun receives it.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2, 0.4, -5.5)
message = "FOURTH INSCRIPTION\n\n\"Then the veterans are saluted. Those who have stood and stand still. Those who stood and stand no longer. Both are present at the rite. Both are saluted.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 4, 0.4, -5.5)
message = "FIFTH INSCRIPTION\n\n\"Then the day is given to Lirien, and Lirien gives it back. This is the whole of the morning. It is a small thing. It is the only thing.\""

[node name="Chest6" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0, -3)
contents_scene = ExtResource("heart_piece")
open_message = "A small fragment of a heart, kept beneath the inscriptions. The Wake remembers every reader."

[node name="Npc7_The_Reader" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3, 0.4, -4.5)
npc_name = "The Reader"
body_color = Color(0.45, 0.4, 0.55, 1)
hat_color = Color(0.25, 0.22, 0.3, 1)
idle_hint = "[E] Speak with the Reader"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"The Reader\", \"text\": \"*she is bent over a long sheet of vellum, copying an inscription with a goose-quill* Hm. A traveler. Step softly — the ink is wet, and the stones are old.\", \"choices\": [{\"label\": \"What are you copying?\", \"next\": \"what\"}, {\"label\": \"Where are you from?\", \"next\": \"from\"}, {\"label\": \"May I read with you?\", \"next\": \"read\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"The Reader\", \"text\": \"The fifth inscription. The hardest one. So small a thing, the morning — and yet the words for it have to be exactly right, or the rite reads wrong. I have copied this one before. I will copy it again.\", \"choices\": [{\"label\": \"Where are you from?\", \"next\": \"from\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"from\": {\"speaker\": \"The Reader\", \"text\": \"From a place where readers go when they want to read. We had a quiet room, and lamps that did not flicker. — Hm. We have a quiet room, I should say. The lamps still do not flicker. Forgive me; I have been at this since dark.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"read\": {\"speaker\": \"The Reader\", \"text\": \"Read all five, in order, slowly. That is the whole of the puzzle, if you must call it one. The inscriptions tell you what the morning is. If you have read them — you already know.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"The Reader\", \"text\": \"Walk well. Mind the wet ink.\"}}}"

[node name="Npc8_Hidden_Child" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.128844, 0, 0.991665, 0, 1, 0, -0.991665, 0, -0.128844, 4, 0, 2)
npc_name = "Hidden Child"
body_color = Color(0.85, 0.7, 0.55, 1)
hat_color = Color(0.95, 0.55, 0.35, 1)
idle_hint = "[E] Look behind the pillar"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Hidden Child\", \"text\": \"*a small kin pressed flat against the back of a stone pillar* shhh. shhh. you can't see me. i'm a stone too.\", \"choices\": [{\"label\": \"I won't tell anyone you're here.\", \"next\": \"kind\"}, {\"label\": \"What are you doing?\", \"next\": \"what\"}, {\"label\": \"Hello, stone.\", \"next\": \"stone\"}]}, \"kind\": {\"speaker\": \"Hidden Child\", \"text\": \"...okay. okay you're nice. i'll tell you a secret. the captain comes here at the second bell and she sits, and she puts her head on the wall, and she breathes for a long time. and then she goes and reads the names. don't tell.\", \"choices\": [{\"label\": \"I won't.\", \"next\": \"wont\"}]}, \"wont\": {\"speaker\": \"Hidden Child\", \"text\": \"good. you're a stone too now. stones don't tell.\"}, \"what\": {\"speaker\": \"Hidden Child\", \"text\": \"i'm hiding from the bell. it's so LOUD. but mama says if i listen all the way through, one day i'll hear what the cliffs say back. so i'm practicing. but quietly.\", \"choices\": [{\"label\": \"I won't tell anyone you're here.\", \"next\": \"kind\"}, {\"label\": \"Good luck, little one.\", \"next\": \"luck\"}]}, \"stone\": {\"speaker\": \"Hidden Child\", \"text\": \"...you can see me, can't you. *a long pause* the stones DON'T see you back. that's the rule. you're cheating.\"}, \"luck\": {\"speaker\": \"Hidden Child\", \"text\": \"thanks. walk well. quietly.\"}}}"

