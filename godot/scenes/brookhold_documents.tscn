[node name="Npc1_Almanac_Keeper_Olber" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.194, 0)
npc_name = "Almanac-Keeper Olber"
body_color = Color(0.55, 0.62, 0.4, 1)
hat_color = Color(0.78, 0.55, 0.32, 1)
idle_hint = "[E] Speak to Olber"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Almanac-Keeper Olber\", \"text\": \"Welcome to the almanac. Every planting, every harvest,\\nevery queer year — it's all on this shelf.\", \"choices\": [{\"label\": \"What's the last entry?\", \"next\": \"last\"}, {\"label\": \"How far back does it go?\", \"next\": \"back\"}, {\"label\": \"Walk well.\"}]}, \"last\": {\"speaker\": \"Almanac-Keeper Olber\", \"text\": \"Last entry says: 'a stranger asked the cows.' I didn't\\nwrite that. I don't know who did.\", \"choices\": [{\"label\": \"What did the cows say?\", \"next\": \"cows\"}]}, \"cows\": {\"speaker\": \"Almanac-Keeper Olber\", \"text\": \"Cows don't speak to me. Perhaps they spoke to the stranger.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"back\": {\"speaker\": \"Almanac-Keeper Olber\", \"text\": \"Four generations. The earliest pages are in my\\ngreat-grandmother's hand. She used a different\\ncalendar; we still don't quite agree which days were\\nTuesday.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 0.733, -1)
message = "Almanac —\n\nwhen to plant, when to harvest."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, -1.174, -1)
message = "Last entry: 'a stranger asked the cows.'"

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.897, 4)
message = "A row of clothbound books, each labelled with a year.\nThe newest is open. The pen sits across the page."

