[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 4, 0, -2)
message = "Glim chimes once, gently. \"You can read what's left of the Source by Sight,\" she says, \"but only one Sigil can pass it on. We carry that one.\""

