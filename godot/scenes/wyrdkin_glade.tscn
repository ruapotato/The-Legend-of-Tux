[node name="Npc42_Old_Hesper" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.416147, 0, 0.909297, 0, 1, 0, -0.909297, 0, -0.416147, 3, -0.392, 8)
npc_name = "Old Hesper"
body_color = Color(0.5, 0.65, 0.7, 1)
hat_color = Color(0.3, 0.45, 0.55, 1)
idle_hint = "[E] Speak with the keeper"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Old Hesper\", \"text\": \"Welcome to the Glade, little one. I am Hesper, oldest of the keepers here. The wyrdkin sleep, and we tend their dreaming. You wake into a strange hour. Will you sit, and learn?\", \"choices\": [{\"label\": \"Tell me of this realm.\", \"next\": \"realm\"}, {\"label\": \"What is the Sigil of Sharing?\", \"next\": \"sigil\"}, {\"label\": \"Who is Glim?\", \"next\": \"glim\"}, {\"label\": \"Where should I go?\", \"next\": \"go\"}, {\"label\": \"Farewell, keeper.\", \"next\": \"bye\"}]}, \"realm\": {\"speaker\": \"Old Hesper\", \"text\": \"This is Lirien's weave. Forest, brook, kiln, and stone — all spun from the Source. The Maker gave; the Hoarder takes. The balance has tipped, and so the wardstones thin. That is why you are here.\", \"choices\": [{\"label\": \"What is the Sigil of Sharing?\", \"next\": \"sigil\"}, {\"label\": \"Who is Glim?\", \"next\": \"glim\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"sigil\": {\"speaker\": \"Old Hesper\", \"text\": \"Three sigils mark the Triglyph — Sight, Shaping, Sharing. Yours is the third. To share is to refuse the hoard; to refuse the hoard is to be the answer to Khorgaul. Carry it gently. Carry it bright.\", \"choices\": [{\"label\": \"Who is Glim?\", \"next\": \"glim\"}, {\"label\": \"Tell me of this realm.\", \"next\": \"realm\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"glim\": {\"speaker\": \"Old Hesper\", \"text\": \"A wisp — a fleck of the Source given a small, brave will. She has chosen you, and that is no small thing. Where you are dim, Glim brightens. Where you forget, Glim remembers.\", \"choices\": [{\"label\": \"Where should I go?\", \"next\": \"go\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"go\": {\"speaker\": \"Old Hesper\", \"text\": \"North, through the wyrdwood. Past the fork, past the ribbon, into the Hollow. You will know it when you see it. The road from there is yours to find.\", \"choices\": [{\"label\": \"Thank you, keeper.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Old Hesper\", \"text\": \"Walk in the green. Walk under the wing of Lirien.\"}}}"

[node name="Npc43_Little_Pip" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.0707372, 0, -0.997495, 0, 1, 0, 0.997495, 0, 0.0707372, -4, 0.648, -6)
npc_name = "Little Pip"
body_color = Color(0.65, 0.8, 0.75, 1)
hat_color = Color(0.55, 0.7, 0.85, 1)
idle_hint = "[E] Talk to Pip"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Little Pip\", \"text\": \"Are you the wanderer? Hesper said a wanderer would come. Are you going north? You should go north! The wyrdwood is north!\", \"next\": \"two\"}, \"two\": {\"speaker\": \"Little Pip\", \"text\": \"I'm not allowed to go past the marker stone. But you can! Go on! The trees there know secrets. I think they whisper them to wisps. Maybe Glim already knows!\"}}}"

[node name="Chest44" parent="." instance=ExtResource("chest")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -9, -0.034, -13)
contents_scene = ExtResource("heart_piece")
open_message = "A piece of heart, pressed deep into a thicket of wyrdkin-bramble. Glim says the bushes were planted to hide it."

[node name="Sign45" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -12, -1.224, 7)
message = "A leaf-curtain stirs against the wall — there is a hollow behind it."

[node name="Npc46_Glim" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.999999, 0, -0.00159265, 0, 1, 0, 0.00159265, 0, -0.999999, 0, -0.295, 4)
npc_name = "Glim"
body_color = Color(0.95, 0.92, 0.55, 1)
hat_color = Color(1, 0.85, 0.3, 1)
idle_hint = "[E] Listen to Glim"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Glim\", \"text\": \"*The little wisp pulses, gentle and curious.* You hear me, don't you. The Source still moves through you. Good.\", \"choices\": [{\"label\": \"Teach me a song.\", \"next\": \"teach\", \"requires_not\": \"glim_theme_learned\"}, {\"label\": \"(You hum the song to yourself.)\", \"next\": \"remembered\", \"requires_song\": \"glim_theme\"}, {\"label\": \"Goodbye.\", \"next\": \"bye\"}]}, \"teach\": {\"speaker\": \"Glim\", \"text\": \"Listen — and remember. *up... right... down... left... up.* Carry it. Hum it at any owl-shrine and the keepers will tend you. *[Z] to hum.*\", \"learns_song\": \"glim_theme\", \"next\": \"bye\"}, \"remembered\": {\"speaker\": \"Glim\", \"text\": \"Yes. The melody's in you now. The Source remembers what you remember.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Glim\", \"text\": \"*Glim drifts a little higher and waits.*\"}}}"

