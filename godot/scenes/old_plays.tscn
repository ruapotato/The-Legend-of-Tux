[node name="Npc17_Carnival_Barker" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, -2.206, -2.5)
npc_name = "Carnival Barker"
body_color = Color(0.55, 0.55, 0.6, 1)
hat_color = Color(0.5, 0.5, 0.55, 1)
idle_hint = "[E] Listen to the barker"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Carnival Barker\", \"text\": \"STEP RIGHT UP! step right up... step... ...you came. Nobody comes any more. ...Step right up.\", \"choices\": [{\"label\": \"Try the Sharpshooter (5 pebbles).\", \"requires\": \"bow\", \"opens_minigame\": \"target_practice\", \"minigame_radius\": 12.0}, {\"label\": \"What's the Sharpshooter?\", \"next\": \"what_game\", \"requires_not\": \"bow\"}, {\"label\": \"What was this place?\", \"next\": \"place\"}, {\"label\": \"Are you alright?\", \"next\": \"alright\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"what_game\": {\"speaker\": \"Carnival Barker\", \"text\": \"Painted boards on a line. You shoot them. You used to shoot them. The boards are still there. The bows... the bows have walked off, walker. Find one and step right back up.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"place\": {\"speaker\": \"Carnival Barker\", \"text\": \"The Old Plays. Loud once. Bright. The painted boards were freshly painted, then. Children came. Their children stopped. Then so did everyone else.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"alright\": {\"speaker\": \"Carnival Barker\", \"text\": \"I am where I was. That is its own kind of alright. Step right up, walker. The line is clear. The line has always been clear.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Carnival Barker\", \"text\": \"Step right out, then. Walk well. ...Step right up...\"}}}"

[node name="Npc18_Caretaker_Tomm" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -3, -1.72, 0)
npc_name = "Caretaker Tomm"
body_color = Color(0.42, 0.36, 0.3, 1)
hat_color = Color(0.55, 0.42, 0.25, 1)
idle_hint = "[E] Talk to Tomm"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Caretaker Tomm\", \"text\": \"Eh. A walker. Don't get many. You carry a bow, by chance? The target row's still good for a turn or two.\", \"choices\": [{\"label\": \"I have a bow — let's play.\", \"next\": \"play\", \"requires\": \"bow\"}, {\"label\": \"No bow on me.\", \"next\": \"no_bow\", \"requires_not\": \"bow\"}, {\"label\": \"Tell me about this place.\", \"next\": \"place\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"play\": {\"speaker\": \"Caretaker Tomm\", \"text\": \"*(creaks to his feet, gestures at the line)* Three boards. Hit them clean. The barker keeps no score, but I do. ...There. Good shooting. Take these — small thanks.\", \"give_pebbles\": 3, \"next\": \"after_play\"}, \"after_play\": {\"speaker\": \"Caretaker Tomm\", \"text\": \"Ha. Like the old days, almost. The boards remember being shot at. Come back if your aim wants the practice.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"no_bow\": {\"speaker\": \"Caretaker Tomm\", \"text\": \"*(sighs)* Aye. Come back when you're armed, walker. The line keeps. The boards keep. We all keep.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"place\": {\"speaker\": \"Caretaker Tomm\", \"text\": \"The Old Plays. I keep them. There is not much keeping to do, and yet there is always more. The swing keeps creaking. The boards keep peeling. I keep painting them.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Caretaker Tomm\", \"text\": \"Walk well, walker. Mind the swing.\"}}}"

[node name="Npc19_Quiet_Visitor" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 3, -1.777, 0)
npc_name = "Quiet Visitor"
body_color = Color(0.4, 0.45, 0.55, 1)
hat_color = Color(0.5, 0.55, 0.6, 1)
idle_hint = "[E] Speak softly"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Quiet Visitor\", \"text\": \"Walker.\", \"choices\": [{\"label\": \"Why come here?\", \"next\": \"why\"}, {\"label\": \"What do you remember?\", \"next\": \"remember\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"why\": {\"speaker\": \"Quiet Visitor\", \"text\": \"Every day. Have, for some time. The boards know me. The swing knows me. That is enough.\", \"choices\": [{\"label\": \"What do you remember?\", \"next\": \"remember\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"remember\": {\"speaker\": \"Quiet Visitor\", \"text\": \"*(does not answer for a long moment)*  ...You came in good time. The light is right today. Walk well, walker.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Quiet Visitor\", \"text\": \"Walk well.\"}}}"

[node name="Chest20" parent="." instance=ExtResource("chest")]
