[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, 3, 0, -3)
message = "POSTED RULES\n\n1. No bringing your own pebbles.\n2. The barker's word is final.\n3. The barker has been final\n   for some time now."

[node name="Sign3" parent="." instance=ExtResource("sign")]
