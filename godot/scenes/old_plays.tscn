idle_hint = "[E] Talk to the Cow"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"The Cow\", \"text\": \" ____________________\\n< Moo. Have a nice day. >\\n --------------------\\n        \\\\   ^__^\\n         \\\\  (oo)\\\\_______\\n            (__)\\\\       )\\\\/\\\\\\n                ||----w |\\n                ||     ||\", \"choices\": [{\"label\": \"...Walk well, cow.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"The Cow\", \"text\": \"*The Cow chews. The bubble holds.*\"}}}"

