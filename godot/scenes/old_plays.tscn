[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, -0.707108, 0, 1, 0, 0.707108, 0, 0.707105, -3, 0, -3)
message = "PAINTED BOARD (faded)\n\n— RING TOSS —\nThree rings, two chips.\nWinner takes a wooden trout.\n\n(boards weathered; a swing creaks somewhere)"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, 3, 0, -3)
message = "POSTED RULES\n\n1. No bringing your own pebbles.\n2. The barker's word is final.\n3. The barker has been final\n   for some time now."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, -0.707103, 0, 1, 0, 0.707103, 0, -0.707111, -3, 0, 3)
message = "NOTICE\n\nThe annual festival has been postponed.\nIt has been postponed for seventeen years.\nThe banners go up anyway."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-0.707111, 0, 0.707103, 0, 1, 0, -0.707103, 0, -0.707111, 3, 0, 3)
message = "WYRDMARK ↗\n\n(arrow points at nothing — paint flaked away below)"

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -5, 0, 0)
message = "TARGET ROW\n\nA painted board at the far end\nstill bears the scars of old arrows.\nThe Caretaker keeps the line clear,\nin case anyone with a bow comes by."

[node name="Chest6" parent="." instance=ExtResource("chest")]
