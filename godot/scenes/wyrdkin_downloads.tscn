[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 1.466, 2)
message = "Wyrdkin Downloads\n\n/home/wyrdkin/Downloads"

[node name="Npc1_Postal_Wyrd_Hessa" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 2.069, 0)
npc_name = "Postal-Wyrd Hessa"
body_color = Color(0.45, 0.42, 0.55, 1)
hat_color = Color(0.62, 0.55, 0.65, 1)
idle_hint = "[E] Speak to Hessa"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Postal-Wyrd Hessa\", \"text\": \"Mm. I keep leaving it here. The pile by the door. I\\nmean to read it, and then a day goes by, and the pile\\ngrows.\", \"choices\": [{\"label\": \"Anything from far away?\", \"next\": \"far\"}, {\"label\": \"Why not just open one?\", \"next\": \"open\"}, {\"label\": \"Walk well.\"}]}, \"far\": {\"speaker\": \"Postal-Wyrd Hessa\", \"text\": \"A folded scroll on top — from somewhere I cannot place.\\nCould be the Drift. Could be older than the Drift.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"open\": {\"speaker\": \"Postal-Wyrd Hessa\", \"text\": \"Because then there will be a thing to do, child. And\\nI am not yet ready for a thing to do.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 2.742, -1)
message = "Things to read — never read.\n\nThe pile by the door grows."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 1.736, -1)
message = "Letters, scrolls, three folded broadsides. Most are\nstill sealed. The seals are unfamiliar."

[node name="LoadZone0" type="Area3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.228668, 5.436, -9.49524)
collision_layer = 64
