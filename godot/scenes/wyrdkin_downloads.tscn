target_spawn = "from_wyrdkin_downloads"
auto_trigger = true
prompt = "[E] Back to the Old Hold"

[node name="Shape" type="CollisionShape3D" parent="LoadZone0"]
shape = SubResource("s166")

[node name="Hint" type="Label3D" parent="LoadZone0"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 3.8, 0)
text = "[E] Back to the Old Hold"
font_size = 32
outline_size = 8
billboard = 1
no_depth_test = true

[node name="Tux" parent="." instance=ExtResource("tux")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.5, 0)
camera_path = NodePath("../Camera")

[node name="Glim" parent="." instance=ExtResource("glim")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.6, 1.4, 0)

[node name="Camera" type="Node3D" parent="."]
script = ExtResource("camera_script")

[node name="SpringArm" type="SpringArm3D" parent="Camera"]
spring_length = 4.5
margin = 0.05

[node name="Camera" type="Camera3D" parent="Camera/SpringArm"]
fov = 70.0

[node name="HUD" parent="." instance=ExtResource("hud")]

[node name="DebugOverlay" type="CanvasLayer" parent="."]
script = ExtResource("debug_script")
visible_initial = false

[node name="PauseMenu" type="CanvasLayer" parent="."]
script = ExtResource("pause_script")
