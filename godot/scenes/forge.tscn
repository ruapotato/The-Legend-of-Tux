[node name="Npc113_Maker_s_Apprentice" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -2, 1.126, -2)
npc_name = "Maker's Apprentice"
body_color = Color(0.5, 0.35, 0.25, 1)
hat_color = Color(0.3, 0.2, 0.15, 1)
idle_hint = "[E] Speak with the apprentice"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Maker's Apprentice\", \"text\": \"*soot on the cheeks, broom in hand*\\n\\nI clean up before I build. Always have. The Forge runs sour if you do not. My mentor said it. Her mentor said it. I am saying it to you in case you forget.\", \"choices\": [{\"label\": \"make clean.\", \"next\": \"yes\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"yes\": {\"speaker\": \"Maker's Apprentice\", \"text\": \"Now you understand. *she returns to the broom*\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Maker's Apprentice\", \"text\": \"*sweep, sweep*\"}}}"

