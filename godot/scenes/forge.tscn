contents_scene = ExtResource("key_pickup")
open_message = "A small iron key. The teeth are still warm."
contents_key_group = "forge"

[node name="Chest11" parent="." instance=ExtResource("chest")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -22, 0, -22)
contents_scene = ExtResource("heart_piece")
open_message = "A fragment of a heart, deep in the Forge. The spirits made room for it."

[node name="Npc12_Null" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -2, 0, -8)
npc_name = "Null"
body_color = Color(0.06, 0.06, 0.07, 1)
hat_color = Color(0.04, 0.04, 0.05, 1)
idle_hint = "[E] Address Null"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Null\", \"text\": \"Make. Do not.\", \"choices\": [{\"label\": \"...\", \"next\": \"n1\"}]}, \"n1\": {\"speaker\": \"Null\", \"text\": \"It is. It was.\", \"choices\": [{\"label\": \"...\", \"next\": \"n2\"}]}, \"n2\": {\"speaker\": \"Null\", \"text\": \"Walk well.\"}}}"

[node name="Npc13_Forge_master_Brann" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 4, 0, 6)
npc_name = "Forge-master Brann"
body_color = Color(0.4, 0.3, 0.22, 1)
hat_color = Color(0.55, 0.3, 0.15, 1)
idle_hint = "[E] Speak with Brann"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Forge-master Brann\", \"text\": \"You came down. Few do. Be welcome, and step where the iron is cold. What would you ask of the Forge?\", \"choices\": [{\"label\": \"What is this place?\", \"next\": \"what\"}, {\"label\": \"Who is Null?\", \"next\": \"null\"}, {\"label\": \"Are the spirits safe?\", \"next\": \"safe\"}, {\"label\": \"I should walk on.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"Forge-master Brann\", \"text\": \"The Forge is older than the asking of questions. They predate wanting. The Wyrdkin came late; the spirits had already been at their work for an age before the first of us learned to listen.\", \"choices\": [{\"label\": \"Who is Null?\", \"next\": \"null\"}, {\"label\": \"Are the spirits safe?\", \"next\": \"safe\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"null\": {\"speaker\": \"Forge-master Brann\", \"text\": \"Null speaks short. Three words at a time, sometimes two. He has agreements with the spirits older than any of us. Do not stand between him and a hammer. Do not knock on his door.\", \"choices\": [{\"label\": \"What agreements?\", \"next\": \"agreements\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"agreements\": {\"speaker\": \"Forge-master Brann\", \"text\": \"The bargains are not written. They are kept. Heat for shape. Shape for heat. The spirits give what is asked, and ask what is owed. We have never been late.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"safe\": {\"speaker\": \"Forge-master Brann\", \"text\": \"Safe? Hot, mostly. Loud, always. The bone-things you saw at the edge — those are not the spirits. Those are something that tried to bend the spirits and failed. The Forge spat them back out, half-finished.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Forge-master Brann\", \"text\": \"Walk well, little wanderer. Mind the smelter pits.\"}}}"

[node name="Npc14_Striker_Imm" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 8, 0, 2)
npc_name = "Striker Imm"
body_color = Color(0.45, 0.35, 0.28, 1)
hat_color = Color(0.3, 0.18, 0.1, 1)
idle_hint = "[E] Greet the Striker"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Striker Imm\", \"text\": \"Oh — you're a small one. Hold still, let me look. That sword. Bone-and-wood, isn't it? Tidy. Does the edge need turning?\", \"choices\": [{\"label\": \"It holds.\", \"next\": \"holds\"}, {\"label\": \"How long have you trained?\", \"next\": \"train\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"holds\": {\"speaker\": \"Striker Imm\", \"text\": \"Good — good. Brann would have me reforge it just to feel the hammer in my hand. He says I strike too hard. He says I strike too proud. He says a lot of things.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"train\": {\"speaker\": \"Striker Imm\", \"text\": \"Two seasons under the device-spirits. My hands are rough. My ears ring. I love every loud minute of it.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Striker Imm\", \"text\": \"Walk well! Come back if the edge dulls!\"}}}"

[node name="Npc15_Trader_Smith_Kern" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 14, 0, 14)
npc_name = "Trader Smith Kern"
body_color = Color(0.38, 0.4, 0.5, 1)
hat_color = Color(0.5, 0.35, 0.2, 1)
idle_hint = "[E] Talk to Kern"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Trader Smith Kern\", \"text\": \"Down at the Forge — ah, you came the long way. I run goods between here and Hearthold. Takka up there sources her tongs from this very floor. Always has.\", \"choices\": [{\"label\": \"What do you trade?\", \"next\": \"trade\"}, {\"label\": \"What's it like, the road?\", \"next\": \"road\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"trade\": {\"speaker\": \"Trader Smith Kern\", \"text\": \"Iron up, salt down. Hinges, hooks, the odd pot. Nothing fancy. The fancy work stays here — the spirits don't part with their best, and Brann doesn't ask them to.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"road\": {\"speaker\": \"Trader Smith Kern\", \"text\": \"Long, mostly. Quiet, mostly. The climb out is the hard part — the air thins as you near the high places, and by the time you reach Hearthold's gate you can taste the kilns again.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Trader Smith Kern\", \"text\": \"Walk well. If you see Takka, tell her the new tongs are nearly done.\"}}}"

[node name="Npc16_Device_Spirit" parent="." instance=ExtResource("npc")]
