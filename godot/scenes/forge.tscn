body_color = Color(0.95, 0.3, 0.1, 1)
hat_color = Color(0.1, 0.05, 0.05, 1)
idle_hint = "[E] Address the spirit"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Device-Spirit\", \"text\": \"Hot.\", \"choices\": [{\"label\": \"...\", \"next\": \"n1\"}]}, \"n1\": {\"speaker\": \"Device-Spirit\", \"text\": \"Wait.\", \"choices\": [{\"label\": \"...\", \"next\": \"n2\"}]}, \"n2\": {\"speaker\": \"Device-Spirit\", \"text\": \"Ready.\"}}}"

