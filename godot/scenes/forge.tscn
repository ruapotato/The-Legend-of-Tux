[node name="Npc13_Null" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -2, 0.021, -8)
npc_name = "Null"
body_color = Color(0.06, 0.06, 0.07, 1)
hat_color = Color(0.04, 0.04, 0.05, 1)
idle_hint = "[E] Address Null"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Null\", \"text\": \"Make. Do not.\", \"choices\": [{\"label\": \"...\", \"next\": \"n1\"}]}, \"n1\": {\"speaker\": \"Null\", \"text\": \"It is. It was.\", \"choices\": [{\"label\": \"...\", \"next\": \"n2\"}]}, \"n2\": {\"speaker\": \"Null\", \"text\": \"Walk well.\"}}}"

[node name="Npc14_Forge_master_Brann" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 4, 1.5, 6)
npc_name = "Forge-master Brann"
body_color = Color(0.4, 0.3, 0.22, 1)
hat_color = Color(0.55, 0.3, 0.15, 1)
idle_hint = "[E] Speak with Brann"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Forge-master Brann\", \"text\": \"You came down. Few do. Be welcome, and step where the iron is cold. What would you ask of the Forge?\", \"choices\": [{\"label\": \"What is this place?\", \"next\": \"what\"}, {\"label\": \"Who is Null?\", \"next\": \"null\"}, {\"label\": \"Are the spirits safe?\", \"next\": \"safe\"}, {\"label\": \"I should walk on.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"Forge-master Brann\", \"text\": \"The Forge is older than the asking of questions. They predate wanting. The Wyrdkin came late; the spirits had already been at their work for an age before the first of us learned to listen.\", \"choices\": [{\"label\": \"Who is Null?\", \"next\": \"null\"}, {\"label\": \"Are the spirits safe?\", \"next\": \"safe\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"null\": {\"speaker\": \"Forge-master Brann\", \"text\": \"Null speaks short. Three words at a time, sometimes two. He has agreements with the spirits older than any of us. Do not stand between him and a hammer. Do not knock on his door.\", \"choices\": [{\"label\": \"What agreements?\", \"next\": \"agreements\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"agreements\": {\"speaker\": \"Forge-master Brann\", \"text\": \"The bargains are not written. They are kept. Heat for shape. Shape for heat. The spirits give what is asked, and ask what is owed. We have never been late.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"safe\": {\"speaker\": \"Forge-master Brann\", \"text\": \"Safe? Hot, mostly. Loud, always. The bone-things you saw at the edge — those are not the spirits. Those are something that tried to bend the spirits and failed. The Forge spat them back out, half-finished.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Forge-master Brann\", \"text\": \"Walk well, little wanderer. Mind the smelter pits.\"}}}"

[node name="Npc15_Striker_Imm" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 8, 1.054, 2)
npc_name = "Striker Imm"
body_color = Color(0.45, 0.35, 0.28, 1)
hat_color = Color(0.3, 0.18, 0.1, 1)
idle_hint = "[E] Greet the Striker"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Striker Imm\", \"text\": \"*Imm sets the hammer down. Wipes their brow.* Forge work is rhythm. You strike to a count, or you don't strike at all.\", \"choices\": [{\"label\": \"Teach me your rhythm.\", \"next\": \"teach\", \"requires_not\": \"sun_chord_learned\"}, {\"label\": \"(Hum the Sun Chord.)\", \"next\": \"remembered\", \"requires_song\": \"sun_chord\"}, {\"label\": \"What count do you keep?\", \"next\": \"count\"}, {\"label\": \"Back to your work.\", \"next\": \"bye\"}]}, \"count\": {\"speaker\": \"Striker Imm\", \"text\": \"Right, up, right, up, left. Five strikes. The Forge taught me. The Sun-marked gates remember the same five — older than my line, older than the village.\", \"next\": \"root\"}, \"teach\": {\"speaker\": \"Striker Imm\", \"text\": \"Then listen. *They tap it out on the anvil.* Right... up... right... up... left. Hum it at any sun-marked gate and it'll open. *[Z] to hum.*\", \"learns_song\": \"sun_chord\", \"next\": \"bye\"}, \"remembered\": {\"speaker\": \"Striker Imm\", \"text\": \"*Imm gives a single approving nod and goes back to the work.*\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Striker Imm\", \"text\": \"*Imm's hammer rings.*\"}}}"

[node name="Npc16_make" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 14, 1.116, 14)
npc_name = "make"
body_color = Color(0.38, 0.4, 0.5, 1)
hat_color = Color(0.5, 0.35, 0.2, 1)
idle_hint = "[E] make"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"make\", \"text\": \"Got resources? Got a target? I'll build it. What are you building?\", \"choices\": [{\"label\": \"Show me your wares.\", \"next\": \"wares\"}, {\"label\": \"What's a target?\", \"next\": \"target\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"target\": {\"speaker\": \"make\", \"text\": \"Anything you can name. Bomb. Arrow. Compiler. State you don't have yet. Bring the parts; I assemble.\", \"choices\": [{\"label\": \"Show me the kit.\", \"next\": \"wares\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"wares\": {\"speaker\": \"make\", \"text\": \"Stock on the bench. Bombs, arrows, a compiler if you mean business, a checker if your state's gone foul.\", \"choices\": [{\"label\": \"make install.\", \"opens_shop\": [\"bomb\", \"arrow\", \"gcc\", \"fsck\"]}, {\"label\": \"Maybe later.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"make\", \"text\": \"Nothing to do. Walk well.\"}}}"

