idle_hint = "[E] Touch the stone"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Anvil Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires\": \"hammer\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"hammer\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Anvil Stone\", \"text\": \"The Wyrm splits when struck — but the Maul ends a head outright.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Anvil Stone\", \"text\": \"The Maul is in your hand. The Wyrm will fall.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Anvil Stone\", \"text\": \"*The hum fades.*\"}}}"

