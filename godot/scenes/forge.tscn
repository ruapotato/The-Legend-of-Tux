[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.553, 22)
message = "THE FORGE IS NOT A KINGDOM.\nTHE FORGE IS WORK."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -12, -1.543, 18)
message = "Posted bargain:\n\nHeat is given. Shape is owed.\nShape is given. Heat is owed.\nNo bargain is forgotten.\nNo bargain is broken."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 12, 1.5, -10)
message = "The Strikers' Memorial:\n\nKel of the long arm.\nMera of the slow eye.\nBren who could not stop.\nThom who would not start.\nWalk well, all of you."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -6, -0.827, -16)
message = "Forge-Law the First:\n\nDo not stand between a spirit and the iron it is working.\nThe iron does not move aside for you.\nThe spirit will not."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 18, 0.481, 6)
message = "Forge-Law the Second:\n\nIf a spirit speaks, listen.\nIf a spirit does not speak, listen harder."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -18, 1.66, -12)
message = "A bargain renewed in Brann's hand:\n\n\"For the next turning: forty hinges, a kettle, a name we will not say. Acknowledged.\""

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 6, 1.098, 18)
message = "Posted in faded paint:\n\n\"Strangers from above: do not bring water close to the smelter pits. The spirits will not warn you twice.\""

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -22, 1.116, 4)
message = "An older inscription, the letters worn:\n\n\"The Forge predates the asking of why.\nDo your work. Walk well.\""

