contents_scene = ExtResource("heart_piece")
open_message = "A fragment of a heart, deep in the Forge. The spirits made room for it."

[node name="Chest12" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0, 0)
contents_scene = ExtResource("hammer_pickup")
open_message = "The Striker's Maul, balanced on a stone anvil at the heart of the Forge. The haft fits as if shaped for your hands."
