[node name="Npc0_Config_Steward" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.623, 0)
npc_name = "Config Steward"
body_color = Color(0.78, 0.72, 0.85, 1)
hat_color = Color(0.55, 0.45, 0.62, 1)
idle_hint = "[E] Speak with the Steward"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Config Steward\", \"text\": \"Welcome to the small ritual room. I tend the\\nconfigurations. Would you like me to tune your shield?\", \"choices\": [{\"label\": \"How much?\", \"next\": \"price\"}, {\"label\": \"What does it do?\", \"next\": \"what\"}, {\"label\": \"Walk well.\"}]}, \"price\": {\"speaker\": \"Config Steward\", \"text\": \"Five pebbles. A reasonable trade for a brief grace.\\nThe grace lasts until you change rooms.\", \"choices\": [{\"label\": \"Done.\", \"next\": \"buy\"}, {\"label\": \"Maybe later.\"}]}, \"buy\": {\"speaker\": \"Config Steward\", \"text\": \"Hold still. ...there. Your shield holds a little\\nstronger now. Walk well.\", \"choices\": [{\"label\": \"Thank you.\"}]}, \"what\": {\"speaker\": \"Config Steward\", \"text\": \"Your shield, briefly stronger. A small thing. The kind\\nof small thing that happens here.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 0.653, -1)
message = ".bashrc — read on every login.\n\nEvery time you wake into this hold, this is the first\nthing the kin recite over you."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.747, -2)
message = ".inputrc — your keys.\n\nHow your hands answer the world. Edit it gently."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 1.369, -1)
message = ".vimrc — your edits.\n\nWhat you change of yourself before you start changing\nanything else."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.049, 4)
message = "A curtain hangs across the doorway, ash-grey.\n\nThe room behind it is quiet. The Wyrdkin step in here\nand step out a little different."

