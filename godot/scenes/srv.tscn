[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0.576, 2.5)
message = "THE SERVERY\n\nThe kitchen of the realm. Always cooking. Always feeding. The hearth has not gone out in living memory.\n\n5 PEBBLES — FULL MEAL"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0.557, 1.5)
message = "Pinned by the pass:\n\n'Today: hot stew, hearthbread, and whatever the runners bring back from the gardens. The Servery feeds whoever asks. The Servery has never not fed whoever asked.'"

[node name="Npc2_Head_Cook_Belna" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0.622, 1.5)
npc_name = "Head Cook Belna"
body_color = Color(0.85, 0.7, 0.55, 1)
hat_color = Color(0.95, 0.92, 0.85, 1)
idle_hint = "[E] Speak with the cook"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Head Cook Belna\", \"text\": \"Walker! Sit, sit. You're three shades pale. When did you last eat a hot meal?\\n\\nFive pebbles. Full bowl. Bread on the side. Hearth's hot.\", \"choices\": [{\"label\": \"Five pebbles, please.\", \"next\": \"meal\"}, {\"label\": \"Just looking, thank you.\", \"next\": \"looking\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"meal\": {\"speaker\": \"Head Cook Belna\", \"text\": \"Right then. *she ladles a bowl deep enough to drown a thought in.*\\n\\nMind the steam. Eat slow. The Servery isn't going anywhere — neither should you, for a moment.\\n\\n*you feel warmer just from sitting at her counter. Walk well.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"looking\": {\"speaker\": \"Head Cook Belna\", \"text\": \"Suit yourself. The pot's here when you change your mind. Hearthbread's coming out in a breath if you can wait.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Head Cook Belna\", \"text\": \"Walk well. Eat better. Come back hungry.\"}}}"

[node name="Npc3_Runner_Jenn" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, -0.932039, 0, 1, 0, 0.932039, 0, 0.362358, -1.5, 0.431, -0.5)
npc_name = "Runner Jenn"
body_color = Color(0.6, 0.55, 0.4, 1)
hat_color = Color(0.78, 0.6, 0.42, 1)
idle_hint = "[E] Speak with the runner"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Runner Jenn\", \"text\": \"Hey hey, walker — mind your toes, hot pot coming through!\\n\\n*she balances three bowls and a kettle without spilling.*\\n\\nBelna says we feed the realm. So we feed the realm.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Runner Jenn\", \"text\": \"Walk well! Out of the way of the kettle, walk well!\"}}}"

[node name="Npc4_Runner_Sef" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, 0.932039, 0, 1, 0, -0.932039, 0, 0.362358, 1.5, 0.415, -0.5)
npc_name = "Runner Sef"
body_color = Color(0.55, 0.5, 0.42, 1)
hat_color = Color(0.65, 0.5, 0.35, 1)
idle_hint = "[E] Speak with the runner"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Runner Sef\", \"text\": \"Two more bowls and I can sit down. Maybe.\\n\\nIf you see a walker who looks like they haven't eaten — drag them in here. Belna won't take no for an answer.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Runner Sef\", \"text\": \"Walk well! And eat something!\"}}}"

[node name="Npc5_Bind_Customer" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 0.31, -1.5)
npc_name = "Bind Customer"
body_color = Color(0.5, 0.4, 0.55, 1)
hat_color = Color(0.7, 0.55, 0.35, 1)
idle_hint = "[E] Listen to the customer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Visiting Bind\", \"text\": \"Five pebbles for this? Down at the Sprawl I'd get three pebbles' worth and a complaint card.\\n\\n*he eats anyway. The bowl is empty inside a minute.*\\n\\nBy the Source, that was a good stew. Don't tell Belna I said so.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Visiting Bind\", \"text\": \"Walk well. Tell Belna the pepper was uneven. Don't tell her it wasn't.\"}}}"

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.5, 0.309, -1.5)
message = "Posted on the kitchen door of the Servery:\n\n    tux@servery $ make sandwich\n    Permission denied.\n\n    tux@servery $ sudo make sandwich\n    Okay."

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -3.5, 0.406, -0.5)
message = "Posted at the Servery's front gate:\n\n    It works!\n\nIf you are reading this, the Servery has been raised correctly.\nYou may now serve content as you see fit.\nIf you did not raise this Servery, the keeper would like a word."

