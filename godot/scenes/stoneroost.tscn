[node name="Npc40_Wind_worn_Stone" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 12, 1.077, 32)
npc_name = "Wind-worn Stone"
body_color = Color(0.32, 0.28, 0.4, 1)
hat_color = Color(0.45, 0.5, 0.4, 1)
idle_hint = "[E] Touch the stone"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Wind-worn Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires\": \"hookshot\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"hookshot\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Wind-worn Stone\", \"text\": \"Reach for the perch. The Roost waits in the wind, beyond the leap.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Wind-worn Stone\", \"text\": \"You can reach where the Roost roosts. Rise.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Wind-worn Stone\", \"text\": \"*The hum fades.*\"}}}"

