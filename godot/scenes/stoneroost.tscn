[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 3.05, 40)
message = "Stoneroost.\n\nThe Source thins here. Khorgaul has hoarded the warmth — the pines stand like bones, the moss clings cold. Climb if you can."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 22, -0.914, 16)
message = "A switchback bench. The stone is scored where countless feet have turned. Glim's wisp pales in the wind: the climb steepens."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -22, 4.182, -8)
message = "An old marker, half-buried.\n\n\"Lirien wove the high places first, that the Source might see far. The hoarder builds nests; the Maker built sight.\""

