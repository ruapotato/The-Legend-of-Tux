[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0, 1.5)
message = "THE SCOREROOM\n\nA wall of high-scores from the games at the Old Plays. The keeper adds names as they earn them. The realm respects a high score. The realm respects an honest one more."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0, 2.5)
message = "HIGH SCORES — current and former\n\n  ARCHERY (current):  Velna of Brookhold — 47\n  ARCHERY (former):  Olbrin the Postmaster — 39\n\n  TARGET-ROUND (current):  Sef the Runner — 22\n  TARGET-ROUND (former):  Marn the Toolwright — 18\n\n  SLINGSHOT (current):  Adra of the Hall — 31\n  SLINGSHOT (former):  Belna the Cook — 28\n\nTUX OF THE GLADE — *blank*"

[node name="Npc2_Scorekeeper_Innis" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0, 0.5)
npc_name = "Scorekeeper Innis"
body_color = Color(0.62, 0.5, 0.55, 1)
hat_color = Color(0.95, 0.85, 0.4, 1)
idle_hint = "[E] Speak with the scorekeeper"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Scorekeeper Innis\", \"text\": \"*she has a stub of chalk and a smile.*\\n\\nWalker! Welcome to the Scoreroom. You play any of the games down at the Old Plays — you come back here, I write you on the wall.\\n\\nWin one, you go on the current list. Lose your record, you go on the former list. The wall keeps both.\", \"choices\": [{\"label\": \"Why both lists?\", \"next\": \"both\"}, {\"label\": \"Will you put me up?\", \"next\": \"me\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"both\": {\"speaker\": \"Scorekeeper Innis\", \"text\": \"Because a record beaten is still a record set. The realm doesn't forget who got there first.\\n\\nMost rooms only keep the new names. We keep all of them. By the Source, that's the kind of room I want to run.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"me\": {\"speaker\": \"Scorekeeper Innis\", \"text\": \"I will the moment you win one. I've already chalked your line — see? — Tux of the Glade, blank for now. The blank is a promise.\\n\\nGo win something.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Scorekeeper Innis\", \"text\": \"Walk well. Come back with a score.\"}}}"

