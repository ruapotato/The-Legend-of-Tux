[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, -1.185, 2)
message = "Lirien Music\n\n/home/lirien/Music"

[node name="Npc1_Bowl_Tender_Veen" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -1.252, 0)
npc_name = "Bowl-Tender Veen"
body_color = Color(0.78, 0.78, 0.92, 1)
hat_color = Color(0.55, 0.55, 0.78, 1)
idle_hint = "[E] Speak to Veen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Bowl-Tender Veen\", \"text\": \"Quietly, please. The bowl wants only one strike at a\\ntime, and only with the rim of one's nail.\", \"choices\": [{\"label\": \"May I try?\", \"next\": \"try\"}, {\"label\": \"Why so quiet?\", \"next\": \"quiet\"}, {\"label\": \"Walk well.\"}]}, \"try\": {\"speaker\": \"Bowl-Tender Veen\", \"text\": \"*Veen guides your hand. The bowl rings a clear note,\\nhigh and watery. The sound hangs in the air longer than\\nyou expect — then fades, and the room is louder for\\nhaving held it.*\", \"choices\": [{\"label\": \"Beautiful.\"}]}, \"quiet\": {\"speaker\": \"Bowl-Tender Veen\", \"text\": \"Because one struck bowl makes you listen for the next.\\nTwo struck bowls makes you stop listening.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

