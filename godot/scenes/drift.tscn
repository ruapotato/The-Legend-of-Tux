message = "BONFIRE PIT\n  Tend nightly.\n  Tend again in the morning."

[node name="Sign20" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -14, 0, -20)
message = "WAY NORTH —\n  Cold path, pale summit.\n  Walk slow."

