[node name="Npc1_Old_Woman" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, -0.564642, 0, 1, 0, 0.564642, 0, 0.825336, -22, 0.868, 20)
npc_name = "Old Woman"
body_color = Color(0.45, 0.35, 0.4, 1)
hat_color = Color(0.25, 0.2, 0.22, 1)
idle_hint = "[E] Speak with the old woman"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Old Woman\", \"text\": \"Oh. There you are. You took your time getting back. Sit, if you like — the bench remembers you better than I do.\", \"choices\": [{\"label\": \"Have we met?\", \"next\": \"met\"}, {\"label\": \"What are you reading?\", \"next\": \"book\"}, {\"label\": \"What is this place?\", \"next\": \"place\"}, {\"label\": \"I should go.\", \"next\": \"bye\", \"sets\": \"met_the_madam\"}]}, \"met\": {\"speaker\": \"Old Woman\", \"text\": \"Mm. Once. You were taller. Or shorter — it's hard to say with travellers. The light was different. You said something kind. I remember kind things.\", \"choices\": [{\"label\": \"What did I say?\", \"next\": \"said\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"said\": {\"speaker\": \"Old Woman\", \"text\": \"I won't repeat it. It was meant only the once. — You were on your way down from the Wake. Tea was brewed. The morning was very long.\", \"choices\": [{\"label\": \"I've never been to the Wake.\", \"next\": \"wake_dodge\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"wake_dodge\": {\"speaker\": \"Old Woman\", \"text\": \"Of course not. Of course not. Forgive an old woman her loose threads. — Have you tried the seeds? Pim's roasted them well this morning.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"book\": {\"speaker\": \"Old Woman\", \"text\": \"Names. Names of every person who has danced in this square. The list is shorter than you'd think. I have to start a fresh page each morning, but the names stay the same.\", \"choices\": [{\"label\": \"May I see?\", \"next\": \"book_no\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"book_no\": {\"speaker\": \"Old Woman\", \"text\": \"No. The page belongs to the morning. It would not know your hand. — Sit a little longer. The lanterns will turn warmer in a moment; it's almost the second song.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"place\": {\"speaker\": \"Old Woman\", \"text\": \"A festival town. They will tell you what is being celebrated, and they will be wrong, and that's all right. — I remember a festival here, when my brother brought down a beam from the Forge for the stage. It was last week. It was four hundred years ago.\", \"choices\": [{\"label\": \"Four hundred years?\", \"next\": \"four_hundred\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"four_hundred\": {\"speaker\": \"Old Woman\", \"text\": \"Mm. Don't dwell. The dancers are starting again. — There's a small glass on the table beside you, by the way. I won't be needing it. A traveller may.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Old Woman\", \"text\": \"Walk well. — Try the seeds before you go.\"}}}"

[node name="Npc2_Innkeeper_Brall" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 14, -0.063, 12)
npc_name = "Innkeeper Brall"
body_color = Color(0.55, 0.3, 0.25, 1)
hat_color = Color(0.85, 0.55, 0.25, 1)
idle_hint = "[E] Speak with Brall"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Innkeeper Brall\", \"text\": \"Welcome, welcome! New face! Or — hah! — newish. Doesn't matter! Today's the festival! Drinks half-price 'til the second drum!\", \"choices\": [{\"label\": \"What festival?\", \"next\": \"what\"}, {\"label\": \"Was there a festival yesterday?\", \"next\": \"yest\"}, {\"label\": \"I'll just look around.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"Innkeeper Brall\", \"text\": \"What festival! What festival, the man asks! — ah, well. We celebrated something. A founding, maybe. Or a returning. Doesn't matter — the music's good and the seeds are hot!\", \"choices\": [{\"label\": \"Was there a festival yesterday?\", \"next\": \"yest\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"yest\": {\"speaker\": \"Innkeeper Brall\", \"text\": \"Yesterday? Hah! Yesterday's a long word for a man behind a bar! We — we celebrated something. I'm sure we did. The banners aren't new. — Anyway! Try the dark ale, brewed this morning!\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Innkeeper Brall\", \"text\": \"Walk well, walk well! Don't miss the second drum!\"}}}"

[node name="Npc3_Reveller_Mira" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -4, 0.143, 4)
npc_name = "Reveller Mira"
body_color = Color(0.85, 0.4, 0.7, 1)
hat_color = Color(1, 0.85, 0.45, 1)
idle_hint = "[E] Greet Mira"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Reveller Mira\", \"text\": \"(spinning) Step in, step in! Don't think about your feet, the floor knows what to do! Whee — oh, hi! Hi! Bye!\"}}}"

[node name="Npc4_Reveller_Tas" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.737394, 0, -0.675463, 0, 1, 0, 0.675463, 0, -0.737394, 8, 0.6, -2)
npc_name = "Reveller Tas"
body_color = Color(0.4, 0.5, 0.75, 1)
hat_color = Color(0.9, 0.7, 0.4, 1)
idle_hint = "[E] Speak with Tas"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Reveller Tas\", \"text\": \"Y'know what's beautiful, friend? Tomorrow. Tomorrow we'll do this again. Same lanterns. Same drums. Same — same everything.\", \"choices\": [{\"label\": \"Same everything?\", \"next\": \"same\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"same\": {\"speaker\": \"Reveller Tas\", \"text\": \"Mm. Yeah. Same. Like — like the morning forgets and starts fresh, see? Fresh and the same. That's a kindness, that is. — Why am I crying? I'm not crying.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Reveller Tas\", \"text\": \"Hey — hey — see you tomorrow! Or, you know. Soon. In the next breath.\"}}}"

[node name="Npc5_Reveller_Ket" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3, -0.4, 10)
npc_name = "Reveller Ket"
body_color = Color(0.95, 0.75, 0.55, 1)
hat_color = Color(0.5, 0.3, 0.7, 1)
idle_hint = "[E] Speak with Ket"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Reveller Ket\", \"text\": \"Oh — oh, look at all of it! Hey, you — hey — do you live here? Can I stay? Do they let people stay? I think I want to stay.\", \"choices\": [{\"label\": \"Sure. Stay.\", \"next\": \"stay\"}, {\"label\": \"Maybe ask in the morning.\", \"next\": \"morning\"}]}, \"stay\": {\"speaker\": \"Reveller Ket\", \"text\": \"Hah! — hah! — thanks, friend! I'm gonna stay! I'm gonna remember this forever!\"}, \"morning\": {\"speaker\": \"Reveller Ket\", \"text\": \"Oh — right, right, in the morning. I'll ask in the morning. Good idea. — Where's the music, I want to be near the music.\"}}}"

[node name="Npc6_Old_Wim" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, -0.932039, 0, 1, 0, 0.932039, 0, 0.362358, -12, 0.51, -8)
npc_name = "Old Wim"
body_color = Color(0.4, 0.4, 0.42, 1)
hat_color = Color(0.55, 0.45, 0.32, 1)
idle_hint = "[E] Speak with Old Wim"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Old Wim\", \"text\": \"Mm. — Mind the broom, friend. This place needs sweeping every morning by someone. Same someone, mostly.\", \"choices\": [{\"label\": \"Why every morning?\", \"next\": \"why\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"why\": {\"speaker\": \"Old Wim\", \"text\": \"Festival leaves a lot. Petals. Cups. Names people drop and don't pick back up. — Someone has to. May as well be me.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Old Wim\", \"text\": \"Walk well. Mind the lanterns; the south one's tilting.\"}}}"

[node name="Npc7_Hawker_Pim" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 16, -0.024, -8)
npc_name = "Hawker Pim"
body_color = Color(0.6, 0.45, 0.3, 1)
hat_color = Color(0.85, 0.4, 0.25, 1)
idle_hint = "[E] Browse Pim's seeds"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Hawker Pim\", \"text\": \"Seeds! Hot seeds! Five for five pebbles, friend, that's the festival rate — oh, you look new. Free taste, then! Just one. Don't tell the next traveller.\", \"choices\": [{\"label\": \"Thanks!\", \"next\": \"taste\"}, {\"label\": \"Maybe later.\", \"next\": \"later\"}]}, \"taste\": {\"speaker\": \"Hawker Pim\", \"text\": \"There y'are. Salt, fire, and a little bit of the morning. Hah! — walk well, friend, walk well!\"}, \"later\": {\"speaker\": \"Hawker Pim\", \"text\": \"Suit yourself! They'll be hot again tomorrow. Always are.\"}}}"

[node name="Npc8_Costumer_Vela" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -18, 1.088, -2)
npc_name = "Costumer Vela"
body_color = Color(0.4, 0.3, 0.5, 1)
hat_color = Color(0.7, 0.6, 0.85, 1)
idle_hint = "[E] Speak with Vela"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Costumer Vela\", \"text\": \"Mask, traveller? I make them in the colours of the morning. They wear well — for a day.\", \"choices\": [{\"label\": \"Just for a day?\", \"next\": \"day\"}, {\"label\": \"Who taught you?\", \"next\": \"taught\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"day\": {\"speaker\": \"Costumer Vela\", \"text\": \"Mm. The dye runs by sunrise. Some of us don't notice. — Some of us notice and don't say.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"taught\": {\"speaker\": \"Costumer Vela\", \"text\": \"An old woman in the corner, with a small book. She doesn't make masks. She told me what colour the morning is. I do the rest.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Costumer Vela\", \"text\": \"Walk well. The blue one suits you.\"}}}"

[node name="Sign9" parent="." instance=ExtResource("sign")]
