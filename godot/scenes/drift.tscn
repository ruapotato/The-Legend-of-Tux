[node name="Npc101_Festival_goer" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 2, 0.348, 1)
npc_name = "Festival-goer"
body_color = Color(0.95, 0.4, 0.15, 1)
hat_color = Color(0.75, 0.25, 0.1, 1)
idle_hint = "[E] Speak with the festival-goer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Festival-goer\", \"text\": \"*she is wearing yesterday's wreath, already wilting*\\n\\nYesterday's release? Forgotten. Tomorrow's? Will be. Today is the festival, walker, and the festival is the only thing.\", \"choices\": [{\"label\": \"What was yesterday's?\", \"next\": \"yest\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"yest\": {\"speaker\": \"Festival-goer\", \"text\": \"*she thinks for a long second*\\n\\nI do not remember. That is the point.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Festival-goer\", \"text\": \"*she spins back into the crowd*\"}}}"

