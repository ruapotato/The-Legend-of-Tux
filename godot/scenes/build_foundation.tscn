[gd_scene load_steps=4 format=3 uid="uid://btuxbldf01"]

; Foundation piece for the survival build system. 2m x 2m floor square,
; 0.4m thick. Origin at the bottom-center so the snap point is at ground
; level — placement code sets global_position to the snap point and the
; mesh sits on top. Brown wood-grain StandardMaterial3D. StaticBody3D on
; layer 1 (World) so the player can walk on it and other physics queries
; treat it as solid terrain. The "build_piece" group lets future tools
; (axe deconstruction, save scrubber) iterate placements cheaply.

[sub_resource type="BoxMesh" id="found_mesh"]
size = Vector3(2, 0.4, 2)

[sub_resource type="BoxShape3D" id="found_shape"]
size = Vector3(2, 0.4, 2)

[sub_resource type="StandardMaterial3D" id="found_mat"]
albedo_color = Color(0.46, 0.31, 0.18, 1)
roughness = 0.85

[node name="BuildFoundation" type="StaticBody3D" groups=["build_piece"]]
collision_layer = 1
collision_mask = 0
metadata/piece_id = "foundation"
metadata/cost_wood = 2

[node name="Mesh" type="MeshInstance3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.2, 0)
