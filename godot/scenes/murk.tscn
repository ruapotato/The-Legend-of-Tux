[node name="Npc1_Pell" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, -0.564642, 0, 1, 0, 0.564642, 0, 0.825336, -8, 1.181, 6)
npc_name = "Pell"
body_color = Color(0.62, 0.72, 0.65, 1)
hat_color = Color(0.45, 0.52, 0.48, 1)
idle_hint = "[E] Speak with the wanderer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Pell\", \"text\": \"(half-turning) Mm. Mm. Was carrying it. Was almost done.\", \"choices\": [{\"label\": \"What were you doing?\", \"next\": \"task\"}, {\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"task\": {\"speaker\": \"Pell\", \"text\": \"Was bringing the lantern down. Down to the south gate. Was almost there. Mm.\", \"choices\": [{\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"done\": {\"speaker\": \"Pell\", \"text\": \"(does not look up) The morning is long. The morning is long.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Pell\", \"text\": \"(does not answer)\"}}}"

[node name="Npc2_Aelis" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, 0.932039, 0, 1, 0, -0.932039, 0, 0.362358, 5, 1.989, 2)
npc_name = "Aelis"
body_color = Color(0.62, 0.72, 0.65, 1)
hat_color = Color(0.45, 0.52, 0.48, 1)
idle_hint = "[E] Speak with the wanderer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Aelis\", \"text\": \"(half-turning) Mm. Mm. Was carrying it. Was almost done.\", \"choices\": [{\"label\": \"What were you doing?\", \"next\": \"task\"}, {\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"task\": {\"speaker\": \"Aelis\", \"text\": \"Was counting the reeds. Counted to a thousand. Was meant to count further. Mm.\", \"choices\": [{\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"done\": {\"speaker\": \"Aelis\", \"text\": \"(does not look up) The morning is long. The morning is long.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Aelis\", \"text\": \"(does not answer)\"}}}"

