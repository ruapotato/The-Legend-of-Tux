body_color = Color(0.62, 0.72, 0.65, 1)
hat_color = Color(0.45, 0.52, 0.48, 1)
idle_hint = "[E] Speak with the wanderer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Olwy\", \"text\": \"(half-turning) Mm. Mm. Was carrying it. Was almost done.\", \"choices\": [{\"label\": \"What were you doing?\", \"next\": \"task\"}, {\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"task\": {\"speaker\": \"Olwy\", \"text\": \"Was watching for the morning. Watched a long time. The morning is long. Mm.\", \"choices\": [{\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"done\": {\"speaker\": \"Olwy\", \"text\": \"(does not look up) The morning is long. The morning is long.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Olwy\", \"text\": \"(does not answer)\"}}}"

