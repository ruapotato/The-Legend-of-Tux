dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Pell\", \"text\": \"(half-turning) Mm. Mm. Was carrying it. Was almost done.\", \"choices\": [{\"label\": \"What were you doing?\", \"next\": \"task\"}, {\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"task\": {\"speaker\": \"Pell\", \"text\": \"Was bringing the lantern down. Down to the south gate. Was almost there. Mm.\", \"choices\": [{\"label\": \"Are you done?\", \"next\": \"done\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"done\": {\"speaker\": \"Pell\", \"text\": \"(does not look up) The morning is long. The morning is long.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Pell\", \"text\": \"(does not answer)\"}}}"

