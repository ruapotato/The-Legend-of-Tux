[node name="Npc1_Lirien_s_Apprentice" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.942, 0)
npc_name = "Lirien's Apprentice"
body_color = Color(0.65, 0.78, 0.95, 1)
hat_color = Color(0.45, 0.55, 0.78, 1)
idle_hint = "[E] Speak to the Apprentice"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Lirien's Apprentice\", \"text\": \"You came up here? Few do. Lirien is below, with the\\nSigilkeep. I keep the instruments clean.\", \"choices\": [{\"label\": \"What are these?\", \"next\": \"what\"}, {\"label\": \"Where did you come from?\", \"next\": \"where\"}, {\"label\": \"Walk well.\"}]}, \"what\": {\"speaker\": \"Lirien's Apprentice\", \"text\": \"Astrolabe — for the slow walkers. Quadrant — for the\\none that does not move. Ruler — it knows the realm\\nhas a curve to it.\", \"choices\": [{\"label\": \"A curved realm?\", \"next\": \"curve\"}]}, \"curve\": {\"speaker\": \"Lirien's Apprentice\", \"text\": \"A small one. Most cannot feel it. Some instruments can.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"where\": {\"speaker\": \"Lirien's Apprentice\", \"text\": \"Sigilkeep, originally. Wandered up. The air here is\\ndifferent — drier, older.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 0.273, -1)
message = "Astrolabe. Quadrant.\n\nA ruler that knows the realm's curve."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 1.858, -1)
message = "Everything set parallel, square, true. Even the dust\nseems to land in rows."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.72, 4)
message = "A clean desk under a slanted skylight. Brass instruments\nrest in their cradles, each catching its own slice of star."

