[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.29, 24)
message = "The Library of Past Echoes.\n\nKeep your voice low. The pages remember footfalls."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -18, 3.371, -14)
message = "Posted, in a careful hand:\n\n\"Silence is asked of every walker in the Stacks. The deepest reading is what looks back at you. Do not surprise it.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 18, 0.671, -14)
message = "An older notice, the ink running:\n\n\"Three Readers were lost to a long inscription in the year of the second thinning. Their names are kept in the west aisle. Speak them only when alone.\""

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -18, 3.385, 14)
message = "Roster of the Readers, freshly inked:\n\nMistress Yvenn (Head)\nApprentice Yawen\nPell (sabbatical)\nTheln (Wyrdmark records)\nOlm (the Drawing-In)\n— and one entry, scratched out long ago."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 18, 1.736, 14)
message = "A page-marker pinned to the shelf:\n\n\"What is forgotten was loved by something. The Library remembers on its behalf.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -8, 3.7, -22)
message = "An inscription carved into the lintel above the north stair:\n\n\"All who walk here walk in Lirien's breath. Walk softly. The breath is thin in the next room.\""

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 8, 3.086, -22)
message = "A folded notice, weighted with a stone:\n\n\"Climbing of ladders by visitors is permitted. Climbing of shelves is not. The shelves were not built to be climbed and they remember.\""

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -22, 3.1, 0)
message = "A small wood plaque:\n\n\"In memory of the year of the long quiet, when no Reader spoke for a season, that the pages might be heard.\""

[node name="Sign8" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 22, 0.408, 0)
message = "A reader's marginalia, framed and posted:\n\n\"The deepest reading is what looks back at you. I have read this line three times this week and it has read me twice. — Olm\""

[node name="Sign9" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 3.394, -8)
message = "A note tied to a lamp-post with a faded cord:\n\n\"To whomever oils these lamps: the third from the south flickers when something old is being read aloud. Please do not adjust it. It is doing its work.\""

