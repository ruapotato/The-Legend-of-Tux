[node name="Npc32_Apprentice_Ted" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 10, 1.665, 8)
npc_name = "Apprentice Ted"
body_color = Color(0.5, 0.55, 0.7, 1)
hat_color = Color(0.22, 0.25, 0.35, 1)
idle_hint = "[E] Speak with Ted"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Apprentice Ted\", \"text\": \"Oh — oh, hello. Hello! I'm — I'm cataloguing. I'm meant to be cataloguing. Mistress Yvenn said one shelf a day and I've done — *(he glances at the shelf)* — about half a shelf. In two days. Please don't tell her.\", \"choices\": [{\"label\": \"(Offer the folded scroll.)\", \"next\": \"trade\", \"requires_flag\": \"trade_step_3\", \"requires_not\": \"trade_step_4\"}, {\"label\": \"(Show the dyed ribbon.)\", \"next\": \"already\", \"requires_flag\": \"trade_step_4\"}, {\"label\": \"Why so slow?\", \"next\": \"slow\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"trade\": {\"speaker\": \"Apprentice Ted\", \"text\": \"*he reaches for the scroll, then stops himself, then reaches again.*\\n\\nMay I — may I see — oh. OH. This is — the hand is — this is from the Reader-on-Sabbatical's circuit, I'd swear it. Look, look, the way the loops carry through. This is a FIND, walker, this is a — a real one.\\n\\n*he scrambles in a drawer, pulls out a length of pale-dyed ribbon, presses it into your hand with both of his.*\\n\\nTake this. Please. It's not — it's only a ribbon, but it's a good one, the dye's true, my sister made it before — before. Take it. Walk it somewhere. The scroll stays here where it belongs and I'll — I'll catalogue it FIRST, I promise, before the shelf, even.\", \"sets_flag\": \"trade_step_4\", \"next\": \"thanks\"}, \"thanks\": {\"speaker\": \"Apprentice Ted\", \"text\": \"*he is already unrolling the scroll on the desk, very carefully, with both hands.*\\n\\nWalk well, walker. Walk well. Oh, this is a GOOD day.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"already\": {\"speaker\": \"Apprentice Ted\", \"text\": \"Still carrying the ribbon? Good. Good! It wants — it wants to be given properly. You'll know who. I think you'll know.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"slow\": {\"speaker\": \"Apprentice Ted\", \"text\": \"Every book makes me read three more. I open a thing meant for the catalogue and the catalogue waits and the THING — the thing pulls me in. The Mistress says that's the trade. The Mistress says nobody good at this is fast.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Apprentice Ted\", \"text\": \"Walk well! Mind the — the third ladder, Yawen says it wobbles. I haven't tried it yet.\"}}}"

