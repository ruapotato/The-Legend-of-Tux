[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.182, 12)
message = "The Cache.\n\nWhat the Library above could not bear to throw away. The dust is older than the catalog."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -12, 0.61, -10)
message = "A catalog card pinned crookedly to the shelf:\n\n\"Aisle three, shelves one through four — contents recovered after the second thinning. Twenty-two volumes. Fourteen partial. Six titled.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 12, -0.148, -10)
message = "A weathered notice pasted to a beam:\n\n\"THIS SHELF: empty since the Drawing-In began. Do not refill. Do not dust. The empty place is itself the record.\""

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -12, 0.217, 8)
message = "A folded courtesy:\n\n\"Visitors are kindly asked not to disturb the dust. The dust is filed.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 12, 0.049, 8)
message = "A small wooden tag:\n\n\"In memory of the volumes that thinned in the year of the long quiet. Their pages went elsewhere. We do not know where.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.309, -10)
message = "A loose page, slipped under glass:\n\n\"...and the lamp at the end of the aisle, when it flickered, named us each in turn — and we who heard it have never named ourselves the same way since.\""

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -6, 0.076, 4)
message = "A faded label hanging from a hook with no shelf beneath it:\n\n\"This shelf has been gone longer than I have been a curator. — Meld\""

