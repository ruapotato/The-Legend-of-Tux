[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 0, -1.5)
message = "LIRIEN'S CHAMBER\n\nA hooded blue-curtained study high in a stone tower. Books on stars. A telescope angled at the south sky. The fire is laid but not lit.\n\nNo one here."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0, 1.5)
message = "A journal lies open on the desk. The hand is small and steady:\n\n'The boy is walking. He doesn't yet know which walk it is. The Sigil sits quiet in him — quieter than I have ever seen it sit in any of his line.\n\nHe will not need me until he needs me. Then he will need me very much.\n\n— L.'"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0, 1.5)
message = "A telescope, dust-free, angled south. Beside it a slip of paper:\n\n'I have watched the Murk for forty seasons. The pulses there have never once skipped. The realm endures.'"

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0, 2.5)
message = "A row of books. The spines: 'Stars by Their Quiet Names', 'On the Slow Returning of Things Once Hoarded', 'A Walker's Manual for Small Mountains', 'The Triglyph and Its Patient Keeping'.\n\nNone of the books are dusty."

