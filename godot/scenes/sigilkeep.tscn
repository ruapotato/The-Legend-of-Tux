[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -1.05, 14)
message = "The Sigilkeep.\n\nThe great door is sealed. A line of wardstones glows across the threshold, dim. Khorgaul's hoard pulses behind them."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 3.257, -16)
message = "Carved into the wardstone:\n\n\"This door opens for one who has shared three Sigils. Bring proof of giving.\"\n\nThe wards do not stir."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -6, 0.076, 0)
message = "A wardstone in the wall, fingers-of-the-Source carved deep:\n\n\"What is sealed here is not the Hoarder, but the shape of his hunger. The Sigilkeep waits for one who has learned not to want.\""

