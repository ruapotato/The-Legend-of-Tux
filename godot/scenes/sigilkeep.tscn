[node name="Npc10_Inkwell_Stone" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -8, -0.005, 4)
npc_name = "Inkwell Stone"
body_color = Color(0.32, 0.28, 0.4, 1)
hat_color = Color(0.45, 0.5, 0.4, 1)
idle_hint = "[E] Touch the stone"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Inkwell Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires_flag\": \"codex_knight_defeated\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"codex_knight_defeated\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Inkwell Stone\", \"text\": \"Quill-spirits guard the Bow Hall. Strike the inkpot. The knight will follow.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Inkwell Stone\", \"text\": \"The Codex sleeps. Its pages no longer turn against you.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Inkwell Stone\", \"text\": \"*The hum fades.*\"}}}"

