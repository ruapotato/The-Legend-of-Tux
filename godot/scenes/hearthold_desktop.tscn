dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Quick-Launch Apprentice\", \"text\": \"Oh, hello! You look like you came in from outside.\\nNeed a quick jump anywhere? I keep the shortcuts.\", \"choices\": [{\"label\": \"Where do the shopkeepers live?\", \"next\": \"shops\"}, {\"label\": \"Where do I drop things off?\", \"next\": \"drops\"}, {\"label\": \"Just looking.\"}]}, \"shops\": {\"speaker\": \"Quick-Launch Apprentice\", \"text\": \"Binds, in the Sprawl. That's `/usr/bin` — every named\\ntool-spirit you'll ever want stocks a stall there. Apt,\\nPacman, Tar. They sell `+x` bits.\", \"choices\": [{\"label\": \"Thanks.\"}]}, \"drops\": {\"speaker\": \"Quick-Launch Apprentice\", \"text\": \"Downloads, next door. Tem is in charge. She has not yet\\nlooked at any of it.\", \"choices\": [{\"label\": \"Got it.\"}]}}}"

[node name="Npc1_Reminder_Sticky_Note" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 1.614, -1)
npc_name = "Reminder Sticky-Note"
body_color = Color(0.95, 0.92, 0.55, 1)
hat_color = Color(1, 0.85, 0.45, 1)
idle_hint = "[E] Read the sticky-note"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Reminder Sticky-Note\", \"text\": \"PICK UP MILK. PICK UP MILK. PICK UP MILK.\\n...oh. Hello.\", \"choices\": [{\"label\": \"What are you doing?\", \"next\": \"job\"}, {\"label\": \"Walk well.\"}]}, \"job\": {\"speaker\": \"Reminder Sticky-Note\", \"text\": \"I am the day's reminder. One line, repeated until it is\\neither done or forgotten. Today's line: pick up milk.\", \"choices\": [{\"label\": \"Whose milk?\", \"next\": \"whose\"}]}, \"whose\": {\"speaker\": \"Reminder Sticky-Note\", \"text\": \"I have never asked. That is not in my job description.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.654, 4)
message = "Desktop —\n\nWhat's in front of you, not what's filed away."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -2, 0.847, 4)
message = "A long low table dominates the room.\n\nTools sit on it where someone put them down: a kettle, a\nledger, a half-folded letter, a key with no chain."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 4, 2.135, 3)
message = "Trash can sits in the corner, full.\n\nNobody empties it. Nobody asks who should."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -4, 1.062, 3)
message = "A glass of water, half-drunk.\n\nIt has been here since this morning. Perhaps yesterday morning."

