[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(0.707105, 0, -0.707108, 0, 1, 0, 0.707108, 0, 0.707105, -2, 0, -2)
message = "An old marker-stone, the lettering wind-worn:\n\n\"Mount Easter — last camp. We sat here until the wind agreed. Then we went home.\"\n\nBeneath, in newer scratch: \"+1 to all who reach.\""

