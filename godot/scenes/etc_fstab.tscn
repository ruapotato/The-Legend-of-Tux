[node name="Npc0_Mounter_Vest" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0, 0)
npc_name = "Mounter Vest"
body_color = Color(0.55, 0.62, 0.78, 1)
hat_color = Color(0.32, 0.42, 0.55, 1)
idle_hint = "[E] Speak with the Mounter"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Mounter Vest\", \"text\": \"I keep the table of attachments. Every path to every place\\nthat hangs off the trunk of the realm.\", \"choices\": [{\"label\": \"What's `auto`?\", \"next\": \"auto\"}, {\"label\": \"What's `noatime`?\", \"next\": \"noatime\"}, {\"label\": \"Walk well.\"}]}, \"auto\": {\"speaker\": \"Mounter Vest\", \"text\": \"It means the place attaches itself when the realm wakes.\\nYou don't have to ask. You don't have to remember.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"noatime\": {\"speaker\": \"Mounter Vest\", \"text\": \"It means the place doesn't write down when you last\\nvisited. Some things are gentler that way.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

