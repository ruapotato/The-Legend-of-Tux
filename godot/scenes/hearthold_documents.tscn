[node name="Npc1_Scriverer_Den" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.76, 0)
npc_name = "Scriverer Den"
body_color = Color(0.78, 0.65, 0.45, 1)
hat_color = Color(0.55, 0.36, 0.22, 1)
idle_hint = "[E] Speak to Scriverer Den"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Scriverer Den\", \"text\": \"Aye, come in, come in. Wipe your boots — these scrolls\\nare older than the village wall.\", \"choices\": [{\"label\": \"What do you keep here?\", \"next\": \"what\"}, {\"label\": \"Anything for me to read?\", \"next\": \"read\"}, {\"label\": \"Walk well.\"}]}, \"what\": {\"speaker\": \"Scriverer Den\", \"text\": \"Household ledgers, mostly. Who owes whom a sack of\\nbarley, who borrowed the long ladder, whose hen is\\nactually whose. Boring, important work.\", \"choices\": [{\"label\": \"Boring?\", \"next\": \"boring\"}, {\"label\": \"Walk well.\"}]}, \"boring\": {\"speaker\": \"Scriverer Den\", \"text\": \"Boring is good. Boring means no one is fighting over it.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"read\": {\"speaker\": \"Scriverer Den\", \"text\": \"There's a child's drawing pinned above the desk. A\\nsmall tux figure with a sword too big for him. Whose\\nchild? I won't say.\", \"choices\": [{\"label\": \"Mine, perhaps.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 0, -1)
message = "Records —\n\nhousehold ledgers, recipe books, a child's drawing."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, -0.143, -1)
message = "The kin keep what they will need to find."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0, 4)
message = "A long writing-table, four chairs, and the smell of\npine-ink. Quiet here even in the busy season."

