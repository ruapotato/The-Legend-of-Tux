[node name="Npc0_Scribe_Onel" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -1.119, 0)
npc_name = "Scribe Onel"
body_color = Color(0.85, 0.82, 0.78, 1)
hat_color = Color(0.55, 0.5, 0.45, 1)
idle_hint = "[E] Ask the scribe"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Scribe Onel\", \"text\": \"I am Onel of the scribe family. I keep the table of names.\\nEvery name that means a place. Every place that has a name.\", \"choices\": [{\"label\": \"How does it work?\", \"next\": \"how\"}, {\"label\": \"Who is `the_oldest_one`?\", \"next\": \"old\"}, {\"label\": \"Walk well.\"}]}, \"how\": {\"speaker\": \"Scribe Onel\", \"text\": \"A name on the left. Four glyphs on the right. The glyphs\\npoint at a place. The place answers when you call the name.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"old\": {\"speaker\": \"Scribe Onel\", \"text\": \"I do not know. I only copy what was given me. The address\\nis `10.0.0.42`. The name has been on the tablet since before\\nmy grandfather sat at this desk.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.823, -3)
message = "A stone tablet, the wall it leans against:\n\n127.0.0.1  localhost\n::1        localhost\n192.168.1.1  router\n10.0.0.42  the_oldest_one"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, -1.357, 2)
message = "Names mapped to places.\n\nThe scribes say this is the only wall in the realm where\neverything is true at once."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 0.063, 2)
message = "A second smaller tablet, half-finished:\n\n0.0.0.0  nowhere\n255.255.255.255  everywhere\n                                  — someone's joke?"

