[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 12, 2.303, -8)
message = "An inscription cut deep into the wall:\n\n\"Here is kept what the Wyrdmark agreed to remember. Forgetting these things would thin the Source itself.\""

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -12, -0.291, 8)
message = "A stone plaque, polished by centuries of touching:\n\n\"The names of the first walkers — Vael, Anth, and the third whose name is no longer spoken.\""

[node name="Sign8" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 6, 2.15, -12)
message = "A small wood plaque set into the floor:\n\n\"Master Archivist Tannen, who kept these stacks for sixty years and never raised her voice. Walk well.\""

[node name="Sign9" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -6, 1.479, -12)
message = "A folded cloth notice, weighted with a stone:\n\n\"Reading aloud is permitted in the Stacks if you are alone. If you are not alone, ask first. Most readings are gentle. Some are not.\""

[node name="Sign10" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.343, 6)
message = "A page set under glass:\n\n\"Lirien's eye is on the page when the page is opened. The reader is, briefly, also read.\""

