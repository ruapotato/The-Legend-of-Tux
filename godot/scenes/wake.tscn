[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0, 0, 12)
message = "The Wake.\n\nCarved into the cliffs where the sun first touches the realm. The boot-soldiers keep the morning."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -14.5, 0.6, -8)
message = "An inscription cut into the rock:\n\n\"At the first pale, we stand. At the first breath, we sing. At the first light, the realm wakes — and we have not slept.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 3, 0, 10)
message = "ORDER OF THE MORNING\n\n1. The captain reads the names.\n2. The bell sounds three times.\n3. The sun is greeted at the eastern step.\n4. The veterans are saluted.\n5. The day is given to Lirien.\n\n— By the hand of Captain Iren."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -5, 0, -2)
message = "MEMORIAL SLAB\n\nThey kept the morning so we could live the day.\n\n  Hesper of the long watch.\n  Olber, who sang the third bell.\n  Wenna, blade and breath.\n  Vaella, who knew every name.\n  Tova, last of the East-keep.\n\nWalk well."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 14.5, 0.6, 4)
message = "Carved deep into the cliff:\n\n\"These stones were old before the Wyrdmark had a name. They will be old when the name is forgotten. Stand among them, and stand straight.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 10, 0, -2)
message = "NOTICE\n\nNew recruits report to Captain Iren at the eastern step before second bell. Bring nothing but breath. The Wake provides the rest."

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3, 0, -10)
message = "A small stone, set apart:\n\n\"For the morning that almost did not come. — H.\""

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 8, 0, 3)
message = "Boot-soldier inscription:\n\n\"What we do, no one sees. If we do it well, no one ever will. By the Source, this is enough.\""

