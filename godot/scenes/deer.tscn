; Sword hits land here. layer=32 matches Tux's SwordHitbox.collision_mask;
; the area has no take_damage of its own — sword_hitbox falls through to
; get_parent() and calls take_damage on the CharacterBody3D root.
[node name="Hitbox" type="Area3D" parent="."]
collision_layer = 32
collision_mask = 0
monitorable = true
monitoring = false

