[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, -0.6, -1.5)
message = "THE NAMES HALL\n\nEvery name in the realm, carved into the long stone wall. Each one was once a stranger. Strangers are how the realm grows."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, -0.351, 2.5)
message = "THE WALL — west run\n\n  Belna of the Servery\n  Esweth, weaver of the Loomhouse\n  Marn the Toolwright\n  Pell, Marn's apprentice\n  Velis, Heart-Reader\n  Adra of the Hall of Lost Things\n  Maren of Sigilkeep\n  Pyl, acolyte\n\n...and many more, and many before them, and many to come."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, -0.523, 2.5)
message = "THE WALL — east run\n\n  Annette, who once paid for tea and left the change\n  Esh of nowhere-given, the long-necked listener\n  the Reader from a Library no Wyrdkin can name\n  the grey-cloaked walker, never seen turning\n  the Colonel of the bright watch (the priests would say: Lirien)\n\nThese names the Scribe writes in a finer hand. They have walked the realm and never asked to be marked, but the wall asked anyway."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, -0.359, 2.5)
message = "Tacked to a small ledger:\n\n'Tux of the Wyrdkin Glade, son of the line that thinned, bearer of a mark not yet announced.'\n\n*the ink is still wet.*"

[node name="Npc4_Scribe_Onel" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, -0.443, 0.5)
npc_name = "Scribe Onel"
body_color = Color(0.55, 0.5, 0.62, 1)
hat_color = Color(0.78, 0.7, 0.55, 1)
idle_hint = "[E] Speak with the scribe"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Scribe Onel\", \"text\": \"*she does not look up from the stylus. The iron makes a small, careful scrape against stone.*\\n\\nWalker. Welcome to the Hall.\\n\\nNew name? Or just looking?\", \"choices\": [{\"label\": \"Just looking.\", \"next\": \"look\"}, {\"label\": \"What's the finer-hand list?\", \"next\": \"fine\"}, {\"label\": \"Will you write my name?\", \"next\": \"name\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"look\": {\"speaker\": \"Scribe Onel\", \"text\": \"Look as long as you like. Every name on this wall was once a stranger to the realm. Now they're all of them part of it.\\n\\nThat's how a realm grows.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"fine\": {\"speaker\": \"Scribe Onel\", \"text\": \"*she pauses, then quietly:*\\n\\nThe finer hand is for walkers who passed through but never stopped to be recorded. The wall remembers them anyway. The wall is patient.\\n\\nSome of those names I do not understand. The Scriptorium tells me to write them anyway. I write them anyway.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"name\": {\"speaker\": \"Scribe Onel\", \"text\": \"*she looks at you, properly, for the first time.*\\n\\n...I already wrote yours. The wall asked me to. The wall does sometimes.\\n\\nI did not understand the line about your mark. I wrote it anyway.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Scribe Onel\", \"text\": \"Walk well, walker. The wall keeps.\"}}}"

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -2.5, -0.594, -0.5)
message = "Cast in bronze, twelve names long:\n\n    root:x:0:0:root:/root:/bin/bash\n    daemon:x:1:1:daemon:/sbin:/usr/sbin/nologin\n    nobody:x:65534:65534:nobody:/nonexistent:/usr/sbin/nologin\n    tux:x:1000:1000:Hero:/home/wyrdkin:/bin/bash"

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 2.5, -0.74, -0.5)
message = "Whispered on the back wall:\n\n    ::1 is just as much localhost as 127.0.0.1.\n\nWe do not talk about this."

