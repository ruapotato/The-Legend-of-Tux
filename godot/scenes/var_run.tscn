[node name="default" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 0.05, -0.5)

[node name="from_library" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 0.132, -1.5)

[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, -0.064, 2.5)
message = "THE PULSE ROOM\n\nA chamber of beating drums — one for every walker, every keeper, every shaped daemon currently alive in the realm. A drum stops if its keeper falls.\n\nThe drumkeeper listens. He has been listening for a long time."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0.084, -1.5)
message = "DRUM: WYRDKING BONELORD\n\nA deep slow drum, low and hollow. Beats once every long breath. The hide is bone-white."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0.11, -0.5)
message = "DRUM: WYRD TOMATO\n\nA quick light drum, the rhythm slightly off-kilter, as if it can't decide which beat is the strong one. Painted leaf-green."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0.282, 1.5)
message = "DRUM: THE CODEX KNIGHT\n\nA steady drum with three beats, then a pause. Hide painted with the marks of an older Sigilkeep. The keeper has not yet been faced."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, 1, 0, 1, 0, -1, 0, 6.12323e-17, 2.5, -0.283, -1.5)
message = "DRUM: THE MIRELAKE THING\n\nA wet, slow drum. The drumhead is leather treated with something dark. Beats on a long count."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, 1, 0, 1, 0, -1, 0, 6.12323e-17, 2.5, -0.299, -0.5)
message = "DRUM: THE BURNT SHEPHERD\n\nA cracked, bright drum. The fire-marks on it are old. Beats fast, then long pauses."

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, 1, 0, 1, 0, -1, 0, 6.12323e-17, 2.5, -0.103, 1.5)
message = "DRUM: KHORGAUL\n\nThe largest drum in the room. The beat is so slow you can stand and listen and not hear it twice.\n\nIt is still beating."

[node name="Npc7_Drumkeeper_Hesh" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, -0.307, 0.5)
npc_name = "Drumkeeper Hesh"
body_color = Color(0.55, 0.45, 0.4, 1)
hat_color = Color(0.78, 0.65, 0.45, 1)
idle_hint = "[E] Speak with the drumkeeper"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Drumkeeper Hesh\", \"text\": \"*he is sitting cross-legged in the centre, eyes closed, listening. The drums beat around him in a slow round.*\\n\\nQuiet, walker. The room is counting.\\n\\n...all of them are still going. The realm endures.\", \"choices\": [{\"label\": \"What happens when one stops?\", \"next\": \"stop\"}, {\"label\": \"Whose drum is the largest?\", \"next\": \"large\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"stop\": {\"speaker\": \"Drumkeeper Hesh\", \"text\": \"Then the keeper has fallen. The realm hears the silence. The drum is taken down and the wall is left bare for a season, then a new drum is hung — for whoever rises in their place.\\n\\nA bare wall is not a sad thing here. It is a kept promise.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"large\": {\"speaker\": \"Drumkeeper Hesh\", \"text\": \"*his voice goes very quiet.*\\n\\nKhorgaul's. The slow one. Some days I forget it is there, because the beats are so far apart. Some days I remember and have to sit down for a while.\\n\\nHe is still going, walker. That is information. Take it as you will.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Drumkeeper Hesh\", \"text\": \"Walk well. The drums will tell me when you've done something.\"}}}"

[node name="Sign8" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0.5, -0.368, -1.5)
message = "Mounted on the Pulse Room wall:\n\n    * * * * * /usr/bin/pulse\n\nIt has run every minute since the beginning. It will run every minute until the end. It does not know what it is for. We do not ask."

