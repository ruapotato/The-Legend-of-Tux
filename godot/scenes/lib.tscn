[node name="from_crown" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 1.334, -1.5)

[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 1.351, 1.5)
message = "THE LOOMHOUSE\n\nThe shared looms run themselves. A thread you start at one bench is finished at another. Borrow what you need, leave what you can.\n\n'A loom kept private is a loom that forgets its purpose.'"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 1.089, 2.5)
message = "THE GREAT TAPESTRY\n\nWoven across the back wall — every room of the realm in shared thread. The Crown above. The Burrows in the warm middle. The Forge at the bottom in deep iron-greys.\n\nIf you look at any one room long enough you can see the threads that run between it and every other room. Nothing is alone."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 0.869, -1.5)
message = "A small notice pinned to a loom-frame:\n\n'A thread returned is a thread shared. The Loomhouse keeps no debts. Walk well.'"

[node name="Npc3_Master_Weaver_Esweth" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, -0.564642, 0, 1, 0, 0.564642, 0, 0.825336, -1.5, 1.095, 0.5)
npc_name = "Master Weaver Esweth"
body_color = Color(0.55, 0.45, 0.6, 1)
hat_color = Color(0.78, 0.65, 0.45, 1)
idle_hint = "[E] Speak with the weaver"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Master Weaver Esweth\", \"text\": \"*she does not look up from the shuttle.*\\n\\nWalk softly. The threads pick up footfall.\\n\\nWhat brings a sword-bearer to a loomhouse?\", \"choices\": [{\"label\": \"What is woven here?\", \"next\": \"weave\"}, {\"label\": \"May I look at the great tapestry?\", \"next\": \"tap\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"weave\": {\"speaker\": \"Master Weaver Esweth\", \"text\": \"Whatever the realm needs that day. Cloth. Cordage. Sometimes a song the loom remembered.\\n\\nThe looms are shared. Every weaver here borrows from every other. By the Source, that is how a Loomhouse stays a Loomhouse.\", \"choices\": [{\"label\": \"And if a weaver hoards?\", \"next\": \"hoard\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"hoard\": {\"speaker\": \"Master Weaver Esweth\", \"text\": \"*the shuttle slows.*\\n\\nThen the loom forgets her. The thread will not run. The cloth comes off uneven.\\n\\nA loom is a polite thing. It asks only that you give back what you borrow. Most of us can manage that.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"tap\": {\"speaker\": \"Master Weaver Esweth\", \"text\": \"Look as long as you like. Every room you have ever stood in is on that wall. Some you have not stood in yet are also there.\\n\\nThe Loomhouse is patient.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Master Weaver Esweth\", \"text\": \"Walk well. Mind the threads on the floor.\"}}}"

[node name="Npc4_Borrower_Tem" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, 0.564642, 0, 1, 0, -0.564642, 0, 0.825336, 1.5, 0.894, 0.5)
npc_name = "Borrower Tem"
body_color = Color(0.7, 0.55, 0.4, 1)
hat_color = Color(0.45, 0.55, 0.4, 1)
idle_hint = "[E] Speak with the borrower"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Borrower Tem\", \"text\": \"Just returning a thread, walker. I borrowed a length of green for a cloak last winter — finished now, and the spool comes home.\\n\\nThat's all the Loomhouse asks.\", \"choices\": [{\"label\": \"And it's that simple?\", \"next\": \"simple\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"simple\": {\"speaker\": \"Borrower Tem\", \"text\": \"It's that simple. Take what you need. Give back what you borrowed. The loom keeps no other ledger.\\n\\nMy mother used to say it kept us a people.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Borrower Tem\", \"text\": \"Walk well, walker. Mind the threads.\"}}}"

