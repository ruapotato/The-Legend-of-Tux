[node name="Npc9_Hearthold_Elder" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 0.743, 4)
npc_name = "Hearthold Elder"
body_color = Color(0.55, 0.42, 0.3, 1)
hat_color = Color(0.3, 0.2, 0.12, 1)
idle_hint = "[E] Speak with the Elder"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Hearthold Elder\", \"text\": \"Well met, little wanderer. The kilns burn warm tonight, and the rooks still keep their watch. Ask, if you would.\", \"choices\": [{\"label\": \"Tell me about the Source.\", \"next\": \"source\"}, {\"label\": \"What of Khorgaul?\", \"next\": \"khorgaul\"}, {\"label\": \"What is the Sigil?\", \"next\": \"sigil\"}, {\"label\": \"I should be going.\", \"next\": \"bye\"}]}, \"source\": {\"speaker\": \"Hearthold Elder\", \"text\": \"The Source is the spring of all green things — the breath that Lirien gave the world before names were spoken. Glim is a fleck of it, you know. The whole forest is.\", \"choices\": [{\"label\": \"And the Sigil?\", \"next\": \"sigil\"}, {\"label\": \"And Khorgaul?\", \"next\": \"khorgaul\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"khorgaul\": {\"speaker\": \"Hearthold Elder\", \"text\": \"The Hoarder. He does not steal so much as he gathers — the light, the warmth, the names of things. The wardstones held him once. They thin now.\", \"choices\": [{\"label\": \"Tell me of the Source.\", \"next\": \"source\"}, {\"label\": \"And the Sigil?\", \"next\": \"sigil\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"sigil\": {\"speaker\": \"Hearthold Elder\", \"text\": \"The Triglyph — three marks, three vows. One for the root, one for the wing, one for the spark. When all three glow, the wards renew. We have lost two.\", \"choices\": [{\"label\": \"Tell me of the Source.\", \"next\": \"source\"}, {\"label\": \"And Khorgaul?\", \"next\": \"khorgaul\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Hearthold Elder\", \"text\": \"Walk under the wing of Lirien, friend.\"}}}"

[node name="Npc10_Takka_the_Smith" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 10, 0.214, 4)
npc_name = "Takka the Smith"
body_color = Color(0.4, 0.35, 0.45, 1)
hat_color = Color(0.55, 0.3, 0.15, 1)
idle_hint = "[E] Talk to Takka"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Takka the Smith\", \"text\": \"Eh? You look light in the pouch, traveler. Need any pebbles for the sling?\", \"choices\": [{\"label\": \"Yes — spare me a handful.\", \"next\": \"give\", \"requires_not\": \"took_takka_pebbles\"}, {\"label\": \"You already gave me some.\", \"next\": \"already_gave\", \"requires\": \"took_takka_pebbles\"}, {\"label\": \"No, I'm fine.\", \"next\": \"bye\"}]}, \"give\": {\"speaker\": \"Takka the Smith\", \"text\": \"Five pebbles. Good for one good throw and four bad ones. Don't tell the Pebbler.\", \"give_pebbles\": 5, \"next\": \"post_give\"}, \"post_give\": {\"speaker\": \"Takka the Smith\", \"text\": \"Mind the wardstones to the north. They sing when they're upset.\", \"choices\": [{\"label\": \"Thanks, Takka.\", \"next\": \"bye\", \"sets\": \"took_takka_pebbles\"}]}, \"already_gave\": {\"speaker\": \"Takka the Smith\", \"text\": \"Aye, and I'll not give again 'til the moon turns. Off with you, sling-arm.\"}, \"bye\": {\"speaker\": \"Takka the Smith\", \"text\": \"Hammer and hearth keep you.\"}}}"

[node name="Npc11_Smith_Brann" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 12, 0.039, 4)
npc_name = "Smith Brann"
body_color = Color(0.32, 0.3, 0.36, 1)
hat_color = Color(0.62, 0.66, 0.72, 1)
idle_hint = "[E] Talk to Smith Brann"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Smith Brann\", \"text\": \"I can shape you a brighter blade. 30 pebbles.\", \"choices\": [{\"label\": \"Buy the Brightsteel. (30 pebbles)\", \"next\": \"bought\", \"upgrades_sword\": 1, \"costs_pebbles\": 30, \"fails_to\": \"broke\", \"sets\": \"brann_brightsteel_bought\", \"requires_not\": \"brann_brightsteel_bought\"}, {\"label\": \"About your blade.\", \"next\": \"already\", \"requires\": \"brann_brightsteel_bought\"}, {\"label\": \"Maybe later.\", \"next\": \"bye\"}]}, \"bought\": {\"speaker\": \"Smith Brann\", \"text\": \"Hold it firm and let it sing. Brightsteel keeps an edge — mind it.\"}, \"already\": {\"speaker\": \"Smith Brann\", \"text\": \"Your blade is already brighter than mine. Carry it well.\"}, \"broke\": {\"speaker\": \"Smith Brann\", \"text\": \"Pebbles first, blade after. Come back when your pouch is heavier.\"}, \"bye\": {\"speaker\": \"Smith Brann\", \"text\": \"Hammer and hearth keep you, friend.\"}}}"

[node name="Npc12_Pim" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.877583, 0, -0.479426, 0, 1, 0, 0.479426, 0, 0.877583, -3, 0.088, 8)
npc_name = "Pim"
body_color = Color(0.7, 0.8, 0.6, 1)
hat_color = Color(0.95, 0.65, 0.3, 1)
idle_hint = "[E] Talk to Pim"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Pim\", \"text\": \"Lambwisp! LAMBWISP! Did you see one? It went *floof* and then it went *poof*!\", \"next\": \"two\"}, \"two\": {\"speaker\": \"Pim\", \"text\": \"Mama says they're little pieces of Lirien's breath. I want to catch one and put it in a jar. Don't tell mama.\"}}}"

[node name="Npc13_Father_Velis" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.540302, 0, -0.841471, 0, 1, 0, 0.841471, 0, 0.540302, -7, 0.95, -6)
npc_name = "Father Velis"
body_color = Color(0.6, 0.4, 0.3, 1)
hat_color = Color(0.85, 0.55, 0.3, 1)
idle_hint = "[E] Speak with Father Velis"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Father Velis\", \"text\": \"Welcome to the Hearth-shrine, traveler. The kilns warm our bones; the Source warms our names. You bring questions. Speak them.\", \"choices\": [{\"label\": \"Tell me of the Source.\", \"next\": \"source\"}, {\"label\": \"Tell me of the Triglyph.\", \"next\": \"trig\"}, {\"label\": \"Tell me of Lirien.\", \"next\": \"lirien\"}, {\"label\": \"Tell me of Khorgaul.\", \"next\": \"khor\"}, {\"label\": \"What is this shrine for?\", \"next\": \"shrine\"}, {\"label\": \"Bless me, then.\", \"next\": \"bless\"}]}, \"source\": {\"speaker\": \"Father Velis\", \"text\": \"The Source flows through every green thing — through fire as it leaps, through water as it falls, through the breath of any kin who tells the truth. To break it is the easiest thing. To mend it asks a life.\", \"choices\": [{\"label\": \"Tell me of the Triglyph.\", \"next\": \"trig\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"trig\": {\"speaker\": \"Father Velis\", \"text\": \"Three sigils, three vows. Sight — to see truly. Shaping — to make and unmake. Sharing — to refuse the hoard. The first two were claimed in elder days. The third was given to a small one. Perhaps to you.\", \"choices\": [{\"label\": \"Tell me of Lirien.\", \"next\": \"lirien\"}, {\"label\": \"Tell me of Khorgaul.\", \"next\": \"khor\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"lirien\": {\"speaker\": \"Father Velis\", \"text\": \"Lirien the Maker, the Wing, the Greenhand. We say she is everywhere a leaf unfurls and nowhere we may name. Her gift is the giving — the freedom of the green to grow and grow again.\", \"choices\": [{\"label\": \"Tell me of Khorgaul.\", \"next\": \"khor\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"khor\": {\"speaker\": \"Father Velis\", \"text\": \"Khorgaul the Hoarder, the Cold-hand, the Without-Sharing. He is what the Source becomes when nothing is given. We do not curse him at the shrine. We pity him. And we hold the wards.\", \"choices\": [{\"label\": \"Tell me of Lirien.\", \"next\": \"lirien\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"shrine\": {\"speaker\": \"Father Velis\", \"text\": \"The hearth-shrine warms two flames — one for the kiln, one for the kin. When both burn, Hearthold endures. Should one go cold, the other will not last the season.\", \"choices\": [{\"label\": \"Bless me, then.\", \"next\": \"bless\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"bless\": {\"speaker\": \"Father Velis\", \"text\": \"*marks your brow with ash*\\nGo with the wing of Lirien at your back. Go with the green underfoot. Go with the giving in your hand.\"}}}"

[node name="Npc14_Tilly" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.801144, 0, 0.598472, 0, 1, 0, -0.598472, 0, -0.801144, 6, 1.268, -2)
npc_name = "Tilly"
body_color = Color(0.75, 0.5, 0.4, 1)
hat_color = Color(0.9, 0.65, 0.3, 1)
idle_hint = "[E] Talk to Tilly"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Tilly\", \"text\": \"HYAA! I am the bravest knight in Hearthold and I have THREE swords and they are ALL invisible except this one which is a stick.\", \"next\": \"two\"}, \"two\": {\"speaker\": \"Tilly\", \"text\": \"Wanna duel? *brandishes stick*\\nNo? Fine. I'll save the realm without you. Tell Father Velis if I don't come back by supper.\"}}}"

[node name="Chest15" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 0, 17)
contents_scene = ExtResource("heart_piece")
open_message = "Tucked in the kitchen-yard behind the Elder's house. The keepers leave heart-pulses where children can find them first."

[node name="Sign16" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -8, -0.33, 13)
message = "Worn cellar steps disappear under the kitchen-yard. The Elder's pickles, perhaps."

[node name="Npc17_Pellman_the_Baker" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -3, 1.804, 0)
npc_name = "Pellman the Baker"
body_color = Color(0.85, 0.78, 0.55, 1)
hat_color = Color(0.95, 0.92, 0.8, 1)
idle_hint = "[E] Talk to Pellman"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Pellman the Baker\", \"text\": \"Fresh from the oven, this morning's. Smell that? First batch. Honey-loaf and salt-rusks — a heart's worth in every bite, near enough.\", \"choices\": [{\"label\": \"What are you selling?\", \"next\": \"wares\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"wares\": {\"speaker\": \"Pellman the Baker\", \"text\": \"Loaves to mend you, a few seeds for your sling-pouch. Nothing fancy. Hearthold prices.\", \"choices\": [{\"label\": \"Show me.\", \"opens_shop\": [\"heart\", \"heart\", \"seed\"]}, {\"label\": \"Not today.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Pellman the Baker\", \"text\": \"Mind the kilns on your way out. Walk well.\"}}}"

[node name="Npc18_Old_Naya_the_Beekeeper" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7, -0.849, 14)
npc_name = "Old Naya the Beekeeper"
body_color = Color(0.62, 0.5, 0.32, 1)
hat_color = Color(0.85, 0.7, 0.3, 1)
idle_hint = "[E] Speak with Old Naya"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Old Naya\", \"text\": \"*she squints up from a row of clay jars, hands sticky with comb.*\\n\\nMind the bees, walker. They mind themselves, mostly. Mind them anyway.\", \"choices\": [{\"label\": \"Have you anything for a traveller?\", \"next\": \"offer\", \"requires_not\": \"trade_step_1\"}, {\"label\": \"(Show the honey jar.)\", \"next\": \"already\", \"requires_flag\": \"trade_step_1\"}, {\"label\": \"Tell me about the bees.\", \"next\": \"bees\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"offer\": {\"speaker\": \"Old Naya\", \"text\": \"*she wipes her hands and considers you a long moment.*\\n\\nHere. A jar of comb-honey, sealed in wax. It'll mean something to someone — gifts always do, when they're carried far enough.\\n\\nTake it. Pass it along when the moment finds you.\", \"sets_flag\": \"trade_step_1\", \"next\": \"bye\"}, \"already\": {\"speaker\": \"Old Naya\", \"text\": \"Mm. Still got it? Then you've not yet met the one who needs it. Keep walking. They'll know the jar when they see it.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bees\": {\"speaker\": \"Old Naya\", \"text\": \"Old as the kilns, this hive. Older. My grandmother kept her at this same stand. The bees remember the shape of a hand, you know — they remember mine. They'll learn yours, if you stay long enough.\\n\\nNobody stays long enough.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Old Naya\", \"text\": \"Walk well, walker. The Source is in the comb, same as it's in the leaf.\"}}}"

