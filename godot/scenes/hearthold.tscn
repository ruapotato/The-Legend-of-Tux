[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -12, 2.447, 4)
message = "A hand-painted shingle: \"Takka the Pebbler. Trades stone for stone. Will not haggle.\"\n\nThe shop is shuttered."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 12, 0.284, 4)
message = "A wax-sealed notice on the smithy door:\n\n\"By order of the keepers of the Hold: no sword may be carried past the inner gate. Edge magic flares badly near the sealed wards.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3, -1.192, 12)
message = "A wax-fresh proclamation:\n\n\"By the keepers of Hearthold: any traveler who has drawn breath in the Sourceplain shall be welcomed at the hearths within. Coin is not asked of the brave.\""

