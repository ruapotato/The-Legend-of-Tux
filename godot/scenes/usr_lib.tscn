[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0.909, 2.5)
message = "SPRAWL LIBRARY\n\nA quieter wing of the Sprawl, where the merchants share the tools and the secrets. Quieter than the market. Just as busy.\n\nThe threads here run all the way back to the Loomhouse on the Crown."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0.943, 2.5)
message = "Borrower's notice:\n\n'A thread borrowed here is a thread the Loomhouse will eventually want back. The Sprawl pays its debts in the next breath, or the breath after — but it pays them.'"

[node name="Npc2_Bind_Halor" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, -0.564642, 0, 1, 0, 0.564642, 0, 0.825336, -1.5, 0.724, 0.5)
npc_name = "Bind Halor"
body_color = Color(0.5, 0.42, 0.6, 1)
hat_color = Color(0.78, 0.6, 0.35, 1)
idle_hint = "[E] Speak with the Bind"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Bind Halor\", \"text\": \"*she's leaning on a workbench, passing a chisel handle-first to a Local who looks faintly suspicious about the whole transaction.*\\n\\nWalker. We share, here. The market's just up the way. The Library's just over my shoulder. The Sprawl runs on borrowing — and we keep good books.\", \"choices\": [{\"label\": \"What does the Local think?\", \"next\": \"loc\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"loc\": {\"speaker\": \"Bind Halor\", \"text\": \"She thinks I'm going to charge her for it. I'm not. I borrowed the chisel from the Loomhouse last spring; I'm not about to put a price on it.\\n\\nWhen the Sprawl forgets that, the Sprawl breaks down. By the Source, we know it.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Bind Halor\", \"text\": \"Walk well, walker. Borrow what you need. The library is open.\"}}}"

[node name="Npc3_Local_Vesh" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, 0.564642, 0, 1, 0, -0.564642, 0, 0.825336, 0.5, 0.775, 0.5)
npc_name = "Local Vesh"
body_color = Color(0.6, 0.5, 0.42, 1)
hat_color = Color(0.45, 0.55, 0.42, 1)
idle_hint = "[E] Speak with the Local"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Local Vesh\", \"text\": \"*she's holding the chisel like it might still ask her for pebbles.*\\n\\nMost Binds don't lend, walker. Halor's an exception. Most Binds want something for everything.\\n\\nThe Library — this Library, here — is the part of the Sprawl I trust.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Local Vesh\", \"text\": \"Walk well. And keep your pebbles in your pocket here.\"}}}"

