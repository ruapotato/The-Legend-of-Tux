[node name="Npc48_Nix" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0.5, 0.771, -1.5)
npc_name = "Nix"
body_color = Color(0.85, 0.85, 0.9, 1)
hat_color = Color(0.55, 0.7, 0.95, 1)
idle_hint = "[E] Speak with Nix"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Nix\", \"text\": \"*she does not blink when you arrive. she has been here long enough that arrival is uninteresting*\\n\\nI never change. When the realm needs me changed, it replaces me. The one before me was also called Nix. So will the one after.\", \"choices\": [{\"label\": \"Then who are you?\", \"next\": \"who\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"who\": {\"speaker\": \"Nix\", \"text\": \"Whichever Nix is current. The realm will know.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Nix\", \"text\": \"*she does not move*\"}}}"

[node name="Sign49" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 2.5, 0.805, -1.5)
message = "Pinned by a tangle of threads at the loomhouse:\n\n    yarn install\n\nWait twelve minutes.\nDo not interrupt.\nIt is doing what it has always done."

[node name="Sign50" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -2.5, 0.719, -1.5)
message = "Pinned over a workbench:\n\n    There are two hard things in this realm:\n        naming,\n        cache invalidation,\n        and off-by-one errors."

