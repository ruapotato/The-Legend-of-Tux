[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0, 2.5)
message = "THE SOURCEROOMS\n\nA vast hall of bound scrolls. Each scroll is the source-text for one shared loom in the Loomhouse. Half the scrolls are missing pages.\n\nWhat the realm was first told to be is written here. So is what it has become."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0, 2.5)
message = "Carved into a reading-desk:\n\n'The realm was written. The realm is being written. The realm will be written.\n\nWalker — if you find a missing page, return it to the shelf. The Sourcerooms keep no other tax.'"

[node name="Npc2_Indexer_Mor" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, -0.564642, 0, 1, 0, 0.564642, 0, 0.825336, -1.5, 0, 0.5)
npc_name = "Indexer Mor"
body_color = Color(0.5, 0.55, 0.62, 1)
hat_color = Color(0.78, 0.7, 0.55, 1)
idle_hint = "[E] Speak with the indexer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Indexer Mor\", \"text\": \"*he is up a ladder, sliding scrolls. He doesn't look down.*\\n\\nWalker — careful with the floor scrolls. They look like rugs. They are not rugs.\\n\\nWhat are you after?\", \"choices\": [{\"label\": \"What's in here?\", \"next\": \"what\"}, {\"label\": \"Have you seen anything unusual?\", \"next\": \"weird\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"Indexer Mor\", \"text\": \"Source-text. The first writings of the realm. Each scroll says what one thing in the Wyrdmark was supposed to be.\\n\\nA lot of them are wrong now. The realm is older than the writings. That's how it should be.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"weird\": {\"speaker\": \"Indexer Mor\", \"text\": \"*he pauses on the ladder.*\\n\\nThere's a scroll behind the back-shelf nobody pulls. The Indexer before me said it had a key in it. I never went looking — too tall, too tired, too busy.\\n\\nIf you're a walker who finishes things, walker — go find it. The realm might thank you.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Indexer Mor\", \"text\": \"Walk well. Mind the floor scrolls.\"}}}"

[node name="Npc3_Scribe_Tella" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, 0.564642, 0, 1, 0, -0.564642, 0, 0.825336, 1.5, 0, 0.5)
npc_name = "Scribe Tella"
body_color = Color(0.6, 0.5, 0.55, 1)
hat_color = Color(0.55, 0.42, 0.65, 1)
idle_hint = "[E] Speak with the scribe"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Scribe Tella\", \"text\": \"*she's copying a scroll by hand. Her ink is the colour of deep water.*\\n\\nMor sends me to find the missing pages. I find some of them. The rest the realm is keeping for a reason.\\n\\nWalk softly, walker. The shelves are listening.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Scribe Tella\", \"text\": \"Walk well. Walk softly.\"}}}"

[node name="Chest4" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0, 1.5)
contents_scene = ExtResource("key_pickup")
open_message = "A small dark key, tucked behind a back-shelf scroll nobody reads. The Indexer before Mor must have left it for the walker who would finish things. The realm thanks you."
contents_key_group = "final_dungeon"
requires_flag = "triglyph_assembled"

