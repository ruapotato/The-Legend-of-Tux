[node name="Npc1_Drev_the_Cultist" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.043, 0)
npc_name = "Drev the Cultist"
body_color = Color(0.55, 0.32, 0.28, 1)
hat_color = Color(0.32, 0.2, 0.18, 1)
idle_hint = "[E] Speak to Drev"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Drev the Cultist\", \"text\": \"He believed it, you understand. He wrote it on every\\npage he could find. The fire ate most of them.\", \"choices\": [{\"label\": \"Believed what?\", \"next\": \"what\"}, {\"label\": \"Who was he?\", \"next\": \"who\"}, {\"label\": \"Walk well.\"}]}, \"what\": {\"speaker\": \"Drev the Cultist\", \"text\": \"That he would be the one to keep what the realm\\ncouldn't lose. He called himself 'the Hoarder.' The\\nname is on the half-page.\", \"choices\": [{\"label\": \"And was he?\", \"next\": \"was\"}, {\"label\": \"Walk well.\"}]}, \"was\": {\"speaker\": \"Drev the Cultist\", \"text\": \"The realm lost him. So no.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"who\": {\"speaker\": \"Drev the Cultist\", \"text\": \"Khorgaul. Before he was the burned thing. Before the\\nHoarder ate the man.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign2" parent="." instance=ExtResource("sign")]
