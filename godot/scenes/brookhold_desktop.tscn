[node name="Npc1_Farmer_Tess" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 1.315, 0)
npc_name = "Farmer Tess"
body_color = Color(0.65, 0.55, 0.32, 1)
hat_color = Color(0.85, 0.72, 0.4, 1)
idle_hint = "[E] Speak to Farmer Tess"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Farmer Tess\", \"text\": \"Just out here doing the day's reading. Field-bench is\\nwarmer than the kitchen this time of year.\", \"choices\": [{\"label\": \"What are you reading?\", \"next\": \"what\"}, {\"label\": \"Day's reading?\", \"next\": \"day\"}, {\"label\": \"Walk well.\"}]}, \"what\": {\"speaker\": \"Farmer Tess\", \"text\": \"Same as ever. The sky, the wind, the way the wheat\\nleans. Books come later, when the light goes.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"day\": {\"speaker\": \"Farmer Tess\", \"text\": \"Every morning. You read the field before you work it.\\nIf you don't, you waste a whole day arguing with it.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

