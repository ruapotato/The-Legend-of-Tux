; Adapted from hamberg pig (without the wings — Tux pigs don't fly).
; Round stretched sphere torso, separate spherical head, cylindrical
; snout pointing forward, two prism-triangle ears, four stubby legs,
; and a torus curly tail. The pig's signature feature is the contrast
; between the rounded pink hide and the protruding cylindrical snout.
[sub_resource type="SphereMesh" id="torso_mesh"]
radius = 0.30
height = 0.55

