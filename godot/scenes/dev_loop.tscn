[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(6.12323e-17, 0, -1, 0, 1, 0, 1, 0, 6.12323e-17, -2.5, 0, -1)
message = "THE RECURSION HALL\n\nA corridor whose far door always brings you back to its near door, no matter how many times you walk through.\n\nUntil you walk it seven times. Then a third door appears.\n\nThe Wyrdkin who built this hall did not explain why."

