message = "NOTICE BOARD\n\n- Lirien blesses the Source; we tend its margins.\n- Dust the lantern oil weekly. Keep the wicks trimmed.\n- The west road runs to the plain. The Hoarder has not reached us.\n- Lambwisp count: short by three. If found, return to the paddocks."

[node name="Sign2" parent="." instance=ExtResource("sign")]
