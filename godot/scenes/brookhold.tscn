[node name="Npc48_Farmer_Brook" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3, 1.718, -10)
npc_name = "Farmer Brook"
body_color = Color(0.45, 0.55, 0.35, 1)
hat_color = Color(0.7, 0.55, 0.25, 1)
idle_hint = "[E] Speak to the Farmer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Farmer Brook\", \"text\": \"Bah! Three lambwisps gone in a fortnight. They drift off chasing their own glimmers and never come back. You wouldn't be one of those wandering sorts, would you?\", \"choices\": [{\"label\": \"Maybe I can help.\", \"next\": \"offer\", \"requires_not\": \"lambwisp_charm\"}, {\"label\": \"I have your charm in hand.\", \"next\": \"have_charm\", \"requires\": \"lambwisp_charm\"}, {\"label\": \"Sorry to hear it.\", \"next\": \"bye\"}]}, \"offer\": {\"speaker\": \"Farmer Brook\", \"text\": \"Take this — a lambwisp charm. They follow the chime of it. If you find one drifting, give it a shake and walk it home.\", \"give_item\": \"lambwisp_charm\", \"next\": \"post_offer\"}, \"post_offer\": {\"speaker\": \"Farmer Brook\", \"text\": \"Mind the brook stones near the south paddock. Slippery as a fish in butter.\", \"choices\": [{\"label\": \"I'll keep watch.\", \"next\": \"bye\"}]}, \"have_charm\": {\"speaker\": \"Farmer Brook\", \"text\": \"Aye, that's the one. Ring it true and the wisps will come. Bless the kin, traveler.\"}, \"bye\": {\"speaker\": \"Farmer Brook\", \"text\": \"Mind the lambwisps. Mind the kin.\"}}}"

[node name="Npc49_Matriarch_Brook" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, -30, 0.317, 6)
npc_name = "Matriarch Brook"
body_color = Color(0.4, 0.55, 0.35, 1)
hat_color = Color(0.55, 0.45, 0.25, 1)
idle_hint = "[E] Speak to the Matriarch"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Matriarch Brook\", \"text\": \"Well, well. A traveler at our gate. The kin keep the kettle warm — sit a moment, if you've news. Or even if you haven't.\", \"choices\": [{\"label\": \"I have a letter from Tova.\", \"next\": \"letter\", \"requires\": \"brookhold_letter\", \"requires_not\": \"delivered_brookhold_letter\"}, {\"label\": \"Tova's letter — already delivered.\", \"next\": \"after\", \"requires\": \"delivered_brookhold_letter\"}, {\"label\": \"Tell me of the holding.\", \"next\": \"holding\"}, {\"label\": \"Just stopping through.\", \"next\": \"bye\"}]}, \"letter\": {\"speaker\": \"Matriarch Brook\", \"text\": \"From Tova? Truly?! *unfolds it, reads silently — eyes wet*\\nYou good soul. You stubborn, lovely soul. She lives — she lives. Take this — eight pebbles for a sling-arm who carried what mattered.\", \"give_pebbles\": 8, \"next\": \"letter_post\"}, \"letter_post\": {\"speaker\": \"Matriarch Brook\", \"text\": \"May the green hold you on every road, traveler. Tell her, if you pass her again, that the gate is always open.\", \"choices\": [{\"label\": \"I will. Farewell.\", \"next\": \"bye\", \"sets\": \"delivered_brookhold_letter\"}]}, \"after\": {\"speaker\": \"Matriarch Brook\", \"text\": \"Bless you again for that letter, wanderer. The kettle is yours whenever you pass.\"}, \"holding\": {\"speaker\": \"Matriarch Brook\", \"text\": \"We tend the lambwisps and we tend the gate. The brookwater runs sweet here; we keep our share and let the rest go. The Sigil of Sharing is in the very ground.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Matriarch Brook\", \"text\": \"Safe roads. The kin keep watch.\"}}}"

[node name="Npc50_Barn_keeper_Hod" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.540302, 0, 0.841471, 0, 1, 0, -0.841471, 0, 0.540302, 14, 1.925, -8)
npc_name = "Barn-keeper Hod"
body_color = Color(0.5, 0.55, 0.3, 1)
hat_color = Color(0.65, 0.5, 0.2, 1)
idle_hint = "[E] Talk to Hod"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Barn-keeper Hod\", \"text\": \"Mind the gate, mind the latch, mind the little ones in the paddock. Lambwisps don't know fences. They just bump into them and look surprised.\", \"choices\": [{\"label\": \"Tell me of the lambwisps.\", \"next\": \"wisps\"}, {\"label\": \"Tell me of the paddocks.\", \"next\": \"padd\"}, {\"label\": \"I'll be off.\", \"next\": \"bye\"}]}, \"wisps\": {\"speaker\": \"Barn-keeper Hod\", \"text\": \"Little drifting things. Half wool, half wisp. They eat root-greens and chime when they're happy. Lose 'em to the wind if you don't ring the charm at sundown.\", \"choices\": [{\"label\": \"Tell me of the paddocks.\", \"next\": \"padd\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"padd\": {\"speaker\": \"Barn-keeper Hod\", \"text\": \"North paddock for grazing, east for the older flock, south for the lambs. The east gate sticks. I keep meaning to plane it.\", \"choices\": [{\"label\": \"Tell me of the lambwisps.\", \"next\": \"wisps\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Barn-keeper Hod\", \"text\": \"Mind the latch on your way.\"}}}"

[node name="Npc51_Little_Wren" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.416147, 0, -0.909297, 0, 1, 0, 0.909297, 0, -0.416147, -7, 0.796, 11)
npc_name = "Little Wren"
body_color = Color(0.55, 0.7, 0.45, 1)
hat_color = Color(0.85, 0.75, 0.35, 1)
idle_hint = "[E] Talk to Wren"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Little Wren\", \"text\": \"*chases an invisible thing*\\nCome BACK, Tuffins! Tuffins is my favorite lambwisp and she is REALLY FAST and also INVISIBLE because she is hiding which is RUDE.\", \"next\": \"two\"}, \"two\": {\"speaker\": \"Little Wren\", \"text\": \"Have you seen her? She has — well, she has wool. And a chime. And a tiny attitude. ...You haven't, have you. Sigh. *runs off*\"}}}"

[node name="Chest52" parent="." instance=ExtResource("chest")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 10, 0.292, 33)
contents_scene = ExtResource("heart_piece")
open_message = "Where the brook empties into the lambwisp pen — a piece of heart, washed clean and waiting on a stone."

[node name="Npc53_Old_Stone" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -32, 0.631, -1)
npc_name = "Old Stone"
body_color = Color(0.32, 0.28, 0.4, 1)
hat_color = Color(0.45, 0.5, 0.4, 1)
idle_hint = "[E] Touch the stone"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Old Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires_flag\": \"glim_theme_learned\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"glim_theme_learned\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Old Stone\", \"text\": \"Some kin hum the world open. Listen for a wisp; she carries the first note.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Old Stone\", \"text\": \"You have learned to hum. Use the air at every owl-shrine.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Old Stone\", \"text\": \"*The hum fades.*\"}}}"

