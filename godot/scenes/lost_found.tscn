[node name="from_crown" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 0.5, -1.5)

[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0, 2.5)
message = "HALL OF LOST THINGS\n\nThings rescued when their keeping-place broke. Each labelled with a number whose owner has gone elsewhere. The Hall keeps them anyway."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0, 2.5)
message = "A short catalogue, posted by the door:\n\n  No. 14 — A bone-flute mouthpiece, cracked at the rim.\n  No. 27 — One small leather shoe, child-size, left foot.\n  No. 138 — A folded letter, addressed to 'My own one', never delivered.\n\nIf you know the keeper of any of these, speak to Adra."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 0, -1.5)
message = "Pinned beside the keeper's desk:\n\n'Bring three claim-tokens from broken places in the realm and I will give you a piece of heart in return. Walker — you'll know one when you see one.'"

[node name="Npc3_Keeper_Adra" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0, 0.5)
npc_name = "Keeper Adra"
body_color = Color(0.62, 0.55, 0.48, 1)
hat_color = Color(0.45, 0.4, 0.35, 1)
idle_hint = "[E] Speak with the keeper"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Keeper Adra\", \"text\": \"*she looks up slowly, the way someone does when they have been looking at small things for a long while.*\\n\\nWelcome, walker. Welcome to a place that holds things that nothing else holds.\\n\\nWhat have you found?\", \"choices\": [{\"label\": \"(Offer the dyed ribbon.)\", \"next\": \"ribbon_trade\", \"requires_flag\": \"trade_step_4\", \"requires_not\": \"trade_step_5\"}, {\"label\": \"(About that ribbon-shaped kindness...)\", \"next\": \"ribbon_after\", \"requires_flag\": \"trade_step_5\"}, {\"label\": \"What is this place?\", \"next\": \"what\"}, {\"label\": \"What's behind the locked chest?\", \"next\": \"chest\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"ribbon_trade\": {\"speaker\": \"Keeper Adra\", \"text\": \"*she takes the ribbon between two fingers, very carefully, the way one handles a thing whose owner is known.*\\n\\n...oh.\\n\\nOh, walker. This is the dye-work of a child of Hearthold-by-the-kilns. I knew her mother. I held this ribbon's twin in this Hall for nine years before its keeper came back for it. They came back smiling. They came back smiling, walker.\\n\\n*she sets the ribbon into a labelled drawer, slow as a vow. Then she turns and lifts a lacquered box from the shelf behind her.*\\n\\nIn this Hall we keep what was lost. But sometimes the realm gives back what was held — and when it does, the Hall gives back too. Take this. It was kept here for whoever brought a kindness across the realm without dropping it.\\n\\nIt is a heart. A whole one. Yours.\", \"sets_flag\": \"trade_step_5\", \"give_item\": \"heart_container\", \"next\": \"ribbon_close\"}, \"ribbon_close\": {\"speaker\": \"Keeper Adra\", \"text\": \"*she closes the box's lid over your hands, both of hers warm on yours.*\\n\\nWalk well, walker. The Hall will remember the day a ribbon came home. By the Source, that is something.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"ribbon_after\": {\"speaker\": \"Keeper Adra\", \"text\": \"*she smiles, small and kind.*\\n\\nThe ribbon is in its drawer. Its twin is on a shelf in Hearthold, by now — I sent word. The realm carries the kindness on. That is the whole work, in the end.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"Keeper Adra\", \"text\": \"When a chest in the realm breaks open and what was in it tumbles loose, the pieces find their way here. The Source carries them. I catalogue what I can.\\n\\nMost have nobody coming back for them. Some still might.\", \"choices\": [{\"label\": \"Doesn't that get sad?\", \"next\": \"sad\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"sad\": {\"speaker\": \"Keeper Adra\", \"text\": \"*a small, kind smile.*\\n\\nIt got sad once. Now it is just the work. The work is good. The Hall keeps them safe until somebody knows their name again.\\n\\nBy the Source, that is something.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"chest\": {\"speaker\": \"Keeper Adra\", \"text\": \"A piece of heart. I keep it for the walker who brings me three claim-tokens — the small things you find when a chest breaks open in the wild.\\n\\nBring me three. I'll give you the chest. The realm asks no more of either of us.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Keeper Adra\", \"text\": \"Walk well, walker. If you find a small leather shoe, left foot, child-size — come back to me.\"}}}"

