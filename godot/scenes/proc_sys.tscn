[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 1.26, 2.5)
message = "THE MURK SENATE\n\nA roundtable of seven walkers in the fog. They are arguing about settings nobody set, on a thing nobody can name, with consequences nobody can describe.\n\nThey have been at it for some time."

[node name="Npc1_Senator_Olm" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 1.112, -1.5)
npc_name = "Senator Olm"
body_color = Color(0.55, 0.55, 0.6, 1)
hat_color = Color(0.4, 0.42, 0.45, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Senator Olm\", \"text\": \"The number wants to be lower. I have always said the number wants to be lower.\"}}}"

[node name="Npc2_Senator_Bethel" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, 0.564642, 0, 1, 0, -0.564642, 0, 0.825336, 1.5, 1.013, -0.5)
npc_name = "Senator Bethel"
body_color = Color(0.5, 0.55, 0.6, 1)
hat_color = Color(0.45, 0.42, 0.4, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Senator Bethel\", \"text\": \"The number cannot be lower. Olm has been wrong about the number for a long time.\"}}}"

[node name="Npc3_Senator_Reska" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, 0.932039, 0, 1, 0, -0.932039, 0, 0.362358, 1.5, 1.063, 0.5)
npc_name = "Senator Reska"
body_color = Color(0.6, 0.55, 0.55, 1)
hat_color = Color(0.42, 0.4, 0.42, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Senator Reska\", \"text\": \"The number must be considered carefully. We have been considering it carefully for some time.\"}}}"

[node name="Npc4_Senator_Pell" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.416147, 0, 0.909297, 0, 1, 0, -0.909297, 0, -0.416147, 0.5, 1.158, 1.5)
npc_name = "Senator Pell"
body_color = Color(0.55, 0.6, 0.6, 1)
hat_color = Color(0.4, 0.42, 0.42, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Senator Pell\", \"text\": \"Friends, friends — perhaps the number is not the right question. Perhaps the right question is which of us last knew the question.\"}}}"

[node name="Npc5_Senator_Ulor" parent="." instance=ExtResource("npc")]
transform = Transform3D(-0.416147, 0, -0.909297, 0, 1, 0, 0.909297, 0, -0.416147, -0.5, 1.193, 1.5)
npc_name = "Senator Ulor"
body_color = Color(0.5, 0.55, 0.55, 1)
hat_color = Color(0.4, 0.4, 0.42, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Senator Ulor\", \"text\": \"Pell is changing the subject again. Pell is always changing the subject. Khorgaul's grip, Pell.\"}}}"

[node name="Npc6_Senator_Velna" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.362358, 0, -0.932039, 0, 1, 0, 0.932039, 0, 0.362358, -1.5, 1.202, 0.5)
npc_name = "Senator Velna"
body_color = Color(0.55, 0.55, 0.6, 1)
hat_color = Color(0.45, 0.42, 0.4, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Senator Velna\", \"text\": \"Move that we adjourn. ...Move that we have always adjourned. ...Move that we begin to consider a motion to perhaps adjourn.\"}}}"

[node name="Npc7_Senator_Marn" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.825336, 0, -0.564642, 0, 1, 0, 0.564642, 0, 0.825336, -1.5, 1.125, -0.5)
npc_name = "Senator Marn"
body_color = Color(0.6, 0.55, 0.55, 1)
hat_color = Color(0.42, 0.4, 0.42, 1)
idle_hint = "[E] Listen"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Senator Marn\", \"text\": \"Walker — would you cast the deciding voice? ...No, I see, the question has shifted again. Never mind. Walk well.\"}}}"

[node name="Npc8_Top" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 2.5, 1.031, -1.5)
npc_name = "Top"
body_color = Color(0.3, 0.5, 0.65, 1)
hat_color = Color(0.2, 0.3, 0.45, 1)
idle_hint = "[E] Ask Top what's running"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Top\", \"text\": \"*she watches the air the way a hawk watches a field*\\n\\nThe three loudest in the Mount, just now? init at 0.0% — quiet, as he ought to be. wyrdking at — well. wyrdking returns nothing; defeated. and tux, 99%, running. You.\", \"choices\": [{\"label\": \"What about the rest?\", \"next\": \"rest\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"rest\": {\"speaker\": \"Top\", \"text\": \"Sleeping. Waiting. A few zombies the wardens have not got to. The realm hums. I listen.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Top\", \"text\": \"*she resumes listening*\"}}}"

