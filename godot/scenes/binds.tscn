[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -3, -0.007, 9)
message = "POSTED — Guild Bylaws\n\n1. Stalls open at first bell.\n2. Coins counted twice.\n3. No haggling on holy days.\n\n(no one observes #3)"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 3, -0.253, 9)
message = "PRICES TODAY\n\nSalt — 2 chips a measure\nKnot-rope — 1 chip a fathom\nSweetwood — by the bundle\nPromises — free, expire at dusk"

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -9, 0.673, 4)
message = "NOTICE\n\nLost: a small dog answering to “Crumb.”\nReward in chips. No questions asked.\n\n— Stallkeep Manda"

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 9, -0.403, -3)
message = "WARNING\n\nThe alley past the second lamp is uneven.\nThe Guild is not liable for sprains, twists,\nor things you tripped on while cursing the Guild."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -9, 1.311, -10)
message = "POSTED\n\nPickpockets shall be named on the bell-board\nfor a turn of seven days, then forgiven.\nThe board has names on it. So does the wall behind it."

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 9, -0.594, -10)
message = "INSCRIPTION (worn)\n\n“Trade is the smaller breath of Lirien —\nshorter, but it carries grain.”"

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 1.427, -12)
message = "ANNOUNCEMENT\n\nThe Old Quarter scales were re-cut at the spring forge.\nIf yours weighs short, that is between you and your conscience."

