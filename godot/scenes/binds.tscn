[node name="Npc28_Stallkeep_Manda" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.707105, 0, -0.707108, 0, 1, 0, 0.707108, 0, 0.707105, -4, 0.105, 3)
npc_name = "Stallkeep Manda"
body_color = Color(0.55, 0.4, 0.5, 1)
hat_color = Color(0.85, 0.55, 0.3, 1)
idle_hint = "[E] Talk to Manda"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Manda\", \"text\": \"Look at you. Light pouch, heavy step. Tell me what you're after and I'll tell you what it costs.\", \"choices\": [{\"label\": \"What do you sell?\", \"next\": \"sell\"}, {\"label\": \"I'm just browsing.\", \"next\": \"brows\"}, {\"label\": \"I'm flattered, I think.\", \"next\": \"flirt\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"sell\": {\"speaker\": \"Manda\", \"text\": \"Today? Nothing. Tomorrow? Whatever you'd pay for. Come back tomorrow.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"brows\": {\"speaker\": \"Manda\", \"text\": \"Browse, then. The shelves are on me. The looking, half-price.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"flirt\": {\"speaker\": \"Manda\", \"text\": \"Don't be. I flirt with the till too. ...Mostly the till.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Manda\", \"text\": \"Back tomorrow. Bring chips.\"}}}"

[node name="Npc29_Bureaucrat_Imon" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.707105, 0, 0.707108, 0, 1, 0, -0.707108, 0, 0.707105, 4, 0.109, 3)
npc_name = "Bureaucrat Imon"
body_color = Color(0.45, 0.45, 0.55, 1)
hat_color = Color(0.25, 0.25, 0.35, 1)
idle_hint = "[E] Listen to Imon"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Bureaucrat Imon\", \"text\": \"*(unrolls a scroll)* Bylaw nine, subsection three: ‘No coin shall be cast in anger.’ ...And yet, every market-day...\", \"choices\": [{\"label\": \"Read me another.\", \"next\": \"another\"}, {\"label\": \"Does anyone follow these?\", \"next\": \"follow\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"another\": {\"speaker\": \"Bureaucrat Imon\", \"text\": \"Bylaw twelve: ‘All wagers shall be witnessed by a sober party.’ The Guild keeps no record of a sober party in the Binds.\", \"choices\": [{\"label\": \"Another.\", \"next\": \"another2\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"another2\": {\"speaker\": \"Bureaucrat Imon\", \"text\": \"Bylaw seventeen, omnibus: ‘Honesty is best. Where impractical, courtesy.’ My favourite, in the dignified sense.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"follow\": {\"speaker\": \"Bureaucrat Imon\", \"text\": \"Follow them? Dear walker, the bylaws are not for following. They are for *citing*.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Bureaucrat Imon\", \"text\": \"Walk well. Cite kindly.\"}}}"

[node name="Npc30_apt" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.540302, 0, -0.841471, 0, 1, 0, 0.841471, 0, 0.540302, -7, 0.194, -2)
npc_name = "apt"
body_color = Color(0.5, 0.4, 0.32, 1)
hat_color = Color(0.6, 0.4, 0.2, 1)
idle_hint = "[E] apt"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"apt\", \"text\": \"What do you need? I keep the index. Pebbles in, packages out.\", \"choices\": [{\"label\": \"Show me your wares.\", \"next\": \"wares\"}, {\"label\": \"What are you, exactly?\", \"next\": \"what\"}, {\"label\": \"Any advice?\", \"next\": \"advice\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"what\": {\"speaker\": \"apt\", \"text\": \"A tool-spirit of the Binds. I install. I update. I don't haggle — the price is the price.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"advice\": {\"speaker\": \"apt\", \"text\": \"Take `man` first if you can spare eight pebbles. Reading the page beats guessing the flag.\", \"choices\": [{\"label\": \"Show me.\", \"next\": \"wares\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"wares\": {\"speaker\": \"apt\", \"text\": \"Cache is fresh. Pick a name; I'll fetch it.\", \"choices\": [{\"label\": \"apt install.\", \"opens_shop\": [\"heart\", \"arrow\", \"seed\", \"wget\", \"man\"]}, {\"label\": \"Maybe later.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"apt\", \"text\": \"Walk well. Run `apt update` once in a while.\"}}}"

[node name="Npc31_Trader_Kel" parent="." instance=ExtResource("npc")]
transform = Transform3D(0.540302, 0, 0.841471, 0, 1, 0, -0.841471, 0, 0.540302, 7, 0.189, -2)
npc_name = "Trader Kel"
body_color = Color(0.7, 0.55, 0.3, 1)
hat_color = Color(0.95, 0.7, 0.2, 1)
idle_hint = "[E] Talk to Kel"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Trader Kel\", \"text\": \"Step UP, walker, step UP! Bottled birdsong! Salt that remembers its sea! A coin polished by a passing breath of Lirien!\", \"choices\": [{\"label\": \"Bottled birdsong?\", \"next\": \"bird\"}, {\"label\": \"A polished coin?\", \"next\": \"coin\"}, {\"label\": \"I'll pass.\", \"next\": \"bye\"}]}, \"bird\": {\"speaker\": \"Trader Kel\", \"text\": \"Genuine. Mostly. Caught fresh at dawn, bottled by mid-morning, marked down by lunch.\", \"choices\": [{\"label\": \"Anything else?\", \"next\": \"coin\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"coin\": {\"speaker\": \"Trader Kel\", \"text\": \"She passed by, didn't notice me — but the breath caught the coin as she went. You can FEEL the polish, walker. Three chips.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Trader Kel\", \"text\": \"Your loss! Probably! Step well!\"}}}"

[node name="Npc32_Rin" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -12, 0.539, -8)
npc_name = "Rin"
body_color = Color(0.3, 0.3, 0.35, 1)
hat_color = Color(0.2, 0.2, 0.25, 1)
idle_hint = "[E] Speak softly"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Rin\", \"text\": \"...You spoke first. Most don't. Most cross the alley.\", \"choices\": [{\"label\": \"Are you alright?\", \"next\": \"alright\"}, {\"label\": \"Why are you here?\", \"next\": \"why\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"alright\": {\"speaker\": \"Rin\", \"text\": \"Better than I deserve. I lifted purses for a turn of years. I gave it up. The Guild doesn't know yet. I'll tell them. ...In the next breath.\", \"choices\": [{\"label\": \"Why give it up?\", \"next\": \"why\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"why\": {\"speaker\": \"Rin\", \"text\": \"I lifted from a Sharer once. He smiled when he found out. Said the loss was a poem he hadn't written yet. I haven't slept right since.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Rin\", \"text\": \"Walk well. Mind your purse, all the same — habit's hard to lose.\"}}}"

[node name="Npc33_Vim_the_Modal" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, -1, 0.271, 0)
npc_name = "Vim the Modal"
body_color = Color(0.2, 0.5, 0.2, 1)
hat_color = Color(0.1, 0.35, 0.1, 1)
idle_hint = "[E] Speak with Vim"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Vim the Modal\", \"text\": \"I have lived in this town for forty years and I still cannot leave. *he gestures helplessly* I have tried :q. I have tried :q!. The door does not open. I do not know which mode I am in.\", \"choices\": [{\"label\": \"Try :wq?\", \"next\": \"wq\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"wq\": {\"speaker\": \"Vim the Modal\", \"text\": \"I have not written the changes. There are no changes. There are only forty years and a door that will not.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Vim the Modal\", \"text\": \"*he stares at the door*\"}}}"

[node name="Npc34_Emaca_the_Boundless" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, 2, 0.35, -1)
npc_name = "Emaca the Boundless"
body_color = Color(0.45, 0.25, 0.5, 1)
hat_color = Color(0.6, 0.35, 0.7, 1)
idle_hint = "[E] Speak with Emaca"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Emaca the Boundless\", \"text\": \"I have built an entire realm inside this kitchen. I read my mail in the soup. I balance the ledger in the bread. I draft a treatise while the pot boils.\\n\\n*she gestures at Vim across the way* He cannot leave because he has not learned to bring the whole world inside.\", \"choices\": [{\"label\": \"...Doesn't that get exhausting?\", \"next\": \"ex\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"ex\": {\"speaker\": \"Emaca the Boundless\", \"text\": \"Only the keyboard. *she flexes her hand* The chord is C-x C-c. I will press it when I am ready. Not before.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Emaca the Boundless\", \"text\": \"*she returns to seven things at once*\"}}}"

