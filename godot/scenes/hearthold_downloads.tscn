[node name="Npc0_Tem_the_Hoarder" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 1.549, 0)
npc_name = "Tem the Hoarder"
body_color = Color(0.62, 0.45, 0.3, 1)
hat_color = Color(0.45, 0.3, 0.2, 1)
idle_hint = "[E] Speak with Tem"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Tem the Hoarder\", \"text\": \"Oh, friend, you've come at a busy time. I'm sorting.\\nOr I'm about to sort. I've been about to sort for a while.\", \"choices\": [{\"label\": \"What are these chests?\", \"next\": \"chests\"}, {\"label\": \"Why so many?\", \"next\": \"why\"}, {\"label\": \"Walk well.\"}]}, \"chests\": {\"speaker\": \"Tem the Hoarder\", \"text\": \"Things I asked for and meant to look at. Some of them I\\nremember asking for. Most I do not.\", \"choices\": [{\"label\": \"Can I open them?\", \"next\": \"open\"}]}, \"open\": {\"speaker\": \"Tem the Hoarder\", \"text\": \"Please. If something rolls out and you can use it,\\nit's yours. That's how it should work, isn't it.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"why\": {\"speaker\": \"Tem the Hoarder\", \"text\": \"Have you ever clicked something and then walked away\\nbefore it finished? I have done that for a lifetime.\", \"choices\": [{\"label\": \"...\"}]}}}"

