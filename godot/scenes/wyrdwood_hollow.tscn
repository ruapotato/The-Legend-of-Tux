hat_color = Color(0.7, 0.55, 0.3, 1)
dialog_tree_json = "{\"start\": {\"text\": \"'The bark round is light because hands tire. Heavier is not always better. Tell Brann I said so.'\"}}"

[node name="NPC4" parent="Placed" instance=ExtResource("r16")]
transform = Transform3D(0.5, 0, 0.866025, 0, 1, 0, -0.866025, 0, 0.5, -13, 0, 16)
