dialog_tree_json = "{\"start\": {\"text\": \"'I carved that little blade myself. It'll bend before it breaks. So would I, mind.'\"}}"

[node name="NPC3" parent="Placed" instance=ExtResource("r16")]
transform = Transform3D(0, 0, -1, 0, 1, 0, 1, 0, 0, 12, 0, -7)
