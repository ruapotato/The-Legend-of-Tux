[node name="Npc0_Syslog_Keeper" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 1.845, 0)
npc_name = "Syslog Keeper"
body_color = Color(0.62, 0.55, 0.62, 1)
hat_color = Color(0.42, 0.35, 0.42, 1)
idle_hint = "[E] Hear the latest entry"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Syslog Keeper\", \"text\": \"I am the Syslog Keeper. I read what just happened.\\n\\nMost recent: `[INFO] tux logged in`.\", \"choices\": [{\"label\": \"Read me an older one.\", \"next\": \"warn\"}, {\"label\": \"Walk well.\"}]}, \"warn\": {\"speaker\": \"Syslog Keeper\", \"text\": \"`[WARN] Wyrdking memory low`.\\n\\nWe're not sure what that meant. The Wyrdking did not say.\", \"choices\": [{\"label\": \"Another?\", \"next\": \"err\"}, {\"label\": \"Walk well.\"}]}, \"err\": {\"speaker\": \"Syslog Keeper\", \"text\": \"`[ERROR] segfault in /dev/forge`.\\n\\nSomething fell over in the Forge. Something always is.\", \"choices\": [{\"label\": \"One more.\", \"next\": \"cron\"}, {\"label\": \"Walk well.\"}]}, \"cron\": {\"speaker\": \"Syslog Keeper\", \"text\": \"`[INFO] cron job at midnight succeeded`.\\n\\nGlim flickers when I read that one. I have not asked\\nGlim why.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 1.266, -3)
message = "Running scroll, left wall:\n\n`[INFO] tux logged in`\n`[INFO] cd /opt/wyrdmark/glade`\n`[INFO] entered scene wyrdkin_glade`"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 1.426, -3)
message = "Running scroll, right wall:\n\n`[WARN] Wyrdking memory low`\n`[INFO] cron job at midnight succeeded`\n`[ERROR] segfault in /dev/forge`"

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 1.17, 4)
message = "Records what happens, not what should.\n\nThe Keeper says this often. The Keeper is correct."

[node name="Chest4" parent="." instance=ExtResource("chest")]
