contents_scene = ExtResource("heart_piece")
open_message = "Where six paths meet, in the herb-circle the Burrowers planted to mark the crossroads. A heart-pulse, kept warm by the noon sun."

[node name="Npc2_Wayfarer_s_Stone" parent="." instance=ExtResource("npc")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -3, 3.209, 3)
npc_name = "Wayfarer's Stone"
body_color = Color(0.32, 0.28, 0.4, 1)
hat_color = Color(0.45, 0.5, 0.4, 1)
idle_hint = "[E] Touch the stone"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Wayfarer's Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires_flag\": \"triglyph_assembled\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"triglyph_assembled\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Wayfarer's Stone\", \"text\": \"Every village south of here climbs back to home. Climb far enough and you reach the Crown.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Wayfarer's Stone\", \"text\": \"The chord is yours. The Door listens for it now.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Wayfarer's Stone\", \"text\": \"*The hum fades.*\"}}}"

