transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 1.81, -0.5)

[node name="from_burrows" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, 1.83, -1.5)

[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0, 2.5)
message = "THE KHORGAUL ROOST\n\nA burned-out hilltop hold. Charred furniture. Wind through broken stone. Some things are still warm to the touch — though no fire has been laid here for years.\n\nThe Drawing-In started somewhere. It might have started here."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0, 2.5)
message = "Scorched stone marker:\n\n'The Roost burned in a season nobody wrote down. The wind takes the ash a little further every year. By the time you read this it may already be gone.'"

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.5, 0, -1.5)
message = "Charred floorboards. A handful of black feathers in a corner. The smell is faint but familiar — old smoke, and something underneath it that doesn't have a clean name."

[node name="Npc3_Cultist_Drev" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0, 0.5)
npc_name = "Cultist Drev"
body_color = Color(0.32, 0.28, 0.3, 1)
hat_color = Color(0.55, 0.42, 0.32, 1)
idle_hint = "[E] Speak with the cultist"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Cultist Drev\", \"text\": \"*he is sweeping ash, slowly. The broom is older than he is. He looks up with the friendliness of a man who has not had visitors in a long while.*\\n\\nWelcome, friend. Welcome to the Roost. The Master is away on long business — but he'll be back, oh yes. He'll be back any day now.\", \"choices\": [{\"label\": \"How long ago did the Roost burn?\", \"next\": \"burn\"}, {\"label\": \"When did you last see your master?\", \"next\": \"last\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"burn\": {\"speaker\": \"Cultist Drev\", \"text\": \"Burn? *he looks confused.*\\n\\nThere was — there was a season of bad lightning, perhaps. The roof needs work. The Master will see to it when he returns.\\n\\n*the wind moves a piece of burnt cloth across the floor. He doesn't seem to notice it.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"last\": {\"speaker\": \"Cultist Drev\", \"text\": \"Last? Oh, not long. Not long at all. I keep his rooms in order. He'll be back in the next breath, or the breath after, or the one after that.\\n\\nWalker — would you like a cup of something? I have... I had... let me see what we have.\\n\\n*he doesn't move.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Cultist Drev\", \"text\": \"Walk well. Tell the Master, if you see him on the road, that the Roost is kept. The Roost is kept.\"}}}"

