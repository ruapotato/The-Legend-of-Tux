[node name="Tux" parent="." instance=ExtResource("tux")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.5, 0)
camera_path = NodePath("../Camera")

[node name="Glim" parent="." instance=ExtResource("glim")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -0.6, 1.4, 0)

[node name="Camera" type="Node3D" parent="."]
script = ExtResource("camera_script")

[node name="SpringArm" type="SpringArm3D" parent="Camera"]
