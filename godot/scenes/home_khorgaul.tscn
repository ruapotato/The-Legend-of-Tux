[node name="SpringArm" type="SpringArm3D" parent="Camera"]
spring_length = 4.5
margin = 0.05

[node name="Camera" type="Camera3D" parent="Camera/SpringArm"]
fov = 70.0

[node name="HUD" parent="." instance=ExtResource("hud")]

[node name="DebugOverlay" type="CanvasLayer" parent="."]
script = ExtResource("debug_script")
visible_initial = false

[node name="PauseMenu" type="CanvasLayer" parent="."]
script = ExtResource("pause_script")
