dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Threshold Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires\": \"wyrdking_defeated\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"wyrdking_defeated\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Threshold Stone\", \"text\": \"The Wyrdmark welcomes those who walk in Lirien's breath.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Threshold Stone\", \"text\": \"You walk far. The path remembers you.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Threshold Stone\", \"text\": \"*The hum fades.*\"}}}"

