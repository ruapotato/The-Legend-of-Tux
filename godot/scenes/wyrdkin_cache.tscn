[node name="Npc0_Cache_Pantry_Keeper" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 2.01, 0)
npc_name = "Cache Pantry-Keeper"
body_color = Color(0.62, 0.62, 0.55, 1)
hat_color = Color(0.45, 0.42, 0.35, 1)
idle_hint = "[E] Speak to the Keeper"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Cache Pantry-Keeper\", \"text\": \"Mind your step. The shelves remember being full.\\nMost of what's here is from yesterday. Some is older.\", \"choices\": [{\"label\": \"Is any of it good?\", \"next\": \"good\"}, {\"label\": \"Why keep it?\", \"next\": \"keep\"}, {\"label\": \"Walk well.\"}]}, \"good\": {\"speaker\": \"Cache Pantry-Keeper\", \"text\": \"Stale, but here. That's not nothing. Some days a stale\\nthing close at hand is better than a fresh thing far away.\", \"choices\": [{\"label\": \"Walk well.\"}]}, \"keep\": {\"speaker\": \"Cache Pantry-Keeper\", \"text\": \"It costs nothing to keep, mostly. And clearing takes\\nthe kind of attention I don't always have.\\n`rm -rf ~/.cache` — safe to clear, they say.\", \"choices\": [{\"label\": \"Walk well.\"}]}}}"

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -3, 2.474, -1)
message = "`rm -rf ~/.cache` — safe to clear.\n\nThe kin repeat this like a prayer. Nobody ever does it."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 3, 3.004, -1)
message = "A shelf of jars labelled by date.\n\nThe newest is a week old. The oldest predates the\nDrawing-In."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, 1.149, 4)
message = "Damp stone underfoot. The air smells like an offering\nleft out too long."

[node name="Chest4" parent="." instance=ExtResource("chest")]
