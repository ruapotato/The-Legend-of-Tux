[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 0, -0.73, 12)
message = "The Ledger.\n\nThe running record of the realm. Speak softly — the scribes are listening for inscriptions."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, -12, 0.3, -8)
message = "A pinned snippet, recently inked:\n\n\"...the seventh wardstone in Sigilkeep dimmed at the third hour of the morning, and brightened at the fourth, with no walker seen near it.\""

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, 12, -0.392, -8)
message = "A folded notice, weighted with a stone:\n\n\"NOTICE. An unusually large number of un-quieted appeared in the Murk last cycle. The Hidden Choir is consulted. Walkers are advised to keep to lit paths.\""

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, -12, -0.251, 6)
message = "A wood plaque polished by hands:\n\n\"In memory of the Senior Scribes — Vael the elder, Anth the long-handed, Tarn who kept the longest scroll, and Pell the first.\""

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, 12, -0.938, 6)
message = "A small inscription card:\n\n\"...and on the morning of the fourth thinning, the Source was held for the length of one breath, and three Readers fainted, and the realm continued.\""

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -6, 0.198, -10)
message = "A loose page held under a stone weight:\n\n\"...a child in Hearthold asked where her grandfather was buried. The Senior Scribe noted the question. The answer was not given.\""

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 6, -0.034, -10)
message = "A small marker pinned to a beam:\n\n\"Inscriptions from the Burnt Hollow have been arriving in a hand none of us writes. We copy them faithfully. We do not ask.\""

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, -6, -0.098, 0)
message = "A weather-stained note:\n\n\"...the rooks of Hearthold sang at first light, and the Source was full in the air, and a small walker passed under the gate. We marked the line. Walk well.\""

[node name="Sign8" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -2.65359e-06, 0, 1, 0, 2.65359e-06, 0, -1, 6, -0.371, 0)
message = "An old proclamation, framed:\n\n\"By the keepers of the Ledger: the running scroll shall not be cut. What is begun is recorded entire. Brevity is for kinder rooms.\""

