dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Veiled Stone\", \"text\": \"*A faint hum, like wind through stone…*\", \"choices\": [{\"label\": \"Listen.\", \"next\": \"hint_post\", \"requires\": \"glim_sight\"}, {\"label\": \"Listen.\", \"next\": \"hint_pre\", \"requires_not\": \"glim_sight\"}, {\"label\": \"(Walk on.)\", \"next\": \"bye\"}]}, \"hint_pre\": {\"speaker\": \"Veiled Stone\", \"text\": \"What you cannot see is still there. The Lens shows what hides between the lines.\", \"next\": \"bye\"}, \"hint_post\": {\"speaker\": \"Veiled Stone\", \"text\": \"Now you may face the Censor. Walk where ink dares not.\", \"next\": \"bye\"}, \"bye\": {\"speaker\": \"Veiled Stone\", \"text\": \"*The hum fades.*\"}}}"

