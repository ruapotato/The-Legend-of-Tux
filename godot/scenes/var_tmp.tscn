[node name="from_library" type="Marker3D" parent="Spawns"]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 0.5, -0.09, -1.5)

[node name="Sign0" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -2.5, 0, 2.5)
message = "THE LONG DRIFT\n\nA quieter sister-festival to the Drift. Things here are forgotten across more than one day, but eventually still go.\n\nA few people stay anyway."

[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, 2.5, 0, 2.5)
message = "Carved into a sun-faded post:\n\n'STILL WAITING.'"

[node name="Npc2_Festival_Goer_Pyt" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -0.5, 0, 0.5)
npc_name = "Festival-Goer Pyt"
body_color = Color(0.7, 0.6, 0.5, 1)
hat_color = Color(0.95, 0.55, 0.55, 1)
idle_hint = "[E] Speak with the festival-goer"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Festival-Goer Pyt\", \"text\": \"*he sits on a barrel. He is wearing what was a festival hat a year ago. The food on his plate has been there for a while.*\\n\\nWalker. Welcome to the festival. Such as it is.\\n\\nI was supposed to meet someone here. They were supposed to come back the next day. The next day was a year ago.\", \"choices\": [{\"label\": \"Have you tried going home?\", \"next\": \"home\"}, {\"label\": \"Who were you waiting for?\", \"next\": \"who\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"home\": {\"speaker\": \"Festival-Goer Pyt\", \"text\": \"*he smiles. The smile is gentle.*\\n\\nNot yet. Not yet, walker. The next breath. Maybe the breath after.\\n\\nIf I leave and they come back and I'm not here, they'll think I forgot. The Drift forgets. The Long Drift remembers a little. I remember a lot.\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"who\": {\"speaker\": \"Festival-Goer Pyt\", \"text\": \"A friend. Just a friend. The kind of friend you don't have many of.\\n\\nI'm sure they're fine. The road is the road. They'll be back.\\n\\n*he looks at the empty plate.*\", \"choices\": [{\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"bye\": {\"speaker\": \"Festival-Goer Pyt\", \"text\": \"Walk well. If you see anyone on the road who looks like they might be coming this way — point them at the post. The post says 'still waiting'. They'll know.\"}}}"

