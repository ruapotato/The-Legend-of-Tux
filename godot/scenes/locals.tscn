[node name="Sign1" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -3, 0.224, 9)
message = "POSTED LAW\n\n1. Visitors check in with the sheriff.\n2. No torches in the dry months.\n3. We mind our own. We expect the same."

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 3, 0.313, 9)
message = "WARNING\n\nA bone knight wanders the outer edge.\nThe sheriff hasn't dealt with it yet.\nKeep your distance and your wits."

[node name="Sign3" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -9, 0.072, 4)
message = "MEMORIAL\n\nFor those who came to the frontier\nand did not come back.\n\nNames carved here:\nKell. Mar. Old Bren. Two children\nwhose names are still painted on the\nporch beside their mother's door."

[node name="Sign4" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 9, 1.114, 4)
message = "WARNING\n\nThe rafters of the lower hall\nhave a bat. We know.\nIt eats well. Leave it."

[node name="Sign5" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -9, 0.61, -4)
message = "POSTED\n\nWater from the south well only.\nThe north well has gone bitter.\nIt has been bitter since the\nDrawing-In passed by."

[node name="Sign6" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 9, 0.77, -4)
message = "NOTICE\n\nNew arrivals from the Drift welcome.\nQuiet preferred. Most of us\ncame here to be left alone\nand we extend the courtesy."

[node name="Sign7" parent="." instance=ExtResource("sign")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.554, -11)
message = "EDGE OF TOWN\n\nBeyond this point: scrub, wind,\nand whatever Khorgaul's grip has left.\nWalk armed. Walk back."

