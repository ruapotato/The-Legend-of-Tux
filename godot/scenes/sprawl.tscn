[node name="Npc9_Sela_the_Bind_rep" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 8, 0.576, -1.5)
npc_name = "Sela the Bind-rep"
body_color = Color(0.55, 0.45, 0.35, 1)
hat_color = Color(0.7, 0.55, 0.25, 1)
idle_hint = "[E] Speak with Sela"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Sela\", \"text\": \"Wanderer. If you've coin, head to the alleys yonder. If you've ears, mind which side of the plaza you bend them to.\", \"choices\": [{\"label\": \"What do the Binds trade?\", \"next\": \"trade\"}, {\"label\": \"What of the Sharers?\", \"next\": \"sharers\"}, {\"label\": \"And the Locals?\", \"next\": \"locals\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"trade\": {\"speaker\": \"Sela\", \"text\": \"Iron, salt, sweetwood, knot-rope. Whatever moves at a fair price. We don't sell air — leave that to the poets across the way.\", \"choices\": [{\"label\": \"About those poets...\", \"next\": \"sharers\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"sharers\": {\"speaker\": \"Sela\", \"text\": \"Insufferable, in the politest terms. They say they're the soul of the Sprawl. The soul does not weigh out grain at dusk. We do.\", \"choices\": [{\"label\": \"Tell me about trade.\", \"next\": \"trade\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"locals\": {\"speaker\": \"Sela\", \"text\": \"Honest folk. Suspicious folk. They keep their gate closed and their porch swept. I respect that, even when they snub our scales.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Sela\", \"text\": \"Mind your purse. The plaza's quieter than it looks.\"}}}"

[node name="Npc10_Vahn_the_Sharer" parent="." instance=ExtResource("npc")]
transform = Transform3D(-3.67321e-06, 0, -1, 0, 1, 0, 1, 0, -3.67321e-06, -8, -0.124, -1.5)
npc_name = "Vahn the Sharer"
body_color = Color(0.55, 0.6, 0.8, 1)
hat_color = Color(0.85, 0.8, 0.55, 1)
idle_hint = "[E] Speak with Vahn"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Vahn\", \"text\": \"Walk well, walker. You stand on the only patch of ground in the Sprawl that all three peoples agree is no one's. Beautiful, isn't it.\", \"choices\": [{\"label\": \"Tell me of the Sharers.\", \"next\": \"sharers\"}, {\"label\": \"Recite something.\", \"next\": \"verse\"}, {\"label\": \"Why this plaza?\", \"next\": \"plaza\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"sharers\": {\"speaker\": \"Vahn\", \"text\": \"We tend the verses, the plinths, the bell. The Binds say we sell nothing. We give. They cannot tell the difference — which, I suppose, is the difference.\", \"choices\": [{\"label\": \"Recite something.\", \"next\": \"verse\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"verse\": {\"speaker\": \"Vahn\", \"text\": \"*“Three roads, one breath.\\nThe stones forget their cutters,\\nthe bell forgets its hour,\\nbut the air remembers we stood here.”*\", \"choices\": [{\"label\": \"Beautiful.\", \"next\": \"thanks\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"thanks\": {\"speaker\": \"Vahn\", \"text\": \"Lirien's breath. Few say so without a smirk these days.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"plaza\": {\"speaker\": \"Vahn\", \"text\": \"Older than any of us, the agreement. The pillar there is older than the agreement. The stones beneath the pillar — older yet. We are the youngest things here.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Vahn\", \"text\": \"Walk well, and listen as you go.\"}}}"

[node name="Npc11_Garth_the_Local" parent="." instance=ExtResource("npc")]
transform = Transform3D(-1, 0, -1.22465e-16, 0, 1, 0, 1.22465e-16, 0, -1, -1.5, -0.894, 8)
npc_name = "Garth the Local"
body_color = Color(0.42, 0.36, 0.3, 1)
hat_color = Color(0.35, 0.28, 0.2, 1)
idle_hint = "[E] Speak with Garth"
dialog_tree_json = "{\"start\": \"root\", \"nodes\": {\"root\": {\"speaker\": \"Garth\", \"text\": \"What.\", \"choices\": [{\"label\": \"I'm just passing through.\", \"next\": \"pass\"}, {\"label\": \"Tell me about the frontier.\", \"next\": \"frontier\"}, {\"label\": \"What's the standoff about?\", \"next\": \"standoff\"}, {\"label\": \"Walk well.\", \"next\": \"bye\"}]}, \"pass\": {\"speaker\": \"Garth\", \"text\": \"Good. Pass through, then. ...You're not armed like a cutpurse. That's something.\", \"choices\": [{\"label\": \"Tell me about the frontier.\", \"next\": \"frontier\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"frontier\": {\"speaker\": \"Garth\", \"text\": \"Hard wood. Hard wind. The kind of quiet that makes a man hear his own thoughts and not like them. We build, we mend, we keep watch. It suits us.\", \"choices\": [{\"label\": \"What's the standoff about?\", \"next\": \"standoff\"}, {\"label\": \"Back.\", \"next\": \"root\"}]}, \"standoff\": {\"speaker\": \"Garth\", \"text\": \"Couldn't tell you. The Binds reckon coin. The Sharers reckon verses. We reckon neither and neither reckons us. The pillar reckons all three, and says nothing.\", \"choices\": [{\"label\": \"Back.\", \"next\": \"root\"}]}, \"bye\": {\"speaker\": \"Garth\", \"text\": \"Mind the road.\"}}}"

