[node name="Rock1" parent="." instance=ExtResource("rock")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.512, 0)

[node name="Sign2" parent="." instance=ExtResource("sign")]
transform = Transform3D(-3.67321e-06, 0, 1, 0, 1, 0, -1, 0, -3.67321e-06, 1.6, -0.454, 0)
message = "Here three peoples agreed not to fight.\n\nThe agreement is older than any of them remember; none can name what it was made over."

