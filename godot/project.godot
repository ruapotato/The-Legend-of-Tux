; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="The Legend of Tux"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")

[autoload]

GameState="*res://scripts/game_state.gd"
SoundBank="*res://scripts/sound_bank.gd"
MusicBank="*res://scripts/music_bank.gd"
Dialog="*res://scripts/dialog.gd"
SceneFader="*res://scripts/scene_fader.gd"
WorldEvents="*res://scripts/world_events.gd"
TimeOfDay="*res://scripts/time_of_day.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

